{# templates/main/waitlist_success.html.twig #}
{% extends 'base_prospect.html.twig' %}

{% block title %}Welcome to the Waitlist! - Forecastly{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('waitlist_css') }}
{% endblock %}

{% block body_class %}waitlist-success-body{% endblock %}

{% block body %}
    <div class="waitlist-success">
        <div class="container">
            <div class="success-card">

                {# Flash messages #}
                {% for message in app.flashes('success') %}
                    <div class="alert alert-success">
                        <i class="fas fa-check-circle"></i>
                        {{ message }}
                    </div>
                {% endfor %}

                {% for message in app.flashes('error') %}
                    <div class="alert alert-error">
                        <i class="fas fa-exclamation-circle"></i>
                        {{ message }}
                    </div>
                {% endfor %}

                <div class="success-icon">
                    <i class="fas fa-check-circle"></i>
                </div>

                <h1>You're on the List! 🎉</h1>

                <div class="success-content">
                    <p class="success-message">
                        Thank you for joining the Forecastly waitlist! We're excited to have you on board.
                    </p>

                    <div class="next-steps">
                        <h3>What Happens Next?</h3>
                        <div class="steps-grid">
                            <div class="step-item">
                                <div class="step-number">1</div>
                                <div class="step-content">
                                    <h4>Confirmation Email</h4>
                                    <p>Check your inbox for a welcome email from us</p>
                                </div>
                            </div>
                            <div class="step-item">
                                <div class="step-number">2</div>
                                <div class="step-content">
                                    <h4>Early Access Invite</h4>
                                    <p>We'll notify you when early access becomes available</p>
                                </div>
                            </div>
                            <div class="step-item">
                                <div class="step-number">3</div>
                                <div class="step-content">
                                    <h4>Launch Day</h4>
                                    <p>Be the first to experience Forecastly's powerful features</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="share-section">
                        <h3>Help Others Discover Forecastly</h3>
                        <p>Share the waitlist with friends and colleagues</p>
                        <div class="share-buttons">
                            <a href="https://twitter.com/intent/tweet?text=Join%20the%20Forecastly%20waitlist%20for%20intelligent%20financial%20forecasting%20and%20wealth%20management%20%40forecastly"
                               target="_blank" class="btn btn-twitter">
                                <i class="fab fa-twitter"></i>
                                Share on Twitter
                            </a>
                            <a href="https://www.linkedin.com/sharing/share-offsite/?url={{ app.request.uri }}"
                               target="_blank" class="btn btn-linkedin">
                                <i class="fab fa-linkedin"></i>
                                Share on LinkedIn
                            </a>
                        </div>
                    </div>

                    <div class="action-buttons">
                        <a href="{{ path('main_index') }}" class="btn btn-secondary">
                            <i class="fas fa-home"></i>
                            Back to Home
                        </a>
                        <a href="{{ path('main_contact_support') }}" class="btn btn-primary">
                            <i class="fas fa-question-circle"></i>
                            Have Questions?
                        </a>
                    </div>
                </div>
                <br /><p style="font-size: smaller;">&copy; 2025 Meridian Wealth Technologies, LLC. All rights reserved.</p>
            </div>
        </div>
    </div>
{% endblock %}