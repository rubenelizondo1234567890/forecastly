{# templates/main/unsubscribe.html.twig #}
{% extends 'base_prospect.html.twig' %}

{% block title %}Unsubscribed from Forecastly Waitlist{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('waitlist_css') }}
{% endblock %}

{% block body_class %}waitlist-success-body{% endblock %}

{% block body %}
    <div class="waitlist-success">
        <div class="container">
            <div class="success-card">
                <div class="success-icon">
                    <i class="fas fa-envelope-open-text"></i>
                </div>

                <h1>Successfully Unsubscribed</h1>

                <div class="success-message">
                    <p>You have been successfully unsubscribed from Forecastly waitlist communications.</p>
                    <p><strong>Email:</strong> {{ email }}</p>
                    {% if name %}
                        <p><strong>Name:</strong> {{ name }}</p>
                    {% endif %}
                </div>

                <div class="unsubscribe-details" style="background: rgba(94, 96, 206, 0.05); padding: 20px; border-radius: 10px; margin: 20px 0;">
                    <h3 style="color: var(--primary); margin-bottom: 15px;">What this means:</h3>
                    <ul style="text-align: left; color: var(--text-light);">
                        <li>You will no longer receive waitlist updates</li>
                        <li>You will not be notified when early access becomes available</li>
                        <li>You will not receive product updates or financial tips</li>
                    </ul>
                </div>

                <div class="action-buttons">
                    <a href="{{ path('main_index') }}" class="btn btn-primary">
                        <i class="fas fa-home"></i>
                        Return to Homepage
                    </a>
                    <p style="margin-top: 15px; color: var(--text-light); font-size: 0.9rem;">
                        Changed your mind? <a href="{{ path('waitlist') }}" style="color: var(--primary);">Rejoin the waitlist</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
{% endblock %}