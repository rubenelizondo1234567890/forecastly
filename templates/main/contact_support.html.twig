{# templates/main/contact_support.html.twig #}
{% extends 'base_prospect.html.twig' %}

{% block title %}Contact Support - Forecastly{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('contact_support_css') }}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('contact_support_js') }}
{% endblock %}

{% block body_class %}contact-support-body{% endblock %}

{% block body %}
    <div class="contact-support-section">
        <div class="contact-support-container">
            <div class="contact-support-card">
                <div class="contact-support-header">
                    <div class="logo">
                        <a href="{{ path('main_index') }}" class="logo-link">
                            <img src="{{ asset('template/img/forecastly_logo_64x64.png') }}" width="22px" height="22px" />
                            <span>Forecastly</span>
                        </a>
                    </div>
                    <h1>Contact Support</h1>
                    <p>We're here to help you with any questions or concerns</p>
                </div>

                {# Flash messages #}
                {% for message in app.flashes('success') %}
                    <div class="alert alert-success">
                        <i class="fas fa-check-circle"></i>
                        {{ message }}
                    </div>
                {% endfor %}

                {% for message in app.flashes('error') %}
                    <div class="alert alert-error">
                        <i class="fas fa-exclamation-circle"></i>
                        {{ message }}
                    </div>
                {% endfor %}

                {{ form_start(form, {'attr': {'class': 'contact-support-form'}}) }}
                <div class="form-row">
                    <div class="form-group">
                        <div class="input-with-icon">
                            <i class="fas fa-user"></i>
                            {{ form_widget(form.fullName, {'attr': {
                                'class': 'form-control',
                                'placeholder': 'Enter your full name'
                            }}) }}
                        </div>
                        {{ form_label(form.fullName, null, {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_errors(form.fullName) }}
                    </div>

                    <div class="form-group">
                        <div class="input-with-icon">
                            <i class="fas fa-envelope"></i>
                            {{ form_widget(form.email, {'attr': {
                                'class': 'form-control',
                                'placeholder': 'Enter your email address'
                            }}) }}
                        </div>
                        {{ form_label(form.email, null, {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_errors(form.email) }}
                    </div>
                </div>

                <div class="form-group">
                    <div class="input-with-icon">
                        <i class="fas fa-phone"></i>
                        {{ form_widget(form.phone, {'attr': {
                            'class': 'form-control',
                            'placeholder': 'Enter your phone number (optional)'
                        }}) }}
                    </div>
                    {{ form_label(form.phone, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_errors(form.phone) }}
                </div>

                <div class="form-group">
                    <div class="input-with-icon">
                        <i class="fas fa-heading"></i>
                        {{ form_widget(form.title, {'attr': {
                            'class': 'form-control',
                            'placeholder': 'Enter a brief title for your inquiry'
                        }}) }}
                    </div>
                    {{ form_label(form.title, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_errors(form.title) }}
                </div>

                <div class="form-group">
                    <div class="input-with-icon textarea-container">
                        <i class="fas fa-comment-dots"></i>
                        {{ form_widget(form.description, {'attr': {
                            'class': 'form-control',
                            'placeholder': 'Please describe your issue or question in detail (minimum 150 characters)',
                            'rows': 6
                        }}) }}
                    </div>
                    {{ form_label(form.description, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_errors(form.description) }}
                    <div class="form-hint">
                        <span id="char-count">0</span> / 150 characters minimum
                    </div>
                </div>

                <div class="form-group checkbox-group">
                    <div class="checkbox-item">
                        {{ form_widget(form.alreadyCustomer, {'attr': {
                            'class': 'checkbox-input'
                        }}) }}
                        <label for="{{ form.alreadyCustomer.vars.id }}" class="checkbox-label">
                            <i class="fas fa-check"></i>
                            <span>{{ form.alreadyCustomer.vars.label }}</span>
                        </label>
                        {{ form_errors(form.alreadyCustomer) }}
                    </div>

                    <div class="checkbox-item">
                        {{ form_widget(form.authorizeContact, {'attr': {
                            'class': 'checkbox-input'
                        }}) }}
                        <label for="{{ form.authorizeContact.vars.id }}" class="checkbox-label">
                            <i class="fas fa-check"></i>
                            <span>{{ form.authorizeContact.vars.label }}</span>
                        </label>
                        {{ form_errors(form.authorizeContact) }}
                    </div>
                </div>

                <div class="form-group terms-section">
                    <p class="terms-text">
                        By submitting this form, you agree to our
                        <a href="#" class="terms-link">Terms and Conditions</a>
                        and Privacy Policy.
                    </p>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-primary btn-full">
                        <i class="fas fa-paper-plane"></i>
                        Send Message
                    </button>
                </div>
                {{ form_end(form) }}

                <div class="contact-support-footer">
                    <p class="support-note">
                        <i class="fas fa-clock"></i>
                        We typically respond within 24 hours during business days
                    </p>
                    <p class="copyright">&copy; 2025 Meridian Wealth Technologies, LLC. All rights reserved.</p>
                </div>
            </div>
        </div>
    </div>
{% endblock %}