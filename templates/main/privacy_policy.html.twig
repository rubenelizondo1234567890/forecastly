{# templates/main/privacy_policy.html.twig #}
{% extends 'base_prospect.html.twig' %}

{% block title %}Privacy Policy - Forecastly{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .privacy-container {
            max-width: 900px;
            margin: 0 auto;
            padding: 40px 20px;
        }

        .privacy-header {
            text-align: center;
            margin-bottom: 40px;
            padding-bottom: 20px;
            border-bottom: 2px solid var(--border);
        }

        .privacy-header h1 {
            color: var(--primary);
            font-size: 2.5rem;
            margin-bottom: 10px;
        }

        .privacy-header .last-updated {
            color: var(--text-light);
            font-size: 1rem;
        }

        .privacy-content {
            background: var(--card-bg);
            border-radius: 10px;
            padding: 40px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
        }

        .privacy-section {
            margin-bottom: 30px;
        }

        .privacy-section h2 {
            color: var(--primary);
            font-size: 1.5rem;
            margin-bottom: 15px;
            padding-bottom: 8px;
            border-bottom: 1px solid var(--border);
        }

        .privacy-section h3 {
            color: var(--text);
            font-size: 1.2rem;
            margin: 20px 0 10px 0;
        }

        .privacy-section p {
            line-height: 1.6;
            margin-bottom: 15px;
            color: var(--text);
        }

        .privacy-section ul {
            margin: 15px 0;
            padding-left: 20px;
        }

        .privacy-section li {
            margin-bottom: 8px;
            line-height: 1.5;
        }

        .highlight-box {
            background: rgba(114, 239, 221, 0.1);
            border-left: 4px solid var(--positive);
            padding: 20px;
            margin: 20px 0;
            border-radius: 0 5px 5px 0;
        }

        .highlight-box strong {
            color: var(--positive);
        }

        .data-table {
            width: 100%;
            border-collapse: collapse;
            margin: 20px 0;
            background: var(--background);
            border-radius: 8px;
            overflow: hidden;
        }

        .data-table th {
            background: var(--primary);
            color: white;
            padding: 12px 15px;
            text-align: left;
            font-weight: 600;
        }

        .data-table td {
            padding: 12px 15px;
            border-bottom: 1px solid var(--border);
        }

        .data-table tr:last-child td {
            border-bottom: none;
        }

        .data-table tr:hover {
            background: rgba(94, 96, 206, 0.05);
        }

        .contact-info {
            background: var(--background);
            padding: 25px;
            border-radius: 8px;
            margin-top: 30px;
            text-align: center;
        }

        .contact-info h3 {
            color: var(--primary);
            margin-bottom: 15px;
        }

        .back-to-home {
            text-align: center;
            margin-top: 40px;
            padding-top: 20px;
            border-top: 1px solid var(--border);
        }

        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: var(--primary);
            text-decoration: none;
            font-weight: 600;
            padding: 12px 24px;
            border: 2px solid var(--primary);
            border-radius: 6px;
            transition: all 0.3s ease;
        }

        .back-link:hover {
            background: var(--primary);
            color: white;
            text-decoration: none;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(94, 96, 206, 0.3);
        }

        .privacy-badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            background: rgba(114, 239, 221, 0.1);
            color: var(--positive);
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 0.8rem;
            margin-left: 8px;
        }

        @media (max-width: 768px) {
            .privacy-container {
                padding: 20px 15px;
            }

            .privacy-content {
                padding: 25px;
            }

            .privacy-header h1 {
                font-size: 2rem;
            }

            .data-table {
                display: block;
                overflow-x: auto;
            }
        }
    </style>
{% endblock %}

{% block body %}
    <div class="prospect-centered-hero-section">
        <div class="privacy-container">
            <div class="privacy-header">
                <h1><i class="fas fa-shield-alt"></i> Privacy Policy</h1>
                <p class="last-updated">Last Updated: {{ "now"|date("F j, Y") }}</p>
            </div>

            <div class="privacy-content">
                <div class="highlight-box">
                    <p><strong>Your privacy is important to us.</strong> This Privacy Policy explains how Forecastly ("we," "our," or "us") collects, uses, discloses, and safeguards your information when you use our financial forecasting application.</p>
                </div>

                <div class="privacy-section">
                    <h2>1. Information We Collect</h2>

                    <h3>Personal Information</h3>
                    <p>When you create an account or use our services, we may collect:</p>
                    <ul>
                        <li>Contact information (name, email address)</li>
                        <li>Account credentials</li>
                        <li>Profile information</li>
                        <li>Communication preferences</li>
                    </ul>

                    <h3>Financial Information</h3>
                    <p>To provide our forecasting services, we collect:</p>
                    <ul>
                        <li>Account balances and transactions</li>
                        <li>Income and expense data</li>
                        <li>Budgeting information</li>
                        <li>Financial goals and projections</li>
                    </ul>
                    <p class="privacy-badge"><i class="fas fa-lock"></i> Encrypted</p>

                    <h3>Technical Information</h3>
                    <p>We automatically collect certain technical data when you use our services:</p>
                    <ul>
                        <li>Device information and IP address</li>
                        <li>Browser type and version</li>
                        <li>Usage patterns and analytics</li>
                        <li>Cookies and similar technologies</li>
                    </ul>
                </div>

                <div class="privacy-section">
                    <h2>2. How We Use Your Information</h2>

                    <table class="data-table">
                        <thead>
                        <tr>
                            <th>Purpose</th>
                            <th>Information Used</th>
                            <th>Legal Basis</th>
                        </tr>
                        </thead>
                        <tbody>
                        <tr>
                            <td>Provide forecasting services</td>
                            <td>Financial data, account information</td>
                            <td>Contractual necessity</td>
                        </tr>
                        <tr>
                            <td>Account management</td>
                            <td>Contact information, credentials</td>
                            <td>Contractual necessity</td>
                        </tr>
                        <tr>
                            <td>Service improvements</td>
                            <td>Usage data, analytics</td>
                            <td>Legitimate interests</td>
                        </tr>
                        <tr>
                            <td>Security & fraud prevention</td>
                            <td>Technical data, login information</td>
                            <td>Legitimate interests</td>
                        </tr>
                        <tr>
                            <td>Customer support</td>
                            <td>Contact information, service data</td>
                            <td>Contractual necessity</td>
                        </tr>
                        </tbody>
                    </table>
                </div>

                <div class="privacy-section">
                    <h2>3. Data Sharing and Disclosure</h2>
                    <p>We do not sell your personal information to third parties. We may share your information in the following circumstances:</p>

                    <h3>Service Providers</h3>
                    <p>We work with trusted third-party providers who help us operate our services:</p>
                    <ul>
                        <li>Cloud hosting services</li>
                        <li>Data analytics providers</li>
                        <li>Customer support platforms</li>
                        <li>Payment processors (for paid subscriptions)</li>
                    </ul>

                    <h3>Legal Requirements</h3>
                    <p>We may disclose information when required by law or to:</p>
                    <ul>
                        <li>Comply with legal obligations</li>
                        <li>Protect our rights and property</li>
                        <li>Prevent fraud or security issues</li>
                        <li>Protect the safety of our users</li>
                    </ul>

                    <h3>Business Transfers</h3>
                    <p>In the event of a merger, acquisition, or sale of assets, your information may be transferred to the new entity.</p>
                </div>

                <div class="privacy-section">
                    <h2>4. Data Security</h2>
                    <p>We implement appropriate technical and organizational measures to protect your information:</p>

                    <ul>
                        <li><strong>Encryption:</strong> All financial data is encrypted in transit and at rest</li>
                        <li><strong>Access Controls:</strong> Strict access limitations to sensitive information</li>
                        <li><strong>Regular Audits:</strong> Security assessments and vulnerability testing</li>
                        <li><strong>Data Minimization:</strong> We only collect what we need to provide our services</li>
                    </ul>

                    <div class="highlight-box">
                        <p><strong>No Bank Credentials:</strong> Forecastly does not store your online banking usernames or passwords. We use secure token-based authentication where supported by financial institutions.</p>
                    </div>
                </div>

                <div class="privacy-section">
                    <h2>5. Your Rights and Choices</h2>

                    <h3>Access and Control</h3>
                    <p>You have the right to:</p>
                    <ul>
                        <li>Access your personal information</li>
                        <li>Correct inaccurate data</li>
                        <li>Delete your account and data</li>
                        <li>Export your data in a portable format</li>
                        <li>Object to certain processing activities</li>
                    </ul>

                    <h3>Account Settings</h3>
                    <p>You can manage your privacy preferences through your account settings, including:</p>
                    <ul>
                        <li>Communication preferences</li>
                        <li>Data sharing options</li>
                        <li>Account deletion requests</li>
                    </ul>

                    <h3>Cookies and Tracking</h3>
                    <p>You can control cookies through your browser settings. However, disabling essential cookies may affect service functionality.</p>
                </div>

                <div class="privacy-section">
                    <h2>6. Data Retention</h2>
                    <p>We retain your information only as long as necessary to provide our services and fulfill the purposes outlined in this policy:</p>

                    <ul>
                        <li><strong>Active Accounts:</strong> Data retained while your account is active</li>
                        <li><strong>Inactive Accounts:</strong> Data deleted after 24 months of inactivity</li>
                        <li><strong>Legal Requirements:</strong> Some data retained to comply with legal obligations</li>
                        <li><strong>Backup Data:</strong> Securely deleted according to our retention schedule</li>
                    </ul>
                </div>

                <div class="privacy-section">
                    <h2>7. International Data Transfers</h2>
                    <p>Forecastly is based in the United States. If you are located outside the U.S., your information may be transferred to and processed in the United States. We ensure appropriate safeguards are in place for international data transfers.</p>
                </div>

                <div class="privacy-section">
                    <h2>8. Children's Privacy</h2>
                    <p>Our services are not directed to individuals under the age of 18. We do not knowingly collect personal information from children. If we become aware that we have collected personal information from a child without parental consent, we will take steps to remove that information.</p>
                </div>

                <div class="privacy-section">
                    <h2>9. Changes to This Policy</h2>
                    <p>We may update this Privacy Policy from time to time. We will notify you of any material changes by:</p>
                    <ul>
                        <li>Posting the updated policy on our website</li>
                        <li>Sending email notifications to registered users</li>
                        <li>Updating the "Last Updated" date</li>
                    </ul>
                    <p>Your continued use of our services after changes constitutes acceptance of the updated policy.</p>
                </div>

                <div class="privacy-section">
                    <h2>10. Contact Us</h2>
                    <p>If you have any questions, concerns, or requests regarding this Privacy Policy or our data practices, please contact us:  <a href="{{path('main_contact_support')}}"><strong>Contact support</strong></a></p>
                </div>

                <div class="contact-info">
                    <h3><i class="fas fa-envelope"></i> Data Protection Officer</h3>
                    <p><strong>info@meridianwealth.tech</strong></p>
                    <p>Meridian Wealth Technologies, LLC</p>
                    <p>600 W Broadway Ste 700100A</p>
                    <p>San Diego, CA 92101</p>
                </div>

                <div class="back-to-home">
                    <a href="{{ path('main_index') }}" class="back-link">
                        <i class="fas fa-arrow-left"></i>
                        Back to Home
                    </a>
                </div>
            </div>
        </div>
    </div>
{% endblock %}