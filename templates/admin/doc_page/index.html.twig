{# templates/admin/doc_page/index.html.twig #}
{% extends 'base_admin.html.twig' %}

{% block title %}Documentation Pages{% endblock %}

{% block body %}
    <div class="header">
        <div class="page-title">
            <h1>Documentation Pages</h1>
            <p>Manage your help center documentation</p>
        </div>
    </div>

    <div class="form-section">
        <div class="section-header">
            <h2 class="section-title">All Documentation Pages</h2>
            <a href="{{ path('admin_doc_new') }}" class="btn btn-primary">
                <i class="fas fa-plus"></i> Create New Page
            </a>
        </div>

        <div class="table-responsive">
            <table class="accounts-table">
                <thead>
                <tr>
                    <th>Title</th>
                    <th>Slug</th>
                    <th>Created</th>
                    <th>Updated</th>
                    <th>Actions</th>
                </tr>
                </thead>
                <tbody>
                {% for doc_page in doc_pages %}
                    <tr>
                        <td>{{ doc_page.title }}</td>
                        <td>{{ doc_page.slug }}</td>
                        <td>{{ doc_page.createdAt|date('Y-m-d H:i') }}</td>
                        <td>{{ doc_page.updatedAt|date('Y-m-d H:i') }}</td>
                        <td>
                            <div class="action-buttons">
                                <a href="{{ path('admin_doc_show', {'id': doc_page.id}) }}" class="action-btn" title="View">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a href="{{ path('admin_doc_edit', {'id': doc_page.id}) }}" class="action-btn edit-btn" title="Edit">
                                    <i class="fas fa-edit"></i>
                                </a>
                                {{ include('admin/doc_page/_delete_form.html.twig') }}
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="empty-state">
                            <i class="fas fa-file-alt"></i>
                            <p>No documentation pages found</p>
                            <a href="{{ path('admin_doc_new') }}" class="btn btn-primary">Create Your First Page</a>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}