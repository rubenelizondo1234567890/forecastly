<form method="post" action="{{ path('admin_doc_delete', {'id': doc_page.id}) }}" onsubmit="return confirm('Are you sure?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ doc_page.id) }}">
    <button class="action-btn delete-btn" title="Delete">
        <i class="fas fa-trash"></i>
    </button>
</form>