{# templates/security/admin_login.html.twig #}
{% extends 'base_prospect.html.twig' %}

{% block title %}Admin Login - Forecastly. Grow your Wealth.{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {# Use customer login CSS for consistent styling #}
    {{ encore_entry_link_tags('admin_login_css') }}
{% endblock %}

{% block body %}
    <body class="login-body">
    <div class="login-container">
        <div class="login-card">
            <div class="login-header">
                <div class="logo">
                    <i class="fas fa-chart-line"></i>
                    <span>Forecastly</span>
                </div>
                <h1>Admin Login</h1>
                <p>Access your Admin Dashboard</p>
            </div>

            {% if error %}
                <div class="alert alert-error">
                    <i class="fas fa-exclamation-circle"></i>
                    {{ error.messageKey|trans(error.messageData, 'security') }}
                </div>
            {% endif %}

            <form method="post" class="login-form">
                {% if app.user %}
                    <div class="logged-in-notice">
                        You are logged in as {{ app.user.userIdentifier }}, <a href="{{ path('admin_logout') }}">Logout</a>
                    </div>
                {% endif %}

                {{ form_start(loginForm) }}

                <div class="form-group">
                    {{ form_label(loginForm._username) }}
                    {{ form_widget(loginForm._username) }}
                </div>

                <div class="form-group">
                    {{ form_label(loginForm._password) }}
                    {{ form_widget(loginForm._password) }}
                </div>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                {{ form_end(loginForm) }}

                <div class="login-links">
                    <a href="#"><i class="fas fa-question-circle"></i> Forgot Password?</a>
                </div>
            </form>
        </div>
        <p style="font-size: smaller;">&copy; 2025 Meridian Wealth Technologies, LLC. All rights reserved.</p>
    </div>
    </body>
{% endblock %}