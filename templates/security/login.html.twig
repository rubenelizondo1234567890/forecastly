{# templates/security/login.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Admin Login{% endblock %}

{% block body %}
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
                <div class="card shadow-lg">
                    <div class="card-header bg-primary text-white text-center py-4">
                        <h3 class="mb-0">
                            <i class="bi bi-shield-lock me-2"></i>Admin Portal
                        </h3>
                        <p class="mb-0">Sign in to access the dashboard</p>
                    </div>
                    <div class="card-body p-4">
                        {% if error %}
                            <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                        {% endif %}

                        <form method="post">
                            <div class="mb-3">
                                <label for="username" class="form-label">Username</label>
                                <input
                                        type="text"
                                        value="{{ last_username }}"
                                        name="_username"  {# Change to _username #}
                                        id="username"
                                        class="form-control"
                                        autocomplete="username"
                                        required
                                        autofocus
                                >
                            </div>

                            <div class="mb-3">
                                <label for="password" class="form-label">Password</label>
                                <input
                                        type="password"
                                        name="_password"  {# Change to _password #}
                                        id="password"
                                        class="form-control"
                                        autocomplete="current-password"
                                        required
                                >
                            </div>

                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                            <div class="mb-3">
                                <button class="btn btn-primary w-100" type="submit">
                                    Sign In
                                </button>
                            </div>
                        </form>

                        <div class="text-center mt-4">
                            <a href="#" class="text-muted">Forgot password?</a>
                        </div>
                    </div>
                </div>

                <div class="text-center mt-4">
                    <p class="text-muted">&copy; 2025 Meridian Wealth Technologies, LLC. All rights reserved.</p>
                </div>
            </div>
        </div>
    </div>

    <style>

        .card {
            border-radius: 10px;
            overflow: hidden;
            border: none;
        }

        .alert {
            border-radius: 8px;
        }
    </style>
{% endblock %}