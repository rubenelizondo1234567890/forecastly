{% extends 'base-roadmaps.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('home_css') }} {# reuse roadmap card styles #}
    <style>
        /* Additional styles for progress display */
        .progress-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 40px;
        }
        .progress-header h1 {
            font-size: 2.5rem;
            font-weight: 800;
            color: var(--dark-color);
        }
        .progress-header .stats-badge {
            background: var(--primary-color);
            color: white;
            padding: 8px 20px;
            border-radius: 30px;
            font-weight: 600;
        }
        .journey-progress-card {
            background: var(--card-bg);
            border-radius: 15px;
            overflow: hidden;
            box-shadow: var(--shadow);
            transition: var(--transition);
            margin-bottom: 30px;
        }
        .journey-progress-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
        }
        .journey-summary {
            padding: 25px 30px;
            display: flex;
            align-items: center;
            gap: 25px;
            cursor: pointer;
            border-bottom: 1px solid var(--light-gray);
        }
        .journey-icon {
            width: 70px;
            height: 70px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            color: white;
            flex-shrink: 0;
        }
        .journey-info {
            flex: 1;
        }
        .journey-info h3 {
            font-size: 1.6rem;
            font-weight: 700;
            margin-bottom: 5px;
        }
        .journey-meta {
            color: var(--gray-color);
            font-size: 0.95rem;
        }
        .journey-score {
            text-align: right;
            min-width: 150px;
        }
        .journey-score .average {
            font-size: 2rem;
            font-weight: 800;
            color: var(--dark-color);
            line-height: 1.2;
        }
        .journey-score .label {
            color: var(--gray-color);
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        .progress-bar-container {
            width: 100%;
            height: 8px;
            background: var(--light-gray);
            border-radius: 10px;
            margin-top: 10px;
        }
        .progress-bar-fill {
            height: 100%;
            border-radius: 10px;
            background: var(--primary-color);
            transition: width 0.3s ease;
        }
        .journey-details {
            padding: 0 30px 25px 125px; /* align with icon offset */
            display: none;
        }
        .journey-details table {
            width: 100%;
            border-collapse: collapse;
        }
        .journey-details th {
            text-align: left;
            padding: 15px 0 10px;
            color: var(--gray-color);
            font-weight: 600;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            border-bottom: 2px solid var(--light-gray);
        }
        .journey-details td {
            padding: 12px 0;
            border-bottom: 1px solid var(--light-gray);
        }
        .journey-details tr:last-child td {
            border-bottom: none;
        }
        .journey-details a {
            color: var(--dark-color);
            text-decoration: none;
            font-weight: 500;
        }
        .journey-details a:hover {
            color: var(--primary-color);
            text-decoration: underline;
        }
        .score-badge {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 20px;
            font-weight: 600;
            font-size: 0.85rem;
        }
        .score-high { background: #d4edda; color: #155724; }
        .score-medium { background: #fff3cd; color: #856404; }
        .score-low { background: #f8d7da; color: #721c24; }
        .toggle-icon {
            transition: transform 0.3s ease;
            margin-right: 10px;
        }
        .expanded .toggle-icon {
            transform: rotate(90deg);
        }
        .empty-state {
            text-align: center;
            padding: 80px 20px;
            background: var(--card-bg);
            border-radius: 15px;
            box-shadow: var(--shadow);
        }
        .empty-state i {
            font-size: 5rem;
            color: var(--light-gray);
            margin-bottom: 20px;
        }
        .empty-state h2 {
            font-size: 2rem;
            font-weight: 700;
            margin-bottom: 15px;
        }
        .empty-state p {
            color: var(--gray-color);
            max-width: 500px;
            margin: 0 auto 30px;
        }
        .btn-explore {
            display: inline-block;
            padding: 14px 32px;
            background: var(--primary-color);
            color: white;
            text-decoration: none;
            border-radius: 50px;
            font-weight: 600;
            transition: var(--transition);
        }
        .btn-explore:hover {
            background: var(--primary-dark);
            transform: translateY(-3px);
        }
        @media (max-width: 768px) {
            .journey-summary {
                flex-wrap: wrap;
                gap: 15px;
            }
            .journey-score {
                min-width: 100%;
                text-align: left;
            }
            .journey-details {
                padding-left: 30px;
            }
        }
    </style>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Toggle journey details
            document.querySelectorAll('.journey-summary').forEach(summary => {
                summary.addEventListener('click', function() {
                    const card = this.closest('.journey-progress-card');
                    const details = card.querySelector('.journey-details');
                    const isVisible = details.style.display === 'block';
                    details.style.display = isVisible ? 'none' : 'block';
                    card.classList.toggle('expanded', !isVisible);
                });
            });
        });
    </script>
{% endblock %}

{% block body %}
    <div class="container" style="margin-top: 40px; margin-bottom: 60px;">
        <div class="progress-header">
            <h1>📚 My Learning Progress</h1>
            <div class="stats-badge">
                {{ progressData|length }} Journey{{ progressData|length != 1 ? 's' : '' }}
            </div>
        </div>

        {% if progressData is empty %}
            <div class="empty-state">
                <i class="fas fa-graduation-cap"></i>
                <h2>No quizzes taken yet</h2>
                <p>Start exploring our financial roadmaps and test your knowledge with quizzes to see your progress here.</p>
                <a href="{{ path('home') }}" class="btn-explore">Explore Roadmaps</a>
            </div>
        {% else %}
            {% for data in progressData %}
                {% set journey = data.journey %}
                {% set avg = data.average %}
                {# Determine CSS class based on journey slug or name #}
                {% set journeyClass = journey.slug|default(journey.name|lower|replace({' ': '-', '&': 'and'})) %}
                {# fallback mapping for known journeys #}
                {% if journeyClass in ['personal-finance', 'forex', 'crypto', 'stocks', 'retirement', 'real-estate', 'tax-smart', 'fire', 'bonds', 'psychology', 'credit', 'career'] %}
                    {% set journeyColorClass = journeyClass %}
                {% else %}
                    {% set journeyColorClass = 'personal-finance' %} {# default #}
                {% endif %}

                <div class="journey-progress-card">
                    <div class="journey-summary">
                        <div class="journey-icon {{ journeyColorClass }}">
                            {# Set icon based on journey – you can define a mapping or use a default #}
                            {% if journeyColorClass == 'personal-finance' %}<i class="fas fa-wallet"></i>
                            {% elseif journeyColorClass == 'forex' %}<i class="fas fa-dollar-sign"></i>
                            {% elseif journeyColorClass == 'crypto' %}<i class="fab fa-bitcoin"></i>
                            {% elseif journeyColorClass == 'stocks' %}<i class="fas fa-chart-line"></i>
                            {% elseif journeyColorClass == 'retirement' %}<i class="fas fa-umbrella-beach"></i>
                            {% elseif journeyColorClass == 'real-estate' %}<i class="fas fa-home"></i>
                            {% elseif journeyColorClass == 'tax-smart' %}<i class="fas fa-file-invoice-dollar"></i>
                            {% elseif journeyColorClass == 'fire' %}<i class="fas fa-fire"></i>
                            {% elseif journeyColorClass == 'bonds' %}<i class="fas fa-hand-holding-usd"></i>
                            {% elseif journeyColorClass == 'psychology' %}<i class="fas fa-brain"></i>
                            {% elseif journeyColorClass == 'credit' %}<i class="fas fa-credit-card"></i>
                            {% elseif journeyColorClass == 'career' %}<i class="fas fa-briefcase"></i>
                            {% else %}<i class="fas fa-book-open"></i>
                            {% endif %}
                        </div>
                        <div class="journey-info">
                            <h3>{{ journey.name }}</h3>
                            <div class="journey-meta">
                                <i class="far fa-file-alt"></i> {{ data.quizzes|length }} page{{ data.quizzes|length != 1 ? 's' : '' }} completed
                            </div>
                            <div class="progress-bar-container">
                                <div class="progress-bar-fill" style="width: {{ avg }}%; background-color: var(--{{ journeyColorClass }}-color, var(--primary-color));"></div>
                            </div>
                        </div>
                        <div class="journey-score">
                            <div class="average">{{ avg }}%</div>
                            <div class="label">average score</div>
                        </div>
                    </div>
                    <div class="journey-details">
                        <table>
                            <thead>
                            <tr>
                                <th>Page</th>
                                <th>Score</th>
                                <th>Date</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for quiz in data.quizzes %}
                                {% set score = quiz.score %}
                                {% if score >= 80 %}
                                    {% set scoreClass = 'score-high' %}
                                {% elseif score >= 50 %}
                                    {% set scoreClass = 'score-medium' %}
                                {% else %}
                                    {% set scoreClass = 'score-low' %}
                                {% endif %}
                                <tr>
                                    <td>
                                        <a href="{{ path('app_page_show', { journey: quiz.page.journey.name, slug: quiz.page.slug }) }}" target="_blank">
                                            {{ quiz.page.title }}
                                        </a>
                                    </td>
                                    <td><span class="score-badge {{ scoreClass }}">{{ score }}%</span></td>
                                    <td>{{ quiz.date|date('M j, Y') }}</td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            {% endfor %}
        {% endif %}
    </div>
{% endblock %}
