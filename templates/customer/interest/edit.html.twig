{# templates/customer/interest/edit.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Edit Recurring Interest - Forecastly{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('customer_recurring_interest_css') }}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('customer_recurring_interest_js') }}
{% endblock %}

{% block body %}
    <div class="header">
        <div class="page-title">
            <h1>Edit Recurring Interest</h1>
            <p>Update your recurring interest settings</p>
        </div>
        <div class="header-actions">
            <a href="{{ path('customer_recurring_interest_index') }}" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Back to List
            </a>
        </div>
    </div>

    <!-- Flash Messages -->
    <div class="flash-messages">
        {% for message in app.flashes('success') %}
            <div class="alert alert-success">
                <i class="fas fa-check-circle"></i> {{ message }}
            </div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="alert alert-error">
                <i class="fas fa-exclamation-circle"></i> {{ message }}
            </div>
        {% endfor %}
    </div>

    <div class="recurring-interest-container">
        <!-- Edit Form Only -->
        <div class="form-section">
            <div class="section-header">
                <h2 class="section-title">Edit Recurring Interest: {{ interest.name }}</h2>
            </div>

            {{ form_start(form, {'attr': {'id': 'recurring-interest-form'}}) }}
            {{ form_errors(form) }}

            <div class="form-group">
                {{ form_label(form.name) }}
                {{ form_widget(form.name, {'attr': {'class': 'form-control', 'placeholder': 'e.g., Savings Account Interest, CD Interest'}}) }}
                {{ form_errors(form.name) }}
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Update Interest</button>
                <a href="{{ path('customer_recurring_interest_index') }}" class="btn btn-secondary">Cancel</a>
            </div>
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}
