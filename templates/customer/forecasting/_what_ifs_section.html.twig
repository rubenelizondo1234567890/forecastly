<div class="forecasting-card">
    <div class="forecasting-header">
        <h2 class="forecasting-title">What-If Scenarios</h2>
    </div>
    <div class="chart-container">
        <canvas id="whatIfChart"></canvas>
    </div>
    <div class="scenario-form">
        <form id="scenarioForm">
            <div class="scenario-controls">
                <div class="form-group">
                    <label for="scenarioType">Scenario Type</label>
                    <select id="scenarioType" class="form-control">
                        <option value="income">Additional Income</option>
                        <option value="expense">Additional Expense</option>
                    </select>
                </div>
                <div class="form-group">
                    <label for="scenarioAmount">Amount ($)</label>
                    <input type="number" id="scenarioAmount" class="form-control" value="500" min="0">
                </div>
                <div class="form-group">
                    <label for="scenarioDuration">Duration (months)</label>
                    <input type="number" id="scenarioDuration" class="form-control" value="60" min="1" max="120">
                </div>
                <div class="form-group" style="align-self: end;">
                    <button type="submit" class="btn btn-primary">Apply Scenario</button>
                </div>
            </div>
        </form>
        <div id="scenarioResult" class="scenario-result"></div>
    </div>
</div>