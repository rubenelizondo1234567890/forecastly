{# templates/customer/forecasting/accounts_projections.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Account Projections - Forecastly. Grow your Wealth.{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('customer_accounts_forecasting_css') }}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        // Pass the route URL to JavaScript
        window.ACCOUNT_PROJECTIONS_URL = "{{ path('customer_forecasting_account_projections') }}";
    </script>
    {{ encore_entry_script_tags('customer_accounts_forecasting_js') }}
{% endblock %}

{% block body %}
    <div class="header">
        <div class="page-title">
            <h1>Account Projections</h1>
            <p>Forecast your account balances over time</p>
        </div>
    </div>

    <!-- Flash Messages -->
    <div class="flash-messages">
        {% for message in app.flashes('success') %}
            <div class="alert alert-success">
                <i class="fas fa-check-circle"></i> {{ message }}
            </div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="alert alert-error">
                <i class="fas fa-exclamation-circle"></i> {{ message }}
            </div>
        {% endfor %}
    </div>

    <div class="forecasting-form-section form-section">
        <div class="section-header">
            <h2 class="section-title">Projection Settings</h2>
        </div>

        <div class="form-row" style="display: flex; gap: 20px;">
            <div class="form-group" style="flex: 1;">
                <label for="accountSelect">Select Account</label>
                <select id="accountSelect" class="form-control">
                    <option value="">Select Account...</option>
                    {% for account in accounts %}
                        <option value="{{ account.id }}">{{ account.name }} ({{ account.budgetTrackingGroup.isIncomeOrExpense }})</option>
                    {% endfor %}
                </select>
            </div>

            <div class="form-group" style="flex: 1;">
                <label for="periodSelect">Select Period</label>
                <select id="periodSelect" class="form-control">
                    <option value="">Select Period...</option>
                    <option value="1">1 Year</option>
                    <option value="3">3 Years</option>
                    <option value="5">5 Years</option>
                    <option value="10">10 Years</option>
                    <option value="15">15 Years</option>
                    <option value="20">20 Years</option>
                    <option value="30">30 Years</option>
                </select>
            </div>
        </div>
    </div>

    <div class="forecasting-results form-section" style="margin-top: 30px;">
        <div class="section-header">
            <h2 class="section-title">Projection Results</h2>
        </div>

        <div id="accountInfo" style="display: none; margin-bottom: 20px;">
            <div class="account-info">
                <div class="account-detail">
                    <div class="label">Account</div>
                    <div class="value" id="accountName"></div>
                </div>
                <div class="account-detail">
                    <div class="label">Current Balance</div>
                    <div class="value" id="currentBalance"></div>
                </div>
            </div>
        </div>

        <div class="chart-container">
            <canvas id="projectionChart"></canvas>
        </div>
    </div>
{% endblock %}