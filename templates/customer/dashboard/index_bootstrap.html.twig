{# templates/dashboard/index.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Dashboard{% endblock %}

{% block body %}
    <div class="container-fluid">
        <div class="container my-5">
            <div class="row mt-5">
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="mb-0">Net Worth Summary as of Today</h5>
                        </div>
                        <div class="card-body">
                            <canvas id="netWorthChart" height="240"></canvas>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="row">
                        <div class="col-12">
                            <div class="card h-100">
                                <div class="card-header bg-primary text-white">
                                    <h5 class="mb-0">Budget Groups</h5>
                                </div>
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <p class="mb-0">Manage income/expense categories</p>
                                        <a href="{{ path('customer_budget_index') }}" class="btn btn-sm btn-outline-primary">View</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="row mt-5">
                        <div class="col-12">
                            <div class="card h-100">
                                <div class="card-header bg-success text-white">
                                    <h5 class="mb-0">Assets</h5>
                                </div>
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <p class="mb-0">Manage your financial assets</p>
                                        <a href="{{ path('customer_account_index', {'isIncomeOrExpense':'income'}) }}" class="btn btn-sm btn-outline-success">View</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="row mt-5">
                        <div class="col-12">
                            <div class="card h-100">
                                <div class="card-header bg-warning text-dark">
                                    <h5 class="mb-0">Liabilities</h5>
                                </div>
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <p class="mb-0">Manage your debts</p>
                                        <a href="{{ path('customer_account_index',{ 'isIncomeOrExpense':'expense'}) }}" class="btn btn-sm btn-outline-warning">View</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row mt-5">
                <div class="col-md-6">
                    {# Income Section #}
                    <div class="row">
                        <div class="col-12">
                            <h3 class="text-success mb-4">
                                <i class="bi bi-arrow-up-circle"></i> Income Management
                            </h3>
                        </div>

                        <div class="col-md-6">
                            <div class="card h-20">
                                <div class="card-header bg-success text-white">
                                    <h5 class="mb-0">Recurring Incomes</h5>
                                </div>
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <p class="mb-0">Manage regular income streams</p>
                                        <a href="{{ path('customer_recurring_income_index') }}" class="btn btn-sm btn-outline-success">View</a>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="card h-20">
                                <div class="card-header bg-success-subtle text-dark">
                                    <h5 class="mb-0">Non-recurring Incomes</h5>
                                </div>
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <p class="mb-0">Manage one-time income sources</p>
                                        <a href="{{ path('customer_non_recurring_income_index') }}" class="btn btn-sm btn-outline-success">View</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    {# Expense Section #}
                    <div class="row">
                        <div class="col-12">
                            <h3 class="text-warning mb-4">
                                <i class="bi bi-arrow-down-circle"></i> Expense Management
                            </h3>
                        </div>

                        <div class="col-md-6">
                            <div class="card h-20">
                                <div class="card-header bg-warning text-dark">
                                    <h5 class="mb-0">Recurring Expenses</h5>
                                </div>
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <p class="mb-0">Manage regular expenses</p>
                                        <a href="{{ path('customer_recurring_expense_index') }}" class="btn btn-sm btn-outline-warning">View</a>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="card h-20">
                                <div class="card-header bg-warning-subtle text-dark">
                                    <h5 class="mb-0">Non-recurring Expenses</h5>
                                </div>
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <p class="mb-0">Manage one-time expenses</p>
                                        <a href="{{ path('customer_non_recurring_expense_index') }}" class="btn btn-sm btn-outline-warning">View</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>

            <div class="row mt-5">
                {# Income Chart #}
                <div class="col-md-6">
                    <div class="card h-100">
                        <div class="card-header bg-success text-white">
                            <h5 class="mb-0">Income Breakdown for this month</h5>
                        </div>
                        <div class="card-body">
                            <h4>Total Income: ${{ totalIncomes|number_format(2) }}</h4>
                            <canvas id="incomeChart" height="150"></canvas>
                        </div>
                    </div>
                </div>
                {# Expense Chart #}
                <div class="col-md-6">
                    <div class="card h-100">
                        <div class="card-header bg-warning text-dark">
                            <h5 class="mb-0">Expense Breakdown for this month</h5>
                        </div>
                        <div class="card-body">
                            <h4>Total Expense: ${{ totalExpenses|number_format(2) }}</h4>
                            <canvas id="expenseChart" height="150"></canvas>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Net Worth Chart
            const netWorthCtx = document.getElementById('netWorthChart').getContext('2d');
            const netWorth = {{ netWorth|json_encode|raw }};
            //console.log(netWorth);
            new Chart(netWorthCtx, {
                type: 'bar',
                data: {
                    labels: netWorth.labels,
                    datasets: [{
                        label: 'Amount ($)',
                        data: netWorth.data,
                        backgroundColor: netWorth.bkgd,
                        borderColor: netWorth.color,
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    scales: {
                        y: {
                            beginAtZero: true
                        }
                    }
                }
            });

            // Income Chart
            const incomeCtx = document.getElementById('incomeChart').getContext('2d');

            const incomes = {{ incomes|json_encode|raw }};
            //console.log(incomes);
            new Chart(incomeCtx, {
                type: 'doughnut',
                data: {
                    labels: incomes.labels,
                    datasets: [{
                        data: incomes.data,
                        backgroundColor: incomes.bkgd,
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: {
                            position: 'right'
                        }
                    }
                }
            });

            // Expense Chart
            const expenseCtx = document.getElementById('expenseChart').getContext('2d');
            const expenses = {{ expenses|json_encode|raw }};
            //console.log(expenses);
            new Chart(expenseCtx, {
                type: 'doughnut',
                data: {
                    labels: expenses.labels,
                    datasets: [{
                        data: expenses.data,
                        backgroundColor: [
                            'rgba(255, 193, 7, 0.7)',
                            'rgba(220, 170, 10, 0.7)',
                            'rgba(200, 150, 0, 0.7)',
                            'rgba(180, 130, 0, 0.7)',
                            'rgba(160, 110, 0, 0.7)'
                        ],
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: {
                            position: 'right'
                        }
                    }
                }
            });
        });
    </script>
{% endblock %}