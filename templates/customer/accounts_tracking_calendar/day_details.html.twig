                            </div>
                            <div class="transaction-amount savings-color">${{ amount|number_format(2) }}</div>
                        </div>
                    {% endfor %}
                {% endfor %}
            </div>
        {% else %}
            <p class="no-data">No savings to save for this day</p>
        {% endif %}
    </div>

    <div class="details-section">
        <h3><i class="fas fa-wallet"></i> Projected Account Balances</h3>
        {% if entry.getAccountsBalances() is not empty %}
            <div class="balances-list">
                {% for accountId, balance in entry.getAccountsBalances() %}
                    <div class="balance-item">
                        <span class="account-name">{{ accountNames[accountId] ?? 'Account #' ~ accountId }}</span>
                        <span class="account-balance {% if balance >= 0 %}positive-balance{% else %}negative-balance{% endif %}">
                            ${{ balance|number_format(2) }}
                        </span>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <p class="no-data">No balance data for this day</p>
        {% endif %}
    </div>
</div>
