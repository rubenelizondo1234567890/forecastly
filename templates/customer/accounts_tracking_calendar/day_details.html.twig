        {% if entry.getPaymentsAccountToPay() is not empty %}
            <div class="transactions-list">
                {% for accountId, transactions in entry.getPaymentsAccountToPay() %}
                    {% for transactionId, amount in transactions %}
                        <div class="transaction-item">
                            <div class="transaction-info">
                                <span class="transaction-name">Revolving Payment #{{ transactionId }}</span>
                                <span class="transaction-account">{{ accountNames[accountId] ?? 'Account #' ~ accountId }}</span>
                            </div>
                            <div class="transaction-amount expense-color">${{ amount|number_format(2) }}</div>
                        </div>
