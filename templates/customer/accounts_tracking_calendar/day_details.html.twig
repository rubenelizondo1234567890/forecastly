<div class="day-details">
    <div class="details-section">
        <h3 class="income-color"><i class="fas fa-money-bill-wave"></i> Recurring Incomes</h3>
        {% if entry.getRecurringIncomes() is not empty %}
            <div class="transactions-list">
                {% for accountId, transactions in entry.getRecurringIncomes() %}
                    {% for transactionId, amount in transactions %}
                        <div class="transaction-item">
                            <div class="transaction-info">
                                <span class="transaction-name">Recurring Income #{{ transactionId }}</span>
                                <span class="transaction-account">{{ accountNames[accountId] ?? 'Account #' ~ accountId }}</span>
                            </div>
                            <div class="transaction-amount income-color">${{ amount|number_format(2) }}</div>
                        </div>
                    {% endfor %}
                {% endfor %}
            </div>
        {% else %}
            <p class="no-data">No recurring incomes for this day</p>
        {% endif %}
    </div>

    <div class="details-section">
        <h3 class="income-color"><i class="fas fa-calendar-day"></i> Non-Recurring Incomes</h3>
        {% if entry.getNonRecurringIncomes() is not empty %}
            <div class="transactions-list">
                {% for accountId, transactions in entry.getNonRecurringIncomes() %}
                    {% for transactionId, amount in transactions %}
                        <div class="transaction-item">
