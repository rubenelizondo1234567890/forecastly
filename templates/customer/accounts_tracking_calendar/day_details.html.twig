        {% endif %}
    </div>

    <div class="details-section">
        <h3 class="savings-color"><i class="fas fa-piggy-bank"></i> Savings to Save</h3>
        {% if entry.getSavingsAccountToSave() is not empty %}
            <div class="transactions-list">
                {% for accountId, transactions in entry.getSavingsAccountToSave() %}
                    {% for transactionId, amount in transactions %}
                        <div class="transaction-item">
                            <div class="transaction-info">
