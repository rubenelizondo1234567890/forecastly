                            </div>
                            <div class="transaction-amount income-color">${{ amount|number_format(2) }}</div>
                        </div>
                    {% endfor %}
                {% endfor %}
            </div>
        {% else %}
            <p class="no-data">No non-recurring incomes for this day</p>
        {% endif %}
    </div>

