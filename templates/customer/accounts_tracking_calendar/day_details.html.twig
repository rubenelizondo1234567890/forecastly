    <div class="details-section">
        <h3 class="expense-color"><i class="fas fa-percentage"></i> Recurring Expense Interests</h3>
        {% if entry.getRecurringExpenseInterest() is not empty %}
            <div class="transactions-list">
                {% for accountId, transactions in entry.getRecurringExpenseInterest() %}
                    {% for transactionId, amount in transactions %}
                        <div class="transaction-item">
                            <div class="transaction-info">
