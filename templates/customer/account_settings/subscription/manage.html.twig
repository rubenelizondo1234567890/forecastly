{# templates/customer/subscription/pricing.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Manage Subscription - Forecastly{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('customer_subscription_css') }}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('customer_subscription_js') }}
{% endblock %}
{% block body %}
    <div class="container mx-auto px-4 py-8">
        <h1 class="text-3xl font-bold mb-6">Manage Your Subscription</h1>

        {% if subscription %}
            <div class="bg-white rounded-lg shadow-lg p-6">
                <div class="mb-4">
                    <h2 class="text-xl font-semibold">Current Plan</h2>
                    <p class="text-gray-600">Status: {{ subscription.status|title }}</p>
                    <p class="text-gray-600">
                        Current Period End: {{ subscription.currentPeriodEnd|date('Y-m-d') }}
                    </p>
                </div>

                {% if subscription.isActive and not subscription.isCanceled %}
                    <div class="mt-6">
                        <form action="{{ path('customer_subscription_cancel') }}" method="post" onsubmit="return confirm('Are you sure you want to cancel your subscription?')">
                            <button type="submit" class="bg-red-600 text-white px-4 py-2 rounded hover:bg-red-700 transition duration-200">
                                Cancel Subscription
                            </button>
                        </form>
                    </div>
                {% endif %}
            </div>
        {% else %}
            <div class="bg-white rounded-lg shadow-lg p-6 text-center">
                <h2 class="text-xl font-semibold mb-4">No Active Subscription</h2>
                <p class="text-gray-600 mb-4">You don't have an active subscription.</p>
                <a href="{{ path('customer_subscription_pricing') }}" class="bg-blue-600 text-white px-6 py-3 rounded-lg hover:bg-blue-700 transition duration-200">
                    View Plans
                </a>
            </div>
        {% endif %}
    </div>
{% endblock %}