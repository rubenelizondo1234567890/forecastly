{# templates/roadmaps/retirement/retirement-journey.html.twig #}
{% extends 'base-roadmaps.html.twig' %}

    {% block stylesheets %}
        {{ parent() }}
        {{ encore_entry_link_tags('retirement_css') }}
    {% endblock %}

    {% block javascripts %}
        {{ parent() }}
        {{ encore_entry_script_tags('retirement_js') }}
    {% endblock %}

{% block body %}
    <div class="container">
        <!-- hero section specific for retirement journey -->
        <div class="journey-hero animate">
            <div class="hero-content">
                <div class="journey-icon">
                    <i class="fas fa-umbrella-beach"></i>
                </div>
                <h1>Retirement & <span>Long‑Term Wealth</span></h1>
                <p class="hero-description">
                    Secure your future with a clear, four‑phase roadmap. From first contribution to comfortable retirement — no jargon, just action.
                </p>
            </div>
        </div>

        <!-- intro text: how our roadmaps work -->
        <div style="text-align: center; margin: 40px 0 20px;" class="animate">
            <h2 class="section-title">🧭 Your 4‑phase retirement roadmap</h2>
            <p class="section-subtitle">
                Each phase follows the <strong>Foundation → Risk → Execution → Skill Building</strong> structure.
                Start with phase 1 or jump to what you need most.
            </p>
        </div>

        <!-- ===== PHASE 1 – FOUNDATION FIRST ===== -->
        <div class="phase-wrapper animate">
            <div class="phase-title">
                <span class="phase-number">1</span>
                <span>Foundation First · Retirement basics & mindset</span>
            </div>
            <div class="article-grid">
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-seedling"></i></div>
                    <h3>Retirement Basics: Why Start Now?</h3>
                    <p class="article-brief">Overwhelmed by retirement jargon? Learn why time is your biggest asset and get a clear overview of how retirement planning works.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 8 min read</span>
                        <a href="{{ url('app_page_show', { journey: 'retirement', slug: 'retirement-basics' }) }}" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-chart-line"></i></div>
                    <h3>Compound Interest: The 8th Wonder of the World</h3>
                    <p class="article-brief">Understand how compound interest can turn small savings into a nest egg. Simple examples show the magic of starting early.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 7 min read</span>
                        <a href="{{ url('app_page_show', { journey: 'retirement', slug: 'compound-interest' }) }}" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-piggy-bank"></i></div>
                    <h3>401(k), IRA, Roth: Choosing the Right Account</h3>
                    <p class="article-brief">Demystify the most common retirement accounts. We explain the differences, tax benefits, and who should use each.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 10 min read</span>
                        <a href="{{ url('app_page_show', { journey: 'retirement', slug: 'choosing-retirement-accounts' }) }}" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-calculator"></i></div>
                    <h3>The 4% Rule: How Much Do You Need to Retire?</h3>
                    <p class="article-brief">Get a first estimate of your retirement number using the famous 4% rule. No complex math, just a starting point.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 9 min read</span>
                        <a href="{{ url('app_page_show', { journey: 'retirement', slug: 'the-4-percent-rule' }) }}" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
            </div>
        </div>

        <!-- ===== PHASE 2 – RISK MANAGEMENT ===== -->
        <div class="phase-wrapper animate">
            <div class="phase-title">
                <span class="phase-number">2</span>
                <span>Risk Management · Protect your future nest egg</span>
            </div>
            <div class="article-grid">
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-chart-pie"></i></div>
                    <h3>Inflation: The Silent Retirement Killer</h3>
                    <p class="article-brief">Learn how inflation erodes purchasing power and what assets can help hedge against it. Essential for long-term planning.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 8 min read</span>
                        <a href="{{ url('app_page_show', { journey: 'retirement', slug: 'inflation-silent-killer' }) }}" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-hourglass-half"></i></div>
                    <h3>Longevity Risk: Planning for a 30‑Year Retirement</h3>
                    <p class="article-brief">With people living longer, outliving your savings is a real risk. Discover strategies to ensure your money lasts.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 9 min read</span>
                        <a href="{{ url('app_page_show', { journey: 'retirement', slug: 'longevity-risk' }) }}" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-wave-square"></i></div>
                    <h3>Market Risk & Sequence of Returns</h3>
                    <p class="article-brief">Why the order of investment returns matters near retirement. Understand the danger and how to mitigate it.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 8 min read</span>
                        <a href="{{ url('app_page_show', { journey: 'retirement', slug: 'market-risk-sequence' }) }}" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-notes-medical"></i></div>
                    <h3>Healthcare & Long‑Term Care Insurance</h3>
                    <p class="article-brief">Medical costs can derail retirement. Get an introduction to Medicare, medigap, and long-term care insurance.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 11 min read</span>
                        <a href="{{ url('app_page_show', { journey: 'retirement', slug: 'healthcare-ltc' }) }}" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
            </div>
        </div>

        <!-- ===== PHASE 3 – PRACTICAL EXECUTION ===== -->
        <div class="phase-wrapper animate">
            <div class="phase-title">
                <span class="phase-number">3</span>
                <span>Practical Execution · Open, contribute, automate</span>
            </div>
            <div class="article-grid">
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-file-signature"></i></div>
                    <h3>Step‑by‑Step: Open Your First Retirement Account</h3>
                    <p class="article-brief">Walk through choosing a provider, filling out forms, and making your first contribution. Actionable steps inside.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 10 min read</span>
                        <a href="{{ url('app_page_show', { journey: 'retirement', slug: 'open-first-retirement-account' }) }}" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-robot"></i></div>
                    <h3>Set It and Forget It: Automate Your Retirement Savings</h3>
                    <p class="article-brief">Learn to automate contributions from your paycheck or bank account. Consistency is key to building wealth.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 7 min read</span>
                        <a href="{{ url('app_page_show', { journey: 'retirement', slug: 'automate-savings' }) }}" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-bullseye"></i></div>
                    <h3>Target‑Date Funds: The Simplest Investment Choice</h3>
                    <p class="article-brief">Discover how target-date funds adjust risk over time and why they're a popular choice for beginners.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 6 min read</span>
                        <a href="{{ url('app_page_show', { journey: 'retirement', slug: 'target-date-funds' }) }}" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-hand-holding-heart"></i></div>
                    <h3>Employer Match 101: Don't Leave Free Money on the Table</h3>
                    <p class="article-brief">If your employer offers a 401(k) match, this is the highest return investment you can make. Here's how it works.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 5 min read</span>
                        <a href="{{ url('app_page_show', { journey: 'retirement', slug: 'employer-match' }) }}" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
            </div>
        </div>

        <!-- ===== PHASE 4 – SKILL BUILDING ===== -->
        <div class="phase-wrapper animate">
            <div class="phase-title">
                <span class="phase-number">4</span>
                <span>Skill Building · Advanced strategies & legacy</span>
            </div>
            <div class="article-grid">
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-coins"></i></div>
                    <h3>Tax‑Efficient Withdrawal Strategies in Retirement</h3>
                    <p class="article-brief">Once you retire, where should you take money from first? Learn about Roth ladders, taxable accounts, and tax brackets.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 12 min read</span>
                        <a href="{{ url('app_page_show', { journey: 'retirement', slug: 'tax-efficient-withdrawal-strategies' }) }}" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-calendar-check"></i></div>
                    <h3>Social Security: When Should You Claim?</h3>
                    <p class="article-brief">Deciding when to take Social Security is a big decision. We break down the trade-offs of claiming early, on time, or late.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 9 min read</span>
                        <a href="{{ url('app_page_show', { journey: 'retirement', slug: 'social-security-claiming' }) }}" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-file-invoice"></i></div>
                    <h3>Required Minimum Distributions (RMDs) Explained</h3>
                    <p class="article-brief">After age 73, the IRS requires you to withdraw from retirement accounts. Understand the rules and how to plan.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 8 min read</span>
                        <a href="{{ url('app_page_show', { journey: 'retirement', slug: 'required-minimum-distributions' }) }}" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-scroll"></i></div>
                    <h3>Estate Planning Essentials: Wills, Trusts, and Beneficiaries</h3>
                    <p class="article-brief">Ensure your wealth goes where you want. A non‑scary intro to estate planning documents and beneficiary designations.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 10 min read</span>
                        <a href="{{ url('app_page_show', { journey: 'retirement', slug: 'estate-planning-essentials' }) }}" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
            </div>
        </div>

        <!-- call to action – start the retirement journey -->
        <div class="journey-cta animate">
            <h2>Ready to build your retirement foundation?</h2>
            <p style="font-size: 1.2rem; color: #2d3748; margin-bottom: 10px;">Start with phase 1 — clear, step‑by‑step, and completely free.</p>
            <a href="{{ url('app_page_show', { journey: 'retirement', slug: 'retirement-basics' }) }}" class="cta-button"><i class="fas fa-road"></i> Begin the journey now</a>
            <p style="margin-top: 25px; color: #718096;"><i class="fas fa-users"></i> 15,000+ members started here</p>
        </div>
    </div>
{% endblock %}
