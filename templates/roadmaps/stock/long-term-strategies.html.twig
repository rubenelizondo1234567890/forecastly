{# templates/roadmaps/stock/long-term-strategies.html.twig #}
{% extends 'base-roadmaps.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('stock_css') }}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('stock_js') }}
{% endblock %}

{% block body %}
    <div class="container">
        <!-- article hero – stock style -->
        <div class="article-hero animate">
            <div class="hero-content">
                <div class="hero-icon" style="background-color: var(--stocks-accent);">
                    <i class="fas fa-arrows-spin"></i>
                </div>
                <h1>Long‑Term Strategies <span>Buy‑and‑Hold vs. Active Trading</span></h1>
                <p class="hero-description">
                    Two different philosophies: holding for decades vs. frequent trading. Learn the trade‑offs in returns, taxes, costs, and peace of mind.
                </p>
                <div class="phase-tag">
                    <i class="fas fa-layer-group"></i> Phase 4: Skill Building · 8 min read
                </div>
            </div>
        </div>

        <!-- introduction -->
        <section class="animate">
            <h2 class="section-title">⚖️ Two Paths to Investing</h2>
            <p style="font-size: 1.2rem; margin-bottom: 20px;">
                Investors generally fall into two camps: those who buy and hold for the long term, and those who actively trade to beat the market. Each approach has its pros and cons, and the right choice depends on your goals, time, and temperament.
            </p>
        </section>

        <!-- comparison -->
        <div class="card animate" style="margin: 40px 0;">
            <h3 style="font-size: 1.8rem; margin-bottom: 20px;">📊 Buy‑and‑Hold vs. Active Trading</h3>
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px;">
                <div>
                    <h4><i class="fas fa-tree"></i> Buy‑and‑Hold</h4>
                    <ul>
                        <li>Long‑term horizon (5+ years)</li>
                        <li>Low turnover → lower taxes & fees</li>
                        <li>Benefit from compounding</li>
                        <li>Less stress, no market timing</li>
                        <li>Typically invests in index funds or quality stocks</li>
                    </ul>
                </div>
                <div>
                    <h4><i class="fas fa-chart-line"></i> Active Trading</h4>
                    <ul>
                        <li>Short‑term horizon (days to months)</li>
                        <li>High turnover → higher taxes (short‑term gains) & commissions</li>
                        <li>Attempts to outperform market</li>
                        <li>Requires time, research, and discipline</li>
                        <li>Higher risk of underperformance</li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- key considerations -->
        <div class="rule-grid animate">
            <div class="rule-item">
                <h4><i class="fas fa-coins"></i> Taxes Matter</h4>
                <p>Long‑term capital gains (held >1 year) are taxed at lower rates (0%, 15%, 20%) than short‑term gains (ordinary income rates, up to 37%).</p>
            </div>
            <div class="rule-item">
                <h4><i class="fas fa-chart-pie"></i> Fees Add Up</h4>
                <p>Active trading incurs commissions, bid‑ask spreads, and higher fund expense ratios. Over decades, these costs can significantly reduce returns.</p>
            </div>
            <div class="rule-item">
                <h4><i class="fas fa-brain"></i> Emotional Discipline</h4>
                <p>Active trading requires constant monitoring and can lead to emotional decisions. Buy‑and‑hold investors just ignore the noise.</p>
            </div>
        </div>

        <!-- interactive tool: Strategy Comparison Simulator -->
        <div class="card animate" style="margin: 40px 0;" id="strategy-simulator">
            <h3><i class="fas fa-scale-balanced"></i> Strategy Comparison Simulator</h3>
            <p>Compare after‑tax outcomes of buy‑and‑hold vs. active trading. Adjust assumptions and see which strategy might leave you with more money.</p>

            <div style="display: flex; flex-wrap: wrap; gap: 20px; margin: 20px 0;">
                <div style="flex: 1 1 180px;">
                    <label style="display: block; font-weight: 600;">Initial investment ($)</label>
                    <input type="number" id="stratInitial" class="cat-input" value="10000" min="0" step="1000">
                </div>
                <div style="flex: 1 1 180px;">
                    <label style="display: block; font-weight: 600;">Years</label>
                    <input type="number" id="stratYears" class="cat-input" value="10" min="1" max="50" step="1">
                </div>
            </div>

            <h4 style="margin: 20px 0 10px;">Buy‑and‑Hold Assumptions</h4>
            <div style="display: flex; flex-wrap: wrap; gap: 20px;">
                <div style="flex: 1 1 180px;">
                    <label style="display: block; font-weight: 600;">Annual return (%)</label>
                    <input type="number" id="bhReturn" class="cat-input" value="8" min="0" max="30" step="0.5">
                </div>
                <div style="flex: 1 1 180px;">
                    <label style="display: block; font-weight: 600;">Expense ratio (%)</label>
                    <input type="number" id="bhExpense" class="cat-input" value="0.1" min="0" max="5" step="0.1">
                </div>
                <div style="flex: 1 1 180px;">
                    <label style="display: block; font-weight: 600;">Turnover (%)</label>
                    <input type="number" id="bhTurnover" class="cat-input" value="10" min="0" max="100" step="5">
                </div>
            </div>

            <h4 style="margin: 20px 0 10px;">Active Trading Assumptions</h4>
            <div style="display: flex; flex-wrap: wrap; gap: 20px;">
                <div style="flex: 1 1 180px;">
                    <label style="display: block; font-weight: 600;">Annual return (%)</label>
                    <input type="number" id="atReturn" class="cat-input" value="10" min="-20" max="50" step="0.5">
                </div>
                <div style="flex: 1 1 180px;">
                    <label style="display: block; font-weight: 600;">Expense ratio + trading costs (%)</label>
                    <input type="number" id="atExpense" class="cat-input" value="1.5" min="0" max="10" step="0.1">
                </div>
                <div style="flex: 1 1 180px;">
                    <label style="display: block; font-weight: 600;">Turnover (%)</label>
                    <input type="number" id="atTurnover" class="cat-input" value="100" min="0" max="200" step="10">
                </div>
            </div>

            <h4 style="margin: 20px 0 10px;">Tax Assumptions</h4>
            <div style="display: flex; flex-wrap: wrap; gap: 20px;">
                <div style="flex: 1 1 180px;">
                    <label style="display: block; font-weight: 600;">Long‑term cap gains rate (%)</label>
                    <input type="number" id="ltcgRate" class="cat-input" value="15" min="0" max="30" step="1">
                </div>
                <div style="flex: 1 1 180px;">
                    <label style="display: block; font-weight: 600;">Short‑term / ordinary rate (%)</label>
                    <input type="number" id="stcgRate" class="cat-input" value="32" min="0" max="50" step="1">
                </div>
            </div>

            <div style="margin-top: 20px;">
                <button id="compareStrategies" class="btn-outline">Compare Strategies</button>
            </div>

            <div id="strategyResult" style="margin-top: 25px; padding: 20px; background: var(--light-color); border-radius: 12px;">
                Your comparison will appear here.
            </div>

            <p class="pro-tip" style="margin-top: 15px; background-color: #e6f7f0; border-left-color: var(--stocks-accent);">
                <i class="fas fa-lightbulb"></i> This model is simplified. It assumes all gains are realized each year according to turnover, and expenses are deducted annually. Actual results vary.
            </p>
        </div>

        <!-- quiz section (conditional) -->
        {% if app.user and quiz is defined and quiz %}
            {# Logged in user – quiz already taken #}
            <div class="quiz-container animate">
                <h3 style="color:white; margin-top: 0;">🧠 You've already taken this quiz</h3>
                <p style="color: #e2e8f0; font-size: 1.2rem;">
                    Your score: <strong>{{ quiz.quizzScore }}%</strong>
                </p>
                <p style="color: #cbd5e0;">
                    You can retake the quiz to improve your score. Click the button below to reset it.
                </p>
                <div class="quiz-actions">
                    <a href="{{ path('app_page_show', { journey: 'stock', slug: 'long-term-strategies', retake: 1 }) }}"
                       class="btn"
                       style="background-color: #0e9f6e; color: white; text-decoration: none;">
                        Retake Quiz
                    </a>
                </div>
            </div>
        {% else %}
            {# Show quiz (interactivity blocked by JS if not logged in) #}
            <div class="quiz-container animate" data-page-id="{{ page.id }}">
                <h3 style="color:white; margin-top: 0;">📝 Test your knowledge: Long‑Term vs. Active</h3>

                <div class="quiz-question">1. Which statement is true about buy‑and‑hold investing?</div>
                <div class="quiz-options" data-question="1">
                    <div class="quiz-option" data-answer="wrong">It requires daily monitoring of the market</div>
                    <div class="quiz-option" data-answer="correct">It typically incurs lower taxes and fees</div>
                    <div class="quiz-option" data-answer="wrong">It guarantees higher returns</div>
                    <div class="quiz-option" data-answer="wrong">It only works with individual stocks</div>
                </div>

                <div class="quiz-question">2. How are short‑term capital gains taxed?</div>
                <div class="quiz-options" data-question="2">
                    <div class="quiz-option" data-answer="correct">As ordinary income (your marginal tax rate)</div>
                    <div class="quiz-option" data-answer="wrong">At a flat 15%</div>
                    <div class="quiz-option" data-answer="wrong">They are tax‑free</div>
                    <div class="quiz-option" data-answer="wrong">At a lower rate than long‑term gains</div>
                </div>

                <div class="quiz-question">3. A major risk of active trading is:</div>
                <div class="quiz-options" data-question="3">
                    <div class="quiz-option" data-answer="wrong">Missing out on dividends</div>
                    <div class="quiz-option" data-answer="correct">Underperforming the market after fees and taxes</div>
                    <div class="quiz-option" data-answer="wrong">Inflation</div>
                    <div class="quiz-option" data-answer="wrong">Lack of liquidity</div>
                </div>

                <div class="quiz-question">4. What is a typical expense ratio for an index fund used in buy‑and‑hold?</div>
                <div class="quiz-options" data-question="4">
                    <div class="quiz-option" data-answer="correct">0.03% – 0.10%</div>
                    <div class="quiz-option" data-answer="wrong">1.5% – 2%</div>
                    <div class="quiz-option" data-answer="wrong">5%</div>
                    <div class="quiz-option" data-answer="wrong">0% (always free)</div>
                </div>

                <div class="quiz-question">5. Why might buy‑and‑hold be less stressful?</div>
                <div class="quiz-options" data-question="5">
                    <div class="quiz-option" data-answer="wrong">You never look at your portfolio</div>
                    <div class="quiz-option" data-answer="correct">You don't need to time the market or react to daily news</div>
                    <div class="quiz-option" data-answer="wrong">It always makes money</div>
                    <div class="quiz-option" data-answer="wrong">There are no decisions to make</div>
                </div>

                <div class="quiz-actions">
                    <button id="quiz-submit" class="btn">Get score & submit</button>
                </div>
                <div class="quiz-result"></div>
            </div>
        {% endif %}

        <!-- next steps in phase 4 (skill building) -->
        <section style="margin: 60px 0;">
            <h2 class="section-title" style="text-align: center;">📘 Continue Phase 4: Skill Building</h2>
            <div class="next-steps">
                <a href="{{ path('app_page_show', { journey: 'stock', slug: 'fundamental-analysis' }) }}" class="next-card">
                    <i class="fas fa-file-lines"></i>
                    <h3>Fundamental Analysis</h3>
                    <p>Reading financial statements.</p>
                </a>
                <a href="{{ path('app_page_show', { journey: 'stock', slug: 'introduction-to-valuation' }) }}" class="next-card">
                    <i class="fas fa-calculator"></i>
                    <h3>Introduction to Valuation</h3>
                    <p>P/E, PEG, and intrinsic value.</p>
                </a>
                <a href="{{ path('app_page_show', { journey: 'stock', slug: 'dividend-investing' }) }}" class="next-card">
                    <i class="fas fa-hand-holding-dollar"></i>
                    <h3>Dividend Investing</h3>
                    <p>Building passive income streams.</p>
                </a>
            </div>
        </section>
    </div>
{% endblock %}
