{# templates/roadmaps/stock/common-stock-vs-preferred.html.twig #}
{% extends 'base-roadmaps.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('stock_css') }}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('stock_js') }}
{% endblock %}

{% block body %}
    <div class="container">
        <!-- article hero – stock style -->
        <div class="article-hero animate">
            <div class="hero-content">
                <div class="hero-icon" style="background-color: var(--stocks-accent);">
                    <i class="fas fa-coins"></i>
                </div>
                <h1>Common Stock vs. Preferred Stock <span>& Dividends</span></h1>
                <p class="hero-description">
                    Not all shares are created equal. Learn the key differences between common and preferred stock, how dividends work, and which might suit your investment goals.
                </p>
                <div class="phase-tag">
                    <i class="fas fa-layer-group"></i> Phase 1: Foundation First · 6 min read
                </div>
            </div>
        </div>

        <!-- introduction -->
        <section class="animate">
            <h2 class="section-title">📊 Two Flavors of Stock</h2>
            <p style="font-size: 1.2rem; margin-bottom: 20px;">
                When you buy stock, you usually get <strong>common stock</strong>. But companies can also issue <strong>preferred stock</strong>, which behaves more like a hybrid of a stock and a bond. Understanding the difference helps you choose the right investment for your income needs and risk tolerance.
            </p>
        </section>

        <!-- comparison grid -->
        <div class="rule-grid animate">
            <div class="rule-item" style="border-top-color: var(--stocks-accent);">
                <h3><i class="fas fa-users"></i> Common Stock</h3>
                <ul style="list-style-type: none; padding-left: 0;">
                    <li><i class="fas fa-check-circle" style="color: var(--stocks-accent);"></i> Voting rights (usually one vote per share)</li>
                    <li><i class="fas fa-check-circle" style="color: var(--stocks-accent);"></i> Dividends variable, not guaranteed</li>
                    <li><i class="fas fa-check-circle" style="color: var(--stocks-accent);"></i> Higher potential for capital appreciation</li>
                    <li><i class="fas fa-exclamation-triangle" style="color: #e67e22;"></i> Last in line if company goes bankrupt</li>
                </ul>
            </div>
            <div class="rule-item" style="border-top-color: var(--stocks-accent);">
                <h3><i class="fas fa-crown"></i> Preferred Stock</h3>
                <ul style="list-style-type: none; padding-left: 0;">
                    <li><i class="fas fa-times-circle" style="color: #e74c3c;"></i> No voting rights (typically)</li>
                    <li><i class="fas fa-check-circle" style="color: var(--stocks-accent);"></i> Fixed dividend, paid before common dividends</li>
                    <li><i class="fas fa-check-circle" style="color: var(--stocks-accent);"></i> Lower price volatility</li>
                    <li><i class="fas fa-check-circle" style="color: var(--stocks-accent);"></i> Higher claim on assets in bankruptcy</li>
                </ul>
            </div>
        </div>

        <!-- dividends section -->
        <div class="card animate" style="margin: 40px 0;">
            <h3 style="font-size: 1.8rem; margin-bottom: 20px;">💵 What Are Dividends?</h3>
            <p>
                Dividends are payments made by a corporation to its shareholders out of profits. They represent a share of the company's earnings. Companies that pay dividends are often mature, stable businesses.
            </p>
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-top: 20px;">
                <div>
                    <h4>📅 Dividend Frequency</h4>
                    <p>Most U.S. companies pay quarterly, but some pay monthly or annually.</p>
                </div>
                <div>
                    <h4>💰 Dividend Yield</h4>
                    <p>Annual dividend per share ÷ stock price. A 3% yield means you get $3 per year for every $100 invested.</p>
                </div>
                <div>
                    <h4>🔄 DRIP</h4>
                    <p>Dividend Reinvestment Plans automatically use dividends to buy more shares, accelerating compounding.</p>
                </div>
            </div>
        </div>

        <!-- interactive tool: Dividend Income Simulator -->
        <div class="card animate" style="margin: 40px 0;" id="dividend-simulator">
            <h3><i class="fas fa-calculator"></i> Dividend Income Simulator</h3>
            <p>Estimate how much annual dividend income you could generate and see the power of reinvestment.</p>

            <div style="display: flex; flex-wrap: wrap; gap: 15px; margin: 20px 0;">
                <div style="flex: 1 1 180px;">
                    <label style="display: block; font-weight: 600;">Number of shares</label>
                    <input type="number" id="divShares" class="cat-input" value="100" min="1" step="1">
                </div>
                <div style="flex: 1 1 180px;">
                    <label style="display: block; font-weight: 600;">Share price ($)</label>
                    <input type="number" id="divPrice" class="cat-input" value="50.00" min="0.01" step="0.01">
                </div>
                <div style="flex: 1 1 180px;">
                    <label style="display: block; font-weight: 600;">Dividend yield (%)</label>
                    <input type="number" id="divYield" class="cat-input" value="3.5" min="0" max="20" step="0.1">
                </div>
                <div style="flex: 1 1 180px;">
                    <label style="display: block; font-weight: 600;">Years</label>
                    <input type="number" id="divYears" class="cat-input" value="10" min="1" max="50" step="1">
                </div>
            </div>

            <div style="margin: 15px 0;">
                <label style="display: flex; align-items: center; gap: 10px;">
                    <input type="checkbox" id="reinvestCheck" checked>
                    <span>Reinvest dividends (DRIP)</span>
                </label>
            </div>

            <div style="margin-top: 20px;">
                <button id="calculateDividend" class="btn-outline">Calculate Dividend Income</button>
            </div>

            <div id="dividendResult" style="margin-top: 25px; padding: 15px; background: var(--light-color); border-radius: 12px;">
                Enter values and click calculate.
            </div>

            <p class="pro-tip" style="margin-top: 15px; background-color: #e6f7f0; border-left-color: var(--stocks-accent);">
                <i class="fas fa-lightbulb"></i> DRIP can significantly boost long‑term returns. This is a simplified projection; actual dividends and prices change.
            </p>
        </div>

        <!-- quiz section (conditional) -->
        {% if app.user and quiz is defined and quiz %}
            {# Logged in user – quiz already taken #}
            <div class="quiz-container animate">
                <h3 style="color:white; margin-top: 0;">🧠 You've already taken this quiz</h3>
                <p style="color: #e2e8f0; font-size: 1.2rem;">
                    Your score: <strong>{{ quiz.quizzScore }}%</strong>
                </p>
                <p style="color: #cbd5e0;">
                    You can retake the quiz to improve your score. Click the button below to reset it.
                </p>
                <div class="quiz-actions">
                    <a href="{{ path('app_page_show', { journey: 'stock', slug: 'common-stock-vs-preferred', retake: 1 }) }}"
                       class="btn"
                       style="background-color: #0e9f6e; color: white; text-decoration: none;">
                        Retake Quiz
                    </a>
                </div>
            </div>
        {% else %}
            {# Show quiz (interactivity blocked by JS if not logged in) #}
            <div class="quiz-container animate" data-page-id="{{ page.id }}">
                <h3 style="color:white; margin-top: 0;">📝 Test your knowledge: Common vs Preferred & Dividends</h3>

                <div class="quiz-question">1. Which type of stock typically gives you voting rights?</div>
                <div class="quiz-options" data-question="1">
                    <div class="quiz-option" data-answer="wrong">Preferred stock</div>
                    <div class="quiz-option" data-answer="correct">Common stock</div>
                    <div class="quiz-option" data-answer="wrong">Both</div>
                    <div class="quiz-option" data-answer="wrong">Neither</div>
                </div>

                <div class="quiz-question">2. In case of bankruptcy, who gets paid first?</div>
                <div class="quiz-options" data-question="2">
                    <div class="quiz-option" data-answer="wrong">Common shareholders</div>
                    <div class="quiz-option" data-answer="correct">Preferred shareholders</div>
                    <div class="quiz-option" data-answer="wrong">Both equally</div>
                    <div class="quiz-option" data-answer="wrong">Neither</div>
                </div>

                <div class="quiz-question">3. What is a dividend?</div>
                <div class="quiz-options" data-question="3">
                    <div class="quiz-option" data-answer="wrong">A fee paid to the broker</div>
                    <div class="quiz-option" data-answer="correct">A portion of a company's profits paid to shareholders</div>
                    <div class="quiz-option" data-answer="wrong">The interest on a bond</div>
                    <div class="quiz-option" data-answer="wrong">The price difference between buying and selling</div>
                </div>

                <div class="quiz-question">4. Which type of stock usually has a fixed dividend?</div>
                <div class="quiz-options" data-question="4">
                    <div class="quiz-option" data-answer="wrong">Common stock</div>
                    <div class="quiz-option" data-answer="correct">Preferred stock</div>
                    <div class="quiz-option" data-answer="wrong">Both</div>
                    <div class="quiz-option" data-answer="wrong">Neither</div>
                </div>

                <div class="quiz-question">5. What does DRIP stand for?</div>
                <div class="quiz-options" data-question="5">
                    <div class="quiz-option" data-answer="wrong">Daily Return Investment Plan</div>
                    <div class="quiz-option" data-answer="correct">Dividend Reinvestment Plan</div>
                    <div class="quiz-option" data-answer="wrong">Direct Roth Investment Plan</div>
                    <div class="quiz-option" data-answer="wrong">Dividend Reduction Insurance Plan</div>
                </div>

                <div class="quiz-actions">
                    <button id="quiz-submit" class="btn">Get score & submit</button>
                </div>
                <div class="quiz-result"></div>
            </div>
        {% endif %}

        <!-- next steps in phase 1 (foundation first) -->
        <section style="margin: 60px 0;">
            <h2 class="section-title" style="text-align: center;">📘 Continue Phase 1: Foundation First</h2>
            <div class="next-steps">
                <a href="{{ path('app_page_show', { journey: 'stock', slug: 'what-is-a-stock' }) }}" class="next-card">
                    <i class="fas fa-file-invoice"></i>
                    <h3>What is a Stock?</h3>
                    <p>Understand ownership and why companies issue shares.</p>
                </a>
                <a href="{{ path('app_page_show', { journey: 'stock', slug: 'how-stock-market-works' }) }}" class="next-card">
                    <i class="fas fa-building"></i>
                    <h3>How the Stock Market Works</h3>
                    <p>Demystify exchanges, indices, and market participants.</p>
                </a>
                <a href="{{ path('app_page_show', { journey: 'stock', slug: 'why-invest-in-stocks' }) }}" class="next-card">
                    <i class="fas fa-chart-line"></i>
                    <h3>Why Invest in Stocks?</h3>
                    <p>Explore historical returns and the power of compounding.</p>
                </a>
            </div>
        </section>
    </div>
{% endblock %}
