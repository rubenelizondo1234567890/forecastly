{# templates/roadmaps/stock/fundamental-analysis.html.twig #}
{% extends 'base-roadmaps.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('stock_css') }}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('stock_js') }}
{% endblock %}

{% block body %}
    <div class="container">
        <!-- article hero – stock style -->
        <div class="article-hero animate">
            <div class="hero-content">
                <div class="hero-icon" style="background-color: var(--stocks-accent);">
                    <i class="fas fa-file-lines"></i>
                </div>
                <h1>Fundamental Analysis <span>Reading Financial Statements</span></h1>
                <p class="hero-description">
                    Learn how to analyze a company's health by reading its income statement, balance sheet, and cash flow statement. The foundation of intelligent investing.
                </p>
                <div class="phase-tag">
                    <i class="fas fa-layer-group"></i> Phase 4: Skill Building · 12 min read
                </div>
            </div>
        </div>

        <!-- introduction -->
        <section class="animate">
            <h2 class="section-title">📚 What Is Fundamental Analysis?</h2>
            <p style="font-size: 1.2rem; margin-bottom: 20px;">
                <strong>Fundamental analysis</strong> is the process of evaluating a company's intrinsic value by examining its financial statements, management, competitive advantages, and the overall economy. For stock investors, the three key financial statements are essential tools.
            </p>
        </section>

        <!-- the three statements -->
        <div class="card animate" style="margin: 40px 0;">
            <h3 style="font-size: 1.8rem; margin-bottom: 20px;">📄 The Big Three</h3>
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px;">
                <div>
                    <h4><i class="fas fa-chart-simple"></i> Income Statement</h4>
                    <p>Shows revenue, expenses, and profit over a period. Key metrics: Revenue, Gross Profit, Operating Income, Net Income, Earnings Per Share (EPS).</p>
                </div>
                <div>
                    <h4><i class="fas fa-scale-balanced"></i> Balance Sheet</h4>
                    <p>A snapshot of assets, liabilities, and shareholders' equity at a point in time. Key equation: Assets = Liabilities + Equity.</p>
                </div>
                <div>
                    <h4><i class="fas fa-water"></i> Cash Flow Statement</h4>
                    <p>Shows cash inflows and outflows from operations, investing, and financing. Critical because profits don't always equal cash.</p>
                </div>
            </div>
        </div>

        <!-- key ratios -->
        <div class="rule-grid animate">
            <div class="rule-item">
                <h4><i class="fas fa-percent"></i> Profit Margin</h4>
                <p>Net Income ÷ Revenue. Indicates how much of each dollar of sales becomes profit.</p>
            </div>
            <div class="rule-item">
                <h4><i class="fas fa-arrow-trend-up"></i> Return on Assets (ROA)</h4>
                <p>Net Income ÷ Total Assets. Measures how efficiently a company uses its assets to generate profit.</p>
            </div>
            <div class="rule-item">
                <h4><i class="fas fa-credit-card"></i> Debt-to-Assets</h4>
                <p>Total Liabilities ÷ Total Assets. Shows what proportion of assets is financed by debt.</p>
            </div>
            <div class="rule-item">
                <h4><i class="fas fa-hand-holding-dollar"></i> Operating Cash Flow / Revenue</h4>
                <p>Operating Cash Flow ÷ Revenue. Indicates how much revenue turns into actual cash from operations.</p>
            </div>
        </div>

        <!-- interactive tool: Financial Statement Analyzer -->
        <div class="card animate" style="margin: 40px 0;" id="financial-analyzer">
            <h3><i class="fas fa-robot"></i> Financial Statement Analyzer</h3>
            <p>Enter key numbers from a company's financials to get a quick health score. (All fields required.)</p>

            <div style="display: flex; flex-wrap: wrap; gap: 20px; margin: 20px 0;">
                <div style="flex: 1 1 200px;">
                    <label style="display: block; font-weight: 600;">Revenue ($M)</label>
                    <input type="number" id="revenue" class="cat-input" value="1000" min="0" step="1">
                </div>
                <div style="flex: 1 1 200px;">
                    <label style="display: block; font-weight: 600;">Net Income ($M)</label>
                    <input type="number" id="netIncome" class="cat-input" value="120" min="-1000" step="1">
                </div>
                <div style="flex: 1 1 200px;">
                    <label style="display: block; font-weight: 600;">Total Assets ($M)</label>
                    <input type="number" id="totalAssets" class="cat-input" value="2000" min="0" step="1">
                </div>
                <div style="flex: 1 1 200px;">
                    <label style="display: block; font-weight: 600;">Total Liabilities ($M)</label>
                    <input type="number" id="totalLiabilities" class="cat-input" value="800" min="0" step="1">
                </div>
                <div style="flex: 1 1 200px;">
                    <label style="display: block; font-weight: 600;">Operating Cash Flow ($M)</label>
                    <input type="number" id="opCashFlow" class="cat-input" value="150" min="-1000" step="1">
                </div>
            </div>

            <div style="margin-top: 20px;">
                <button id="analyzeFinancials" class="btn-outline">Analyze Financial Health</button>
            </div>

            <div id="financialResult" style="margin-top: 25px; padding: 20px; background: var(--light-color); border-radius: 12px;">
                Enter values and click analyze.
            </div>

            <p class="pro-tip" style="margin-top: 15px; background-color: #e6f7f0; border-left-color: var(--stocks-accent);">
                <i class="fas fa-lightbulb"></i> This tool uses simplified ratios. Real analysis requires comparing to industry peers and historical trends.
            </p>
        </div>

        <!-- quiz section (conditional) -->
        {% if app.user and quiz is defined and quiz %}
            {# Logged in user – quiz already taken #}
            <div class="quiz-container animate">
                <h3 style="color:white; margin-top: 0;">🧠 You've already taken this quiz</h3>
                <p style="color: #e2e8f0; font-size: 1.2rem;">
                    Your score: <strong>{{ quiz.quizzScore }}%</strong>
                </p>
                <p style="color: #cbd5e0;">
                    You can retake the quiz to improve your score. Click the button below to reset it.
                </p>
                <div class="quiz-actions">
                    <a href="{{ path('app_page_show', { journey: 'stock', slug: 'fundamental-analysis', retake: 1 }) }}"
                       class="btn"
                       style="background-color: #0e9f6e; color: white; text-decoration: none;">
                        Retake Quiz
                    </a>
                </div>
            </div>
        {% else %}
            {# Show quiz (interactivity blocked by JS if not logged in) #}
            <div class="quiz-container animate" data-page-id="{{ page.id }}">
                <h3 style="color:white; margin-top: 0;">📝 Test your knowledge: Fundamental Analysis</h3>

                <div class="quiz-question">1. Which financial statement shows a company's financial position at a specific point in time?</div>
                <div class="quiz-options" data-question="1">
                    <div class="quiz-option" data-answer="wrong">Income Statement</div>
                    <div class="quiz-option" data-answer="correct">Balance Sheet</div>
                    <div class="quiz-option" data-answer="wrong">Cash Flow Statement</div>
                    <div class="quiz-option" data-answer="wrong">Statement of Equity</div>
                </div>

                <div class="quiz-question">2. Net Income divided by Revenue is called:</div>
                <div class="quiz-options" data-question="2">
                    <div class="quiz-option" data-answer="wrong">Return on Assets</div>
                    <div class="quiz-option" data-answer="correct">Profit Margin</div>
                    <div class="quiz-option" data-answer="wrong">Debt-to-Equity</div>
                    <div class="quiz-option" data-answer="wrong">P/E Ratio</div>
                </div>

                <div class="quiz-question">3. Which statement is most useful for understanding a company's ability to generate cash?</div>
                <div class="quiz-options" data-question="3">
                    <div class="quiz-option" data-answer="wrong">Income Statement</div>
                    <div class="quiz-option" data-answer="wrong">Balance Sheet</div>
                    <div class="quiz-option" data-answer="correct">Cash Flow Statement</div>
                    <div class="quiz-option" data-answer="wrong">Notes to Accounts</div>
                </div>

                <div class="quiz-question">4. A high debt-to-assets ratio might indicate:</div>
                <div class="quiz-options" data-question="4">
                    <div class="quiz-option" data-answer="correct">The company is highly leveraged and potentially risky</div>
                    <div class="quiz-option" data-answer="wrong">Strong profitability</div>
                    <div class="quiz-option" data-answer="wrong">High cash reserves</div>
                    <div class="quiz-option" data-answer="wrong">Low expenses</div>
                </div>

                <div class="quiz-question">5. Return on Assets (ROA) measures:</div>
                <div class="quiz-options" data-question="5">
                    <div class="quiz-option" data-answer="correct">How efficiently a company uses its assets to generate profit</div>
                    <div class="quiz-option" data-answer="wrong">The return to shareholders</div>
                    <div class="quiz-option" data-answer="wrong">The company's liquidity</div>
                    <div class="quiz-option" data-answer="wrong">The growth rate of revenue</div>
                </div>

                <div class="quiz-actions">
                    <button id="quiz-submit" class="btn">Get score & submit</button>
                </div>
                <div class="quiz-result"></div>
            </div>
        {% endif %}

        <!-- next steps in phase 4 (skill building) -->
        <section style="margin: 60px 0;">
            <h2 class="section-title" style="text-align: center;">📘 Continue Phase 4: Skill Building</h2>
            <div class="next-steps">
                <a href="{{ path('app_page_show', { journey: 'stock', slug: 'introduction-to-valuation' }) }}" class="next-card">
                    <i class="fas fa-calculator"></i>
                    <h3>Introduction to Valuation</h3>
                    <p>P/E, PEG, and intrinsic value explained.</p>
                </a>
                <a href="{{ path('app_page_show', { journey: 'stock', slug: 'dividend-investing' }) }}" class="next-card">
                    <i class="fas fa-hand-holding-dollar"></i>
                    <h3>Dividend Investing</h3>
                    <p>Building passive income streams.</p>
                </a>
                <a href="{{ path('app_page_show', { journey: 'stock', slug: 'long-term-strategies' }) }}" class="next-card">
                    <i class="fas fa-arrows-spin"></i>
                    <h3>Long‑Term Strategies</h3>
                    <p>Buy‑and‑hold vs. active trading.</p>
                </a>
            </div>
        </section>
    </div>
{% endblock %}
