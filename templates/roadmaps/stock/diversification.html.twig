{# templates/roadmaps/stock/diversification.html.twig #}
{% extends 'base-roadmaps.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('stock_css') }}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('stock_js') }}
{% endblock %}

{% block body %}
    <div class="container">
        <!-- article hero – stock style -->
        <div class="article-hero animate">
            <div class="hero-content">
                <div class="hero-icon" style="background-color: var(--stocks-accent);">
                    <i class="fas fa-random"></i>
                </div>
                <h1>Diversification <span>Don't Put All Eggs in One Basket</span></h1>
                <p class="hero-description">
                    Spreading your investments across different assets reduces risk without necessarily sacrificing returns. Learn how to build a resilient portfolio.
                </p>
                <div class="phase-tag">
                    <i class="fas fa-layer-group"></i> Phase 2: Risk Management · 9 min read
                </div>
            </div>
        </div>

        <!-- introduction -->
        <section class="animate">
            <h2 class="section-title">🧺 What Is Diversification?</h2>
            <p style="font-size: 1.2rem; margin-bottom: 20px;">
                <strong>Diversification</strong> is the practice of spreading your investments among different financial assets, sectors, and geographies to reduce exposure to any single source of risk. The goal is to smooth out returns so that a sharp drop in one area doesn't devastate your entire portfolio.
            </p>
            <p style="font-size: 1.1rem; color: var(--gray-color);">
                The famous saying "don't put all your eggs in one basket" captures the idea perfectly. If you drop one basket, you still have eggs in the others.
            </p>
        </section>

        <!-- why it works: correlation -->
        <div class="card animate" style="margin: 40px 0;">
            <h3 style="font-size: 1.8rem; margin-bottom: 20px;">📉 Why Diversification Works: Correlation</h3>
            <p>
                <strong>Correlation</strong> measures how two investments move in relation to each other. It ranges from -1 to +1.
            </p>
            <ul style="margin-left: 20px; margin-bottom: 20px;">
                <li><strong>+1:</strong> They move in perfect lockstep – no diversification benefit.</li>
                <li><strong>0:</strong> They move independently – good diversification.</li>
                <li><strong>-1:</strong> They move opposite – ideal diversification, but rare.</li>
            </ul>
            <p>
                By combining assets with low or negative correlation, you can reduce overall portfolio volatility while maintaining expected returns.
            </p>
        </div>

        <!-- ways to diversify -->
        <div class="rule-grid animate">
            <div class="rule-item">
                <h4><i class="fas fa-chart-pie"></i> Asset Classes</h4>
                <p>Stocks, bonds, real estate, commodities, cash. Each behaves differently under various economic conditions.</p>
            </div>
            <div class="rule-item">
                <h4><i class="fas fa-industry"></i> Sectors</h4>
                <p>Technology, healthcare, energy, consumer goods, etc. Don't let one industry sink your portfolio.</p>
            </div>
            <div class="rule-item">
                <h4><i class="fas fa-globe"></i> Geographies</h4>
                <p>Domestic vs. international stocks. Different countries have different growth cycles.</p>
            </div>
        </div>

        <!-- interactive tool: Diversification Simulator -->
        <div class="card animate" style="margin: 40px 0;" id="diversification-simulator">
            <h3><i class="fas fa-chart-line"></i> Diversification Simulator</h3>
            <p>See how combining two assets with different expected returns and risks affects your portfolio. Adjust the allocation and correlation to find the optimal mix.</p>

            <div style="display: flex; flex-wrap: wrap; gap: 20px; margin: 20px 0;">
                <!-- Asset 1 -->
                <div style="flex: 1 1 200px; background: #f8fafc; padding: 15px; border-radius: 12px;">
                    <h4 style="margin-bottom: 10px;">Asset A (e.g., Stocks)</h4>
                    <label>Expected return (%) <input type="number" id="returnA" class="cat-input" value="8" min="0" max="30" step="0.5"></label><br>
                    <label>Risk (std dev %) <input type="number" id="riskA" class="cat-input" value="15" min="0" max="50" step="0.5"></label>
                </div>
                <!-- Asset 2 -->
                <div style="flex: 1 1 200px; background: #f8fafc; padding: 15px; border-radius: 12px;">
                    <h4 style="margin-bottom: 10px;">Asset B (e.g., Bonds)</h4>
                    <label>Expected return (%) <input type="number" id="returnB" class="cat-input" value="4" min="0" max="30" step="0.5"></label><br>
                    <label>Risk (std dev %) <input type="number" id="riskB" class="cat-input" value="5" min="0" max="50" step="0.5"></label>
                </div>
            </div>

            <div style="display: flex; flex-wrap: wrap; gap: 20px; align-items: center;">
                <div style="flex: 2 1 250px;">
                    <label>Weight in Asset A (%) <span id="weightAValue">60</span>%</label>
                    <input type="range" id="weightA" min="0" max="100" value="60" step="1" style="width:100%;">
                </div>
                <div style="flex: 1 1 200px;">
                    <label>Correlation (-1 to +1) <input type="number" id="correlation" class="cat-input" value="0.2" min="-1" max="1" step="0.05"></label>
                </div>
            </div>

            <div style="margin-top: 20px;">
                <button id="calculateDiversification" class="btn-outline">Calculate Portfolio Risk & Return</button>
            </div>

            <div id="diversificationResult" style="margin-top: 25px; padding: 20px; background: var(--light-color); border-radius: 12px;">
                <p>Adjust the sliders and click calculate.</p>
            </div>

            <p class="pro-tip" style="margin-top: 15px; background-color: #e6f7f0; border-left-color: var(--stocks-accent);">
                <i class="fas fa-lightbulb"></i> The lower the correlation, the greater the risk reduction. Perfect negative correlation (-1) can theoretically eliminate risk, but it's rare in real markets.
            </p>
        </div>

        <!-- quiz section (conditional) -->
        {% if app.user and quiz is defined and quiz %}
            {# Logged in user – quiz already taken #}
            <div class="quiz-container animate">
                <h3 style="color:white; margin-top: 0;">🧠 You've already taken this quiz</h3>
                <p style="color: #e2e8f0; font-size: 1.2rem;">
                    Your score: <strong>{{ quiz.quizzScore }}%</strong>
                </p>
                <p style="color: #cbd5e0;">
                    You can retake the quiz to improve your score. Click the button below to reset it.
                </p>
                <div class="quiz-actions">
                    <a href="{{ path('app_page_show', { journey: 'stock', slug: 'diversification', retake: 1 }) }}"
                       class="btn"
                       style="background-color: #0e9f6e; color: white; text-decoration: none;">
                        Retake Quiz
                    </a>
                </div>
            </div>
        {% else %}
            {# Show quiz (interactivity blocked by JS if not logged in) #}
            <div class="quiz-container animate" data-page-id="{{ page.id }}">
                <h3 style="color:white; margin-top: 0;">📝 Test your knowledge: Diversification</h3>

                <div class="quiz-question">1. What is diversification?</div>
                <div class="quiz-options" data-question="1">
                    <div class="quiz-option" data-answer="wrong">Buying only one stock</div>
                    <div class="quiz-option" data-answer="correct">Spreading investments across different assets to reduce risk</div>
                    <div class="quiz-option" data-answer="wrong">Investing all money in the safest asset</div>
                    <div class="quiz-option" data-answer="wrong">Timing the market</div>
                </div>

                <div class="quiz-question">2. Which correlation coefficient provides the greatest diversification benefit?</div>
                <div class="quiz-options" data-question="2">
                    <div class="quiz-option" data-answer="wrong">+1</div>
                    <div class="quiz-option" data-answer="wrong">0</div>
                    <div class="quiz-option" data-answer="correct">-1</div>
                    <div class="quiz-option" data-answer="wrong">+0.5</div>
                </div>

                <div class="quiz-question">3. Which of the following is NOT a way to diversify?</div>
                <div class="quiz-options" data-question="3">
                    <div class="quiz-option" data-answer="wrong">Investing in different sectors</div>
                    <div class="quiz-option" data-answer="wrong">Investing in different countries</div>
                    <div class="quiz-option" data-answer="correct">Putting all your money in one company's stock</div>
                    <div class="quiz-option" data-answer="wrong">Including bonds and stocks</div>
                </div>

                <div class="quiz-question">4. What is the main benefit of diversification?</div>
                <div class="quiz-options" data-question="4">
                    <div class="quiz-option" data-answer="wrong">Higher guaranteed returns</div>
                    <div class="quiz-option" data-answer="correct">Reduced portfolio volatility</div>
                    <div class="quiz-option" data-answer="wrong">Elimination of all risk</div>
                    <div class="quiz-option" data-answer="wrong">Faster compounding</div>
                </div>

                <div class="quiz-question">5. If two assets have a correlation of +0.9, what does that mean?</div>
                <div class="quiz-options" data-question="5">
                    <div class="quiz-option" data-answer="correct">They tend to move in the same direction most of the time</div>
                    <div class="quiz-option" data-answer="wrong">They move opposite each other</div>
                    <div class="quiz-option" data-answer="wrong">They are completely independent</div>
                    <div class="quiz-option" data-answer="wrong">One is always better than the other</div>
                </div>

                <div class="quiz-actions">
                    <button id="quiz-submit" class="btn">Get score & submit</button>
                </div>
                <div class="quiz-result"></div>
            </div>
        {% endif %}

        <!-- next steps in phase 2 (risk management) -->
        <section style="margin: 60px 0;">
            <h2 class="section-title" style="text-align: center;">📘 Continue Phase 2: Risk Management</h2>
            <div class="next-steps">
                <a href="{{ path('app_page_show', { journey: 'stock', slug: 'market-volatility' }) }}" class="next-card">
                    <i class="fas fa-wave-square"></i>
                    <h3>Market Volatility</h3>
                    <p>Understand market cycles and how to stay calm during dips.</p>
                </a>
                <a href="{{ path('app_page_show', { journey: 'stock', slug: 'asset-allocation' }) }}" class="next-card">
                    <i class="fas fa-scale-balanced"></i>
                    <h3>Asset Allocation</h3>
                    <p>Find the right mix of stocks, bonds, and cash for your goals.</p>
                </a>
                <a href="{{ path('app_page_show', { journey: 'stock', slug: 'risk-tolerance' }) }}" class="next-card">
                    <i class="fas fa-heartbeat"></i>
                    <h3>Risk Tolerance</h3>
                    <p>Revisit how to assess your comfort with risk.</p>
                </a>
            </div>
        </section>
    </div>
{% endblock %}
