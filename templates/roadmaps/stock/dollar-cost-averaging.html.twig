{# templates/roadmaps/stock/dollar-cost-averaging.html.twig #}
{% extends 'base-roadmaps.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('stock_css') }}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('stock_js') }}
{% endblock %}

{% block body %}
    <div class="container">
        <!-- article hero – stock style -->
        <div class="article-hero animate">
            <div class="hero-content">
                <div class="hero-icon" style="background-color: var(--stocks-accent);">
                    <i class="fas fa-clock"></i>
                </div>
                <h1>Dollar‑Cost Averaging <span>Invest Consistently Without Stress</span></h1>
                <p class="hero-description">
                    Learn how investing a fixed amount regularly can reduce the impact of market timing and help you build wealth steadily.
                </p>
                <div class="phase-tag">
                    <i class="fas fa-layer-group"></i> Phase 3: Practical Execution · 6 min read
                </div>
            </div>
        </div>

        <!-- introduction -->
        <section class="animate">
            <h2 class="section-title">⏳ What Is Dollar‑Cost Averaging?</h2>
            <p style="font-size: 1.2rem; margin-bottom: 20px;">
                <strong>Dollar‑cost averaging (DCA)</strong> is an investment strategy where you invest a fixed amount of money at regular intervals – regardless of the share price. Over time, you buy more shares when prices are low and fewer when prices are high, which can lower your average cost per share.
            </p>
            <p style="font-size: 1.1rem; color: var(--gray-color);">
                DCA removes the need to time the market. It’s especially popular among beginners and for retirement accounts like 401(k)s, where contributions are automatic.
            </p>
        </section>

        <!-- benefits of DCA -->
        <div class="card animate" style="margin: 40px 0;">
            <h3 style="font-size: 1.8rem; margin-bottom: 20px;">✅ Why Use Dollar‑Cost Averaging?</h3>
            <ul style="margin-left: 20px;">
                <li><strong>Reduces emotional stress:</strong> You invest automatically, ignoring market noise.</li>
                <li><strong>Avoids market timing:</strong> You don’t need to predict highs and lows.</li>
                <li><strong>Discipline:</strong> Encourages consistent saving and investing.</li>
                <li><strong>Works in any market:</strong> You buy more when prices are low, less when high.</li>
                <li><strong>Start small:</strong> You can begin with as little as $50 or $100 per month.</li>
            </ul>
        </div>

        <!-- comparison: lump sum vs. DCA -->
        <div class="rule-grid animate">
            <div class="rule-item">
                <h4><i class="fas fa-hand-holding-usd"></i> Lump Sum</h4>
                <p>Invest everything at once. If the market rises immediately, you win. But if it drops right after, you experience the full loss. Best if you believe the market will go up soon.</p>
            </div>
            <div class="rule-item">
                <h4><i class="fas fa-calendar-alt"></i> Dollar‑Cost Averaging</h4>
                <p>Spread your investment over time. You reduce the risk of investing right before a downturn. Historically, lump sum has outperformed about ⅔ of the time, but DCA helps you sleep better.</p>
            </div>
        </div>

        <!-- interactive tool: DCA Calculator -->
        <div class="card animate" style="margin: 40px 0;" id="dca-calculator">
            <h3><i class="fas fa-calculator"></i> DCA Calculator</h3>
            <p>See how your money can grow by investing a fixed amount each month.</p>

            <div style="display: flex; flex-wrap: wrap; gap: 20px; margin: 20px 0;">
                <div style="flex: 1 1 200px;">
                    <label style="display: block; font-weight: 600;">Monthly investment ($)</label>
                    <input type="number" id="monthlyAmount" class="cat-input" value="200" min="0" step="10">
                </div>
                <div style="flex: 1 1 200px;">
                    <label style="display: block; font-weight: 600;">Number of years</label>
                    <input type="number" id="dcaYears" class="cat-input" value="10" min="1" max="50" step="1">
                </div>
                <div style="flex: 1 1 200px;">
                    <label style="display: block; font-weight: 600;">Expected annual return (%)</label>
                    <input type="number" id="dcaReturn" class="cat-input" value="7" min="0" max="30" step="0.5">
                </div>
            </div>

            <div style="margin-top: 20px;">
                <button id="calculateDCA" class="btn-outline">Calculate Future Value</button>
            </div>

            <div id="dcaResult" style="margin-top: 25px; padding: 20px; background: var(--light-color); border-radius: 12px;">
                Enter values and click calculate.
            </div>

            <p class="pro-tip" style="margin-top: 15px; background-color: #e6f7f0; border-left-color: var(--stocks-accent);">
                <i class="fas fa-lightbulb"></i> This assumes monthly contributions at the end of each month and a constant annual return. Actual results vary.
            </p>
        </div>

        <!-- quiz section (conditional) -->
        {% if app.user and quiz is defined and quiz %}
            {# Logged in user – quiz already taken #}
            <div class="quiz-container animate">
                <h3 style="color:white; margin-top: 0;">🧠 You've already taken this quiz</h3>
                <p style="color: #e2e8f0; font-size: 1.2rem;">
                    Your score: <strong>{{ quiz.quizzScore }}%</strong>
                </p>
                <p style="color: #cbd5e0;">
                    You can retake the quiz to improve your score. Click the button below to reset it.
                </p>
                <div class="quiz-actions">
                    <a href="{{ path('app_page_show', { journey: 'stock', slug: 'dollar-cost-averaging', retake: 1 }) }}"
                       class="btn"
                       style="background-color: #0e9f6e; color: white; text-decoration: none;">
                        Retake Quiz
                    </a>
                </div>
            </div>
        {% else %}
            {# Show quiz (interactivity blocked by JS if not logged in) #}
            <div class="quiz-container animate" data-page-id="{{ page.id }}">
                <h3 style="color:white; margin-top: 0;">📝 Test your knowledge: Dollar‑Cost Averaging</h3>

                <div class="quiz-question">1. What is dollar‑cost averaging?</div>
                <div class="quiz-options" data-question="1">
                    <div class="quiz-option" data-answer="wrong">Investing all your money at once</div>
                    <div class="quiz-option" data-answer="correct">Investing a fixed amount at regular intervals</div>
                    <div class="quiz-option" data-answer="wrong">Buying only when prices are low</div>
                    <div class="quiz-option" data-answer="wrong">Selling shares to average your cost</div>
                </div>

                <div class="quiz-question">2. Which of the following is a benefit of DCA?</div>
                <div class="quiz-options" data-question="2">
                    <div class="quiz-option" data-answer="wrong">It guarantees higher returns</div>
                    <div class="quiz-option" data-answer="correct">It reduces the stress of market timing</div>
                    <div class="quiz-option" data-answer="wrong">It always beats lump sum investing</div>
                    <div class="quiz-option" data-answer="wrong">It eliminates all investment risk</div>
                </div>

                <div class="quiz-question">3. When does DCA cause you to buy more shares?</div>
                <div class="quiz-options" data-question="3">
                    <div class="quiz-option" data-answer="wrong">When prices are high</div>
                    <div class="quiz-option" data-answer="correct">When prices are low</div>
                    <div class="quiz-option" data-answer="wrong">When the market is closed</div>
                    <div class="quiz-option" data-answer="wrong">Every month the same number</div>
                </div>

                <div class="quiz-question">4. Historically, which strategy has outperformed more often?</div>
                <div class="quiz-options" data-question="4">
                    <div class="quiz-option" data-answer="correct">Lump sum investing</div>
                    <div class="quiz-option" data-answer="wrong">Dollar‑cost averaging</div>
                    <div class="quiz-option" data-answer="wrong">They are equal</div>
                    <div class="quiz-option" data-answer="wrong">It depends on the investor's age</div>
                </div>

                <div class="quiz-question">5. Why is DCA especially useful for beginners?</div>
                <div class="quiz-options" data-question="5">
                    <div class="quiz-option" data-answer="correct">It encourages consistent saving and removes the need to time the market</div>
                    <div class="quiz-option" data-answer="wrong">It provides the highest possible returns</div>
                    <div class="quiz-option" data-answer="wrong">It requires a large initial investment</div>
                    <div class="quiz-option" data-answer="wrong">It only works in bull markets</div>
                </div>

                <div class="quiz-actions">
                    <button id="quiz-submit" class="btn">Get score & submit</button>
                </div>
                <div class="quiz-result"></div>
            </div>
        {% endif %}

        <!-- next steps in phase 3 (practical execution) -->
        <section style="margin: 60px 0;">
            <h2 class="section-title" style="text-align: center;">📘 Continue Phase 3: Practical Execution</h2>
            <div class="next-steps">
                <a href="{{ path('app_page_show', { journey: 'stock', slug: 'opening-brokerage-account' }) }}" class="next-card">
                    <i class="fas fa-university"></i>
                    <h3>Opening a Brokerage Account</h3>
                    <p>Step‑by‑step guide to get started.</p>
                </a>
                <a href="{{ path('app_page_show', { journey: 'stock', slug: 'placing-your-first-trade' }) }}" class="next-card">
                    <i class="fas fa-hand-pointer"></i>
                    <h3>Placing Your First Trade</h3>
                    <p>Market vs. limit orders explained.</p>
                </a>
                <a href="{{ path('app_page_show', { journey: 'stock', slug: 'how-to-research-a-stock' }) }}" class="next-card">
                    <i class="fas fa-magnifying-glass-chart"></i>
                    <h3>How to Research a Stock</h3>
                    <p>Key metrics for beginners.</p>
                </a>
            </div>
        </section>
    </div>
{% endblock %}
