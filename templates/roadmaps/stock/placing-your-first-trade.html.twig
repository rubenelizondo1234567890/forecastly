{# templates/roadmaps/stock/placing-your-first-trade.html.twig #}
{% extends 'base-roadmaps.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('stock_css') }}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('stock_js') }}
{% endblock %}

{% block body %}
    <div class="container">
        <!-- article hero – stock style -->
        <div class="article-hero animate">
            <div class="hero-content">
                <div class="hero-icon" style="background-color: var(--stocks-accent);">
                    <i class="fas fa-hand-pointer"></i>
                </div>
                <h1>Placing Your First Trade <span>Market vs. Limit Orders</span></h1>
                <p class="hero-description">
                    Learn the difference between market, limit, and stop orders – and when to use each. Practice with our interactive simulator.
                </p>
                <div class="phase-tag">
                    <i class="fas fa-layer-group"></i> Phase 3: Practical Execution · 7 min read
                </div>
            </div>
        </div>

        <!-- introduction -->
        <section class="animate">
            <h2 class="section-title">📈 What Is an Order?</h2>
            <p style="font-size: 1.2rem; margin-bottom: 20px;">
                An <strong>order</strong> is your instruction to a broker to buy or sell a security. The two most common types are <strong>market orders</strong> and <strong>limit orders</strong>. Understanding the difference helps you control the price you pay or receive.
            </p>
        </section>

        <!-- order types explained -->
        <div class="rule-grid animate">
            <div class="rule-item">
                <h4><i class="fas fa-bolt"></i> Market Order</h4>
                <p>Buys or sells immediately at the best available current price. Execution is fast, but you may get a slightly different price than the last quote (slippage). Best when speed matters more than price.</p>
            </div>
            <div class="rule-item">
                <h4><i class="fas fa-bullseye"></i> Limit Order</h4>
                <p>Buys only at a specified maximum price (or sells at a minimum price). The order waits until the market reaches your limit. Gives price control but may not execute if the price never hits your limit.</p>
            </div>
            <div class="rule-item">
                <h4><i class="fas fa-stop"></i> Stop Order (Stop-Loss)</h4>
                <p>Becomes a market order once a specified stop price is hit. Used to limit losses or protect profits. Example: sell if price drops to $45 to prevent further loss.</p>
            </div>
            <div class="rule-item">
                <h4><i class="fas fa-clock"></i> Stop-Limit Order</h4>
                <p>Combines stop and limit: after the stop price is triggered, a limit order is placed. This gives price control but may not execute if the price moves quickly past your limit.</p>
            </div>
        </div>

        <!-- when to use which -->
        <div class="card animate" style="margin: 40px 0;">
            <h3 style="font-size: 1.8rem; margin-bottom: 20px;">🧠 Choosing the Right Order</h3>
            <ul style="margin-left: 20px;">
                <li><strong>Market order:</strong> Use when you want to get in or out quickly and the stock is highly liquid (like Apple or Microsoft).</li>
                <li><strong>Limit order:</strong> Use when you're not in a hurry and want to buy at a specific price (e.g., you think a stock will dip to $50).</li>
                <li><strong>Stop order:</strong> Essential for risk management – set a stop-loss to cap potential losses.</li>
            </ul>
        </div>

        <!-- interactive tool: Order Type Simulator -->
        <div class="card animate" style="margin: 40px 0;" id="order-simulator">
            <h3><i class="fas fa-flask"></i> Order Type Simulator</h3>
            <p>See how different order types behave with a hypothetical stock price. Set the current price, then configure an order and see if it would execute.</p>

            <div style="display: flex; flex-wrap: wrap; gap: 20px; margin: 20px 0;">
                <div style="flex: 1 1 200px;">
                    <label style="display: block; font-weight: 600;">Current stock price ($)</label>
                    <input type="number" id="currentStockPrice" class="cat-input" value="100.00" min="0.01" step="0.01">
                </div>
                <div style="flex: 1 1 200px;">
                    <label style="display: block; font-weight: 600;">Order type</label>
                    <select id="orderTypeSelect" class="cat-input">
                        <option value="market">Market order (buy)</option>
                        <option value="limit">Limit order (buy)</option>
                        <option value="stop">Stop order (sell stop-loss)</option>
                    </select>
                </div>
                <div style="flex: 1 1 200px;" id="limitPriceField">
                    <label style="display: block; font-weight: 600;">Limit price ($)</label>
                    <input type="number" id="limitPrice" class="cat-input" value="95.00" min="0.01" step="0.01">
                </div>
                <div style="flex: 1 1 200px;" id="stopPriceField">
                    <label style="display: block; font-weight: 600;">Stop price ($)</label>
                    <input type="number" id="stopPrice" class="cat-input" value="90.00" min="0.01" step="0.01">
                </div>
            </div>

            <div style="margin-top: 20px;">
                <button id="simulateOrder" class="btn-outline">Simulate Order</button>
            </div>

            <div id="orderResult" style="margin-top: 25px; padding: 20px; background: var(--light-color); border-radius: 12px;">
                Configure an order and click simulate.
            </div>

            <p class="pro-tip" style="margin-top: 15px; background-color: #e6f7f0; border-left-color: var(--stocks-accent);">
                <i class="fas fa-lightbulb"></i> This simulator simplifies market behavior. In reality, order execution depends on liquidity, bid‑ask spread, and other factors.
            </p>
        </div>

        <!-- quiz section (conditional) -->
        {% if app.user and quiz is defined and quiz %}
            {# Logged in user – quiz already taken #}
            <div class="quiz-container animate">
                <h3 style="color:white; margin-top: 0;">🧠 You've already taken this quiz</h3>
                <p style="color: #e2e8f0; font-size: 1.2rem;">
                    Your score: <strong>{{ quiz.quizzScore }}%</strong>
                </p>
                <p style="color: #cbd5e0;">
                    You can retake the quiz to improve your score. Click the button below to reset it.
                </p>
                <div class="quiz-actions">
                    <a href="{{ path('app_page_show', { journey: 'stock', slug: 'placing-your-first-trade', retake: 1 }) }}"
                       class="btn"
                       style="background-color: #0e9f6e; color: white; text-decoration: none;">
                        Retake Quiz
                    </a>
                </div>
            </div>
        {% else %}
            {# Show quiz (interactivity blocked by JS if not logged in) #}
            <div class="quiz-container animate" data-page-id="{{ page.id }}">
                <h3 style="color:white; margin-top: 0;">📝 Test your knowledge: Market vs. Limit Orders</h3>

                <div class="quiz-question">1. Which order type guarantees execution but not price?</div>
                <div class="quiz-options" data-question="1">
                    <div class="quiz-option" data-answer="correct">Market order</div>
                    <div class="quiz-option" data-answer="wrong">Limit order</div>
                    <div class="quiz-option" data-answer="wrong">Stop order</div>
                    <div class="quiz-option" data-answer="wrong">Stop-limit order</div>
                </div>

                <div class="quiz-question">2. You want to buy a stock only if it drops to $50. What order do you use?</div>
                <div class="quiz-options" data-question="2">
                    <div class="quiz-option" data-answer="wrong">Market order</div>
                    <div class="quiz-option" data-answer="correct">Limit order</div>
                    <div class="quiz-option" data-answer="wrong">Stop order</div>
                    <div class="quiz-option" data-answer="wrong">Stop-limit order</div>
                </div>

                <div class="quiz-question">3. A stop order becomes a ________ order once the stop price is hit.</div>
                <div class="quiz-options" data-question="3">
                    <div class="quiz-option" data-answer="correct">Market</div>
                    <div class="quiz-option" data-answer="wrong">Limit</div>
                    <div class="quiz-option" data-answer="wrong">Stop-limit</div>
                    <div class="quiz-option" data-answer="wrong">Trailing stop</div>
                </div>

                <div class="quiz-question">4. What is "slippage"?</div>
                <div class="quiz-options" data-question="4">
                    <div class="quiz-option" data-answer="wrong">A fee charged by the broker</div>
                    <div class="quiz-option" data-answer="correct">The difference between expected and actual execution price</div>
                    <div class="quiz-option" data-answer="wrong">A type of order</div>
                    <div class="quiz-option" data-answer="wrong">A market crash</div>
                </div>

                <div class="quiz-question">5. Why might you use a stop-loss order?</div>
                <div class="quiz-options" data-question="5">
                    <div class="quiz-option" data-answer="wrong">To guarantee a profit</div>
                    <div class="quiz-option" data-answer="correct">To limit potential losses on a position</div>
                    <div class="quiz-option" data-answer="wrong">To buy at a lower price</div>
                    <div class="quiz-option" data-answer="wrong">To sell at a higher price</div>
                </div>

                <div class="quiz-actions">
                    <button id="quiz-submit" class="btn">Get score & submit</button>
                </div>
                <div class="quiz-result"></div>
            </div>
        {% endif %}

        <!-- next steps in phase 3 (practical execution) -->
        <section style="margin: 60px 0;">
            <h2 class="section-title" style="text-align: center;">📘 Continue Phase 3: Practical Execution</h2>
            <div class="next-steps">
                <a href="{{ path('app_page_show', { journey: 'stock', slug: 'opening-brokerage-account' }) }}" class="next-card">
                    <i class="fas fa-university"></i>
                    <h3>Opening a Brokerage Account</h3>
                    <p>Step‑by‑step guide to get started.</p>
                </a>
                <a href="{{ path('app_page_show', { journey: 'stock', slug: 'dollar-cost-averaging' }) }}" class="next-card">
                    <i class="fas fa-clock"></i>
                    <h3>Dollar‑Cost Averaging</h3>
                    <p>Invest consistently without stress.</p>
                </a>
                <a href="{{ path('app_page_show', { journey: 'stock', slug: 'how-to-research-a-stock' }) }}" class="next-card">
                    <i class="fas fa-magnifying-glass-chart"></i>
                    <h3>How to Research a Stock</h3>
                    <p>Key metrics for beginners.</p>
                </a>
            </div>
        </section>
    </div>

    <script>
        // Simple toggle for limit/stop fields based on order type selection
        document.addEventListener('DOMContentLoaded', function() {
            const orderType = document.getElementById('orderTypeSelect');
            const limitField = document.getElementById('limitPriceField');
            const stopField = document.getElementById('stopPriceField');

            function toggleFields() {
                const val = orderType.value;
                if (val === 'market') {
                    limitField.style.display = 'none';
                    stopField.style.display = 'none';
                } else if (val === 'limit') {
                    limitField.style.display = 'block';
                    stopField.style.display = 'none';
                } else if (val === 'stop') {
                    limitField.style.display = 'none';
                    stopField.style.display = 'block';
                }
            }
            orderType.addEventListener('change', toggleFields);
            toggleFields(); // initial
        });
    </script>
{% endblock %}
