{# templates/roadmaps/crypto/hardware-wallets.html.twig #}
{% extends 'base-roadmaps.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('crypto_css') }}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('crypto_js') }}
{% endblock %}

{% block body %}
    <div class="container">
        <!-- article hero – crypto style -->
        <div class="article-hero animate">
            <div class="hero-content">
                <div class="hero-icon">
                    <i class="fas fa-hard-drive"></i>
                </div>
                <h1>Hardware Wallets: <span>Your Crypto Fortress</span></h1>
                <p class="hero-description">
                    If you own more crypto than you're willing to lose, you need a hardware wallet. These physical devices keep your private keys offline, safe from hackers, malware, and even the most sophisticated online threats.
                </p>
                <div class="phase-tag">
                    <i class="fas fa-layer-group"></i> Phase 2: Risk Management · 10 min read
                </div>
            </div>
        </div>

        <!-- introduction -->
        <section class="animate">
            <h2 class="section-title">🏰 Why You Need a Hardware Wallet</h2>
            <p style="font-size: 1.2rem; margin-bottom: 20px;">
                A hardware wallet is a small device that generates and stores your private keys offline. When you want to make a transaction, it signs it inside the device – your keys never touch your internet‑connected computer or phone. This makes them immune to remote attacks.
            </p>
            <p style="font-size: 1.1rem; color: var(--gray-color);">
                Think of it as a fortress for your crypto. Even if your computer is infected with malware, your funds remain safe because the private keys never leave the device.
            </p>
        </section>

        <!-- key features grid -->
        <div class="rule-grid animate" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 25px; margin: 40px 0;">
            <div class="rule-item" style="border-top: 5px solid var(--crypto-color); background: var(--card-bg); padding: 20px; border-radius: 18px; box-shadow: var(--shadow);">
                <h3><i class="fas fa-microchip"></i> Offline Storage</h3>
                <p>Private keys are generated and stored on a secure element – never exposed to the internet. This is true cold storage.</p>
            </div>
            <div class="rule-item" style="border-top: 5px solid var(--crypto-color); background: var(--card-bg); padding: 20px; border-radius: 18px; box-shadow: var(--shadow);">
                <h3><i class="fas fa-shield-halved"></i> Tamper‑Proof</h3>
                <p>Most devices have secure chips that resist physical tampering. If someone tries to extract keys, the device self‑destructs (wipes).</p>
            </div>
            <div class="rule-item" style="border-top: 5px solid var(--crypto-color); background: var(--card-bg); padding: 20px; border-radius: 18px; box-shadow: var(--shadow);">
                <h3><i class="fas fa-arrows-rotate"></i> Recovery Phrase</h3>
                <p>A 12‑24 word seed phrase lets you recover your funds if the device is lost or broken. Store it offline, never digitally.</p>
            </div>
            <div class="rule-item" style="border-top: 5px solid var(--crypto-color); background: var(--card-bg); padding: 20px; border-radius: 18px; box-shadow: var(--shadow);">
                <h3><i class="fas fa-coins"></i> Multi‑Asset Support</h3>
                <p>Most hardware wallets support hundreds of cryptocurrencies – Bitcoin, Ethereum, altcoins, and even NFTs.</p>
            </div>
        </div>

        <!-- popular hardware wallets -->
        <div class="card animate">
            <h3 style="font-size: 1.8rem; margin-bottom: 20px;">🔝 Top Hardware Wallets</h3>
            <ul style="font-size: 1.1rem; list-style: none; padding: 0;">
                <li style="margin-bottom: 15px;"><i class="fas fa-check-circle" style="color: var(--crypto-color); margin-right: 10px;"></i> <strong>Ledger Nano X / S:</strong> Bluetooth option, supports many coins, user‑friendly Ledger Live app.</li>
                <li style="margin-bottom: 15px;"><i class="fas fa-check-circle" style="color: var(--crypto-color); margin-right: 10px;"></i> <strong>Trezor Model T / One:</strong> Open‑source, touchscreen on Model T, great security track record.</li>
                <li style="margin-bottom: 15px;"><i class="fas fa-check-circle" style="color: var(--crypto-color); margin-right: 10px;"></i> <strong>KeepKey:</strong> Large screen, integrates with ShapeShift, good for beginners.</li>
                <li style="margin-bottom: 15px;"><i class="fas fa-check-circle" style="color: var(--crypto-color); margin-right: 10px;"></i> <strong>Coldcard:</strong> Bitcoin‑only, ultra‑secure, for advanced users who want maximum control.</li>
            </ul>
            <div style="background: #e6f7f2; padding: 20px; border-radius: 16px; margin-top: 20px;">
                <p><i class="fas fa-lightbulb" style="color: var(--crypto-color); margin-right: 10px;"></i> <strong>Buy directly from the manufacturer!</strong> Never buy a hardware wallet from eBay or third‑party sellers – they could be tampered with.</p>
            </div>
        </div>

        <!-- INTERACTIVE TOOL: Hardware Wallet Setup Simulator -->
        <div class="card animate" style="margin: 40px 0;" id="hardware-simulator">
            <h3><i class="fas fa-wrench"></i> Hardware Wallet Setup Simulator</h3>
            <p>Click each step to see what happens during a real hardware wallet setup. This will prepare you for when you get your own device.</p>

            <div style="display: flex; flex-wrap: wrap; gap: 20px; margin: 30px 0; justify-content: center;">
                <button id="step1Btn" class="btn-outline" style="min-width: 180px;">1️⃣ Initialize Device</button>
                <button id="step2Btn" class="btn-outline" style="min-width: 180px;">2️⃣ Write Down Seed</button>
                <button id="step3Btn" class="btn-outline" style="min-width: 180px;">3️⃣ Set PIN</button>
                <button id="step4Btn" class="btn-outline" style="min-width: 180px;">4️⃣ Install Apps & Receive</button>
            </div>

            <div id="setupResult" style="background: #f0f4f8; border-radius: 16px; padding: 25px; min-height: 100px; border-left: 6px solid var(--crypto-color);">
                <i class="fas fa-arrow-left"></i> Click any step above to see details.
            </div>
            <p style="font-style: italic; color: var(--gray-color); margin-top: 20px;">💡 In a real setup, follow the manufacturer's instructions carefully. Never take photos of your seed phrase.</p>
        </div>

        <!-- Quiz section -->
        {% if app.user and quiz is defined and quiz %}
            <div class="quiz-container animate">
                <h3 style="color:white; margin-top: 0;">🧠 You've already taken this quiz</h3>
                <p style="color: #e2e8f0; font-size: 1.2rem;">
                    Your score: <strong>{{ quiz.quizzScore }}%</strong>
                </p>
                <p style="color: #cbd5e0;">
                    You can retake the quiz to improve your score. Click the button below to reset it.
                </p>
                <div class="quiz-actions">
                    <a href="{{ path('app_page_show', { journey: page.journey.name, slug: slug, retake: 1 }) }}"
                       class="btn"
                       style="background-color: #ff6b35; color: white; text-decoration: none;">
                        Retake Quiz
                    </a>
                </div>
            </div>
        {% else %}
            <div class="quiz-container animate" data-page-id="{{ page.id }}">
                <h3 style="color:white; margin-top: 0;">📝 Test your knowledge: Hardware Wallets</h3>

                <div class="quiz-question">1. What is the main purpose of a hardware wallet?</div>
                <div class="quiz-options" data-question="1">
                    <div class="quiz-option" data-answer="wrong">To mine cryptocurrency</div>
                    <div class="quiz-option" data-answer="wrong">To trade crypto faster</div>
                    <div class="quiz-option" data-answer="correct">To store private keys offline, protecting them from online threats</div>
                    <div class="quiz-option" data-answer="wrong">To exchange one crypto for another</div>
                </div>

                <div class="quiz-question">2. What is a seed phrase used for?</div>
                <div class="quiz-options" data-question="2">
                    <div class="quiz-option" data-answer="wrong">To log into your wallet app</div>
                    <div class="quiz-option" data-answer="wrong">To encrypt transactions</div>
                    <div class="quiz-option" data-answer="correct">To recover your funds if the device is lost or damaged</div>
                    <div class="quiz-option" data-answer="wrong">To generate new addresses</div>
                </div>

                <div class="quiz-question">3. Which of the following is a SAFE way to store your seed phrase?</div>
                <div class="quiz-options" data-question="3">
                    <div class="quiz-option" data-answer="wrong">Take a photo and store it in the cloud</div>
                    <div class="quiz-option" data-answer="wrong">Save it in a password manager</div>
                    <div class="quiz-option" data-answer="correct">Write it on paper and keep it in a fireproof safe</div>
                    <div class="quiz-option" data-answer="wrong">Send it to yourself in an email</div>
                </div>

                <div class="quiz-question">4. Why should you buy a hardware wallet directly from the manufacturer?</div>
                <div class="quiz-options" data-question="4">
                    <div class="quiz-option" data-answer="wrong">It's usually cheaper</div>
                    <div class="quiz-option" data-answer="correct">To avoid tampered devices that could compromise your keys</div>
                    <div class="quiz-option" data-answer="wrong">Faster shipping</div>
                    <div class="quiz-option" data-answer="wrong">They include free crypto</div>
                </div>

                <div class="quiz-question">5. What happens if your hardware wallet is lost or destroyed?</div>
                <div class="quiz-options" data-question="5">
                    <div class="quiz-option" data-answer="wrong">Your crypto is lost forever</div>
                    <div class="quiz-option" data-answer="correct">You can restore your funds using your seed phrase on a new device</div>
                    <div class="quiz-option" data-answer="wrong">The manufacturer can refund you</div>
                    <div class="quiz-option" data-answer="wrong">You need to contact customer support to recover</div>
                </div>

                <div class="quiz-actions">
                    <button id="quiz-submit" class="btn">Get score & submit</button>
                </div>
                <div class="quiz-result"></div>
            </div>
        {% endif %}

        <!-- next steps in phase 2 (risk management) -->
        <section style="margin: 60px 0;">
            <h2 class="section-title" style="text-align: center;">📘 Continue strengthening your defenses</h2>
            <div class="next-steps">
                <a href="{{ url('app_page_show', { journey: 'crypto', slug: 'portfolio-allocation' }) }}" class="next-card">
                    <i class="fas fa-scale-balanced"></i>
                    <h3>Portfolio Allocation</h3>
                    <p style="color: var(--gray-color);">How much crypto is too much?</p>
                </a>
                <a href="{{ url('app_page_show', { journey: 'crypto', slug: 'understanding-crypto-volatility' }) }}" class="next-card">
                    <i class="fas fa-chart-line"></i>
                    <h3>Volatility & Emotions</h3>
                    <p style="color: var(--gray-color);">Master your psychology during market swings.</p>
                </a>
                <a href="{{ url('app_page_show', { journey: 'crypto', slug: 'common-crypto-scams' }) }}" class="next-card">
                    <i class="fas fa-skull-crosswind"></i>
                    <h3>Common Crypto Scams</h3>
                    <p style="color: var(--gray-color);">Learn to spot red flags and avoid becoming a victim.</p>
                </a>
            </div>
        </section>
    </div>
{% endblock %}
