{# templates/roadmaps/crypto/crypto-investing-journey.html.twig #}
{% extends 'base-roadmaps.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('crypto_css') }}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('crypto_js') }}
{% endblock %}

{% block body %}
    <div class="container">
        <!-- hero section specific for crypto investing -->
        <div class="journey-hero animate">
            <div class="hero-content">
                <div class="journey-icon">
                    <i class="fas fa-coins"></i>
                </div>
                <h1>Crypto Investing <span>Journey</span></h1>
                <p class="hero-description">
                    Enter the world of digital assets safely. This four‑phase roadmap teaches you self‑custody,
                    security fundamentals, and how to avoid scams – before you invest your first dollar.
                </p>
            </div>
        </div>

        <!-- intro text: how our roadmaps work (crypto version) -->
        <div style="text-align: center; margin: 40px 0 20px;" class="animate">
            <h2 class="section-title">🔐 Your 4‑phase roadmap</h2>
            <p class="section-subtitle">
                Each phase follows the <strong>Foundation → Risk → Execution → Skill Building</strong> structure.
                Complete the articles in order or jump to what you need most. Security is the first lesson.
            </p>
        </div>

        <!-- ===== PHASE 1 – FOUNDATION FIRST ===== -->
        <div class="phase-wrapper animate">
            <div class="phase-title">
                <span class="phase-number">1</span>
                <span>Foundation First · Understand the basics</span>
            </div>
            <div class="article-grid">
                <div class="article-card">
                    <div class="article-icon"><i class="fab fa-bitcoin"></i></div>
                    <h3>What Is Bitcoin & Why Does It Matter?</h3>
                    <p class="article-brief">Discover the origins of Bitcoin, how it works as a decentralised currency, and why it’s called digital gold. No technical jargon.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 10 min read</span>
                        <a href="{{ url('app_page_show', { journey: 'crypto', slug: 'what-is-bitcoin' }) }}" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-link"></i></div>
                    <h3>Blockchain Basics: The Technology Behind Crypto</h3>
                    <p class="article-brief">Learn what a blockchain is, how transactions are verified, and why this technology is considered secure and transparent.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 12 min read</span>
                        <a href="{{ url('app_page_show', { journey: 'crypto', slug: 'blockchain-basics' }) }}" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-wallet"></i></div>
                    <h3>Crypto Wallets: Custodial vs. Self‑Custody</h3>
                    <p class="article-brief">Understand the difference between leaving coins on an exchange and holding your own private keys. The foundation of security.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 9 min read</span>
                        <a href="{{ url('app_page_show', { journey: 'crypto', slug: 'crypto-wallets' }) }}" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-store"></i></div>
                    <h3>How Crypto Exchanges Work (And How to Choose)</h3>
                    <p class="article-brief">A beginner’s guide to centralised exchanges: fees, security features, and what to look for when picking a platform.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 8 min read</span>
                        <a href="{{ url('app_page_show', { journey: 'crypto', slug: 'how-crypto-exchanges-work' }) }}" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
            </div>
        </div>

        <!-- ===== PHASE 2 – RISK MANAGEMENT ===== -->
        <div class="phase-wrapper animate">
            <div class="phase-title">
                <span class="phase-number">2</span>
                <span>Risk Management · Protect your assets</span>
            </div>
            <div class="article-grid">
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-chart-line"></i></div>
                    <h3>Understanding Crypto Volatility & Your Emotions</h3>
                    <p class="article-brief">Why prices swing wildly and how to prepare yourself mentally. Strategies to avoid panic selling or FOMO buying.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 11 min read</span>
                        <a href="{{ url('app_page_show', { journey: 'crypto', slug: 'understanding-crypto-volatility' }) }}" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-skull-crosswind"></i></div>
                    <h3>Common Crypto Scams & How to Spot Them</h3>
                    <p class="article-brief">From fake giveaways to phishing websites – learn the red flags so you never become a victim.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 14 min read</span>
                        <a href="{{ url('app_page_show', { journey: 'crypto', slug: 'common-crypto-scams' }) }}" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-hard-drive"></i></div>
                    <h3>Hardware Wallets: Your Crypto Fortress</h3>
                    <p class="article-brief">When and how to move from software wallets to hardware wallets. Step‑by‑step setup guide for Ledger/Trezor.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 10 min read</span>
                        <a href="{{ url('app_page_show', { journey: 'crypto', slug: 'hardware-wallets' }) }}" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-scale-balanced"></i></div>
                    <h3>Portfolio Allocation: How Much Crypto Is Too Much?</h3>
                    <p class="article-brief">Experts weigh in on sensible crypto allocations. Avoid putting your whole financial future at risk.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 7 min read</span>
                        <a href="{{ url('app_page_show', { journey: 'crypto', slug: 'portfolio-allocation' }) }}" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
            </div>
        </div>

        <!-- ===== PHASE 3 – PRACTICAL EXECUTION ===== -->
        <div class="phase-wrapper animate">
            <div class="phase-title">
                <span class="phase-number">3</span>
                <span>Practical Execution · Make your first moves</span>
            </div>
            <div class="article-grid">
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-user-plus"></i></div>
                    <h3>Opening Your First Exchange Account</h3>
                    <p class="article-brief">Walk through identity verification, setting up 2FA, and depositing fiat currency. Screenshots included.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 12 min read</span>
                        <a href="{{ url('app_page_show', { journey: 'crypto', slug: 'opening-first-exchange-account' }) }}" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-cart-shopping"></i></div>
                    <h3>Your First Crypto Purchase (Without the Fear)</h3>
                    <p class="article-brief">How to buy Bitcoin or Ethereum safely using a market order. Learn about fees and confirmation times.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 8 min read</span>
                        <a href="{{ url('app_page_show', { journey: 'crypto', slug: 'your-first-crypto-purchase' }) }}" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-right-left"></i></div>
                    <h3>Moving Crypto to Your Own Wallet</h3>
                    <p class="article-brief">Step‑by‑step guide to transferring coins off the exchange into a software wallet you control.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 10 min read</span>
                        <a href="{{ url('app_page_show', { journey: 'crypto', slug: 'moving-crypto-to-wallet' }) }}" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-receipt"></i></div>
                    <h3>Tracking Your Trades for Taxes</h3>
                    <p class="article-brief">Simple methods to record buys, sells, and swaps – because tax authorities are watching crypto.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 9 min read</span>
                        <a href="{{ url('app_page_show', { journey: 'crypto', slug: 'tracking-trades-taxes' }) }}" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
            </div>
        </div>

        <!-- ===== PHASE 4 – SKILL BUILDING ===== -->
        <div class="phase-wrapper animate">
            <div class="phase-title">
                <span class="phase-number">4</span>
                <span>Skill Building · Go beyond the basics</span>
            </div>
            <div class="article-grid">
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-chart-simple"></i></div>
                    <h3>Introduction to DeFi (Decentralised Finance)</h3>
                    <p class="article-brief">What are dApps, lending pools, and decentralised exchanges? A beginner’s tour of the DeFi landscape.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 13 min read</span>
                        <a href="{{ url('app_page_show', { journey: 'crypto', slug: 'introduction-to-defi' }) }}" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-seedling"></i></div>
                    <h3>Staking & Yield Farming Explained</h3>
                    <p class="article-brief">How to earn passive income with your crypto – and the risks that come with it. Plain English breakdown.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 11 min read</span>
                        <a href="{{ url('app_page_show', { journey: 'crypto', slug: 'staking-yield-farming' }) }}" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-image"></i></div>
                    <h3>NFTs: Hype or Real Utility?</h3>
                    <p class="article-brief">Understand what non‑fungible tokens are, how they’re used, and whether they belong in your portfolio.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 10 min read</span>
                        <a href="{{ url('app_page_show', { journey: 'crypto', slug: 'nfts-hype-or-utility' }) }}" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-shield-halved"></i></div>
                    <h3>Advanced Security: Multi‑Sig & Seed Phrase Backup</h3>
                    <p class="article-brief">For larger holdings: how to use multi‑signature wallets and properly store your seed phrase offline.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 9 min read</span>
                        <a href="{{ url('app_page_show', { journey: 'crypto', slug: 'advanced-security' }) }}" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
            </div>
        </div>

        <!-- call to action – start journey / community -->
        <div class="journey-cta animate">
            <h2>Ready to invest safely in crypto?</h2>
            <p style="font-size: 1.2rem; color: #2d3748; margin-bottom: 10px;">Start with phase 1 – no credit card, just clear, secure steps.</p>
            <a href="{{ url('app_page_show', { journey: 'crypto', slug: 'what-is-bitcoin' }) }}" class="cta-button"><i class="fas fa-road"></i> Begin the journey now</a>
            <p style="margin-top: 25px; color: #718096;"><i class="fas fa-users"></i> 13,000+ members started here</p>
        </div>
    </div>
{% endblock %}
