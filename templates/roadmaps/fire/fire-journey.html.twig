{# templates/roadmaps/fire/fire-journey.html.twig #}
{% extends 'base-roadmaps.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('fire_css') }}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('fire_js') }}
{% endblock %}

{% block body %}
    <div class="container">
        <!-- hero section specific for FIRE -->
        <div class="journey-hero animate">
            <div class="hero-content">
                <div class="journey-icon">
                    <i class="fas fa-fire"></i>
                </div>
                <h1>Financial Independence <span>FIRE</span></h1>
                <p class="hero-description">
                    Design your freedom number. A practical, non‑extreme path to FI — from your first savings rate to living off your portfolio.
                </p>
            </div>
        </div>

        <!-- intro text: how our roadmaps work (FIRE version) -->
        <div style="text-align: center; margin: 40px 0 20px;" class="animate">
            <h2 class="section-title">🔥 Your 4‑phase FIRE roadmap</h2>
            <p class="section-subtitle">
                Each phase follows the <strong>Foundation → Risk → Execution → Skill Building</strong> structure.
                Go step by step or jump to what you need.
            </p>
        </div>

        <!-- ===== PHASE 1 – FOUNDATION FIRST ===== -->
        <div class="phase-wrapper animate">
            <div class="phase-title">
                <span class="phase-number">1</span>
                <span>Foundation First · The core math of FIRE</span>
            </div>
            <div class="article-grid">
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-calculator"></i></div>
                    <h3>What is FIRE? The Three Pillars: FI, RE, and Your Number</h3>
                    <p class="article-brief">Understand financial independence vs. early retirement, and why your “enough number” is the starting point.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 9 min read</span>
                        <a href="#" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-percent"></i></div>
                    <h3>The Shockingly Simple Math Behind Early Retirement</h3>
                    <p class="article-brief">How your savings rate determines your timeline – the famous table that connects saving 10% vs. 70%.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 8 min read</span>
                        <a href="#" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-chart-line"></i></div>
                    <h3>Calculating Your FI Number: The 4% Rule and Beyond</h3>
                    <p class="article-brief">Learn the classic 25x rule, how it was built, and when you might need a more conservative approach.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 10 min read</span>
                        <a href="#" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-receipt"></i></div>
                    <h3>Your First Step: Track Expenses to Find Your Savings Rate</h3>
                    <p class="article-brief">Actionable guide to categorise spending, calculate your savings rate, and set a baseline for FI.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 7 min read</span>
                        <a href="#" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
            </div>
        </div>

        <!-- ===== PHASE 2 – RISK MANAGEMENT ===== -->
        <div class="phase-wrapper animate">
            <div class="phase-title">
                <span class="phase-number">2</span>
                <span>Risk Management · Protect your FIRE plan</span>
            </div>
            <div class="article-grid">
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-shield-alt"></i></div>
                    <h3>Building a Buffer: Emergency Funds for the FIRE‑Seeker</h3>
                    <p class="article-brief">Why a cash cushion matters even when you're investing aggressively, and how much is enough.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 7 min read</span>
                        <a href="#" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-file-medical-alt"></i></div>
                    <h3>Insurance Essentials: What You Need (and Don't) on the Path to FI</h3>
                    <p class="article-brief">Health, disability, life, and umbrella insurance – cover the big risks without wasting money.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 9 min read</span>
                        <a href="#" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-chart-bar"></i></div>
                    <h3>Market Downturns: Sequence of Returns Risk Explained</h3>
                    <p class="article-brief">The biggest threat near retirement – and how to mitigate it with asset allocation and flexible spending.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 10 min read</span>
                        <a href="#" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-coins"></i></div>
                    <h3>Protecting Against Inflation: Tips, I‑Bonds, and Equities</h3>
                    <p class="article-brief">Real return assets that keep your purchasing power intact during a long retirement.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 8 min read</span>
                        <a href="#" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
            </div>
        </div>

        <!-- ===== PHASE 3 – PRACTICAL EXECUTION ===== -->
        <div class="phase-wrapper animate">
            <div class="phase-title">
                <span class="phase-number">3</span>
                <span>Practical Execution · Take action toward FI</span>
            </div>
            <div class="article-grid">
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-briefcase"></i></div>
                    <h3>Maximizing Income: Side Hustles, Negotiating Raises, and Career Moves</h3>
                    <p class="article-brief">Practical ways to increase your savings rate by earning more – without burning out.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 9 min read</span>
                        <a href="#" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-landmark"></i></div>
                    <h3>Tax‑Efficient Investing: Max 401(k), IRA, and Taxable Accounts</h3>
                    <p class="article-brief">Order of operations for FIRE investors – how to use traditional, Roth, and brokerage accounts.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 11 min read</span>
                        <a href="#" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-wallet"></i></div>
                    <h3>Cutting Costs Without Feeling Deprived: The FIRE Mindset</h3>
                    <p class="article-brief">Focus on spending on what matters and cutting mindless expenses – joy‑based frugality.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 8 min read</span>
                        <a href="#" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-chart-pie"></i></div>
                    <h3>Tracking Your Net Worth: Tools and Habits for Progress</h3>
                    <p class="article-brief">Simple spreadsheets or apps to monitor your FI journey and stay motivated.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 6 min read</span>
                        <a href="#" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
            </div>
        </div>

        <!-- ===== PHASE 4 – SKILL BUILDING ===== -->
        <div class="phase-wrapper animate">
            <div class="phase-title">
                <span class="phase-number">4</span>
                <span>Skill Building · Master the FIRE lifestyle</span>
            </div>
            <div class="article-grid">
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-umbrella-beach"></i></div>
                    <h3>The Withdrawal Phase: How to Live Off Your Portfolio</h3>
                    <p class="article-brief">From accumulation to retirement – strategies like the bucket approach and variable withdrawal rates.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 10 min read</span>
                        <a href="#" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-leaf"></i></div>
                    <h3>Coast FIRE and Barista FIRE: Flexible Paths to Independence</h3>
                    <p class="article-brief">Less extreme versions of FI that let you downshift earlier – definitions and how to calculate them.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 8 min read</span>
                        <a href="#" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-globe-americas"></i></div>
                    <h3>Geographic Arbitrage: Living Well Anywhere</h3>
                    <p class="article-brief">How relocating to a lower‑cost area (or country) can shorten your FI timeline and improve quality of life.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 9 min read</span>
                        <a href="#" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-brain"></i></div>
                    <h3>FIRE Community and Mindset: Staying the Course</h3>
                    <p class="article-brief">Dealing with skepticism, finding like‑minded people, and keeping the long view for decades.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 7 min read</span>
                        <a href="#" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
            </div>
        </div>

        <!-- call to action – start FIRE journey -->
        <div class="journey-cta animate">
            <h2>Ready to design your freedom number?</h2>
            <p style="font-size: 1.2rem; color: #2d3748; margin-bottom: 10px;">Start with phase 1 – no jargon, just a clear path to FI.</p>
            <a href="#" class="cta-button"><i class="fas fa-road"></i> Begin the FIRE journey</a>
            <p style="margin-top: 25px; color: #718096;"><i class="fas fa-users"></i> Join 6,000+ members on the FI path</p>
        </div>
    </div>
{% endblock %}
