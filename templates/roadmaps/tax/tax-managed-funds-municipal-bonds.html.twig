{# templates/roadmaps/tax/tax-managed-funds-municipal-bonds.html.twig #}
{% extends 'base-roadmaps.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('tax_css') }}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('tax_js') }}
{% endblock %}

{% block body %}
    <div class="container">
        <!-- article hero – tax style -->
        <div class="article-hero animate" style="background: linear-gradient(135deg, #1e2b37 0%, #2c3e50 100%);">
            <div class="hero-content">
                <div class="hero-icon" style="background-color: var(--tax-smart-color);">
                    <i class="fas fa-city"></i>
                </div>
                <h1>Advanced: Tax‑Managed Funds <span>& Municipal Bonds</span></h1>
                <p class="hero-description">
                    For investors in higher tax brackets, tax‑managed funds and municipal bonds offer powerful ways to reduce taxable income.
                    Learn how these strategies work, when they make sense, and how to incorporate them into your portfolio.
                </p>
                <div class="phase-tag" style="background-color: rgba(44,62,80,0.2); color: #b0c4de;">
                    <i class="fas fa-layer-group"></i> Phase 4: Skill Building · 9 min read
                </div>
            </div>
        </div>

        <!-- introduction -->
        <section class="animate">
            <h2 class="section-title">📖 Beyond Traditional Investing</h2>
            <p style="font-size: 1.2rem; margin-bottom: 20px;">
                As your wealth grows, so does your tax bill. High‑income investors need sophisticated tools to preserve after‑tax returns.
                Tax‑managed funds minimize annual capital gains distributions, while municipal bonds offer federally tax‑free income.
                This article explores when and how to use these advanced strategies.
            </p>
        </section>

        <!-- key takeaways in rule‑grid style -->
        <div class="rule-grid animate">
            <div class="rule-item">
                <h4><i class="fas fa-chart-line"></i> Tax‑Managed Funds</h4>
                <p>Actively managed to minimize capital gains distributions. Use tax‑loss harvesting and low‑turnover strategies to defer taxes. Best for taxable accounts.</p>
            </div>
            <div class="rule-item">
                <h4><i class="fas fa-hand-holding-usd"></i> Municipal Bonds</h4>
                <p>Interest is exempt from federal income tax (and often state tax if you buy bonds from your state). Ideal for high‑bracket investors in taxable accounts.</p>
            </div>
            <div class="rule-item">
                <h4><i class="fas fa-chart-simple"></i> Tax‑Equivalent Yield</h4>
                <p>Compare muni yields to taxable bonds using: Tax‑Equivalent Yield = Tax‑Free Yield ÷ (1 – Marginal Tax Rate).</p>
            </div>
        </div>

        <!-- interactive tool: Tax‑Equivalent Yield & Fund Comparison -->
        <div class="card animate" style="margin: 40px 0;" id="tax-managed-tool">
            <h3><i class="fas fa-chart-pie"></i> Interactive: Compare After‑Tax Returns</h3>
            <p>See whether municipal bonds or tax‑managed funds outperform traditional investments after taxes.</p>

            <div style="display: flex; flex-wrap: wrap; gap: 20px; margin: 20px 0;">
                <div style="flex: 1 1 250px;">
                    <label>Your Marginal Federal Tax Rate</label>
                    <input type="range" id="taxRateMuni" min="0" max="37" value="32" step="1" class="cat-input" style="width:100%;">
                    <span id="taxRateMuniVal">32</span>%
                </div>
                <div style="flex: 1 1 250px;">
                    <label>State Tax Rate (if applicable)</label>
                    <input type="range" id="stateTaxRate" min="0" max="13" value="5" step="1" class="cat-input" style="width:100%;">
                    <span id="stateTaxRateVal">5</span>%
                </div>
            </div>

            <div style="margin-bottom: 25px;">
                <h4>Option 1: Taxable Bond Fund</h4>
                <div style="display: flex; flex-wrap: wrap; gap: 20px;">
                    <div style="flex: 1 1 200px;">
                        <label>Yield (%)</label>
                        <input type="number" id="taxableYield" class="cat-input" value="5.0" step="0.1" style="width:100%;">
                    </div>
                </div>
                <h4 style="margin-top: 15px;">Option 2: Municipal Bond Fund (Tax‑Exempt)</h4>
                <div style="display: flex; flex-wrap: wrap; gap: 20px;">
                    <div style="flex: 1 1 200px;">
                        <label>Yield (%)</label>
                        <input type="number" id="muniYield" class="cat-input" value="3.5" step="0.1" style="width:100%;">
                    </div>
                </div>
                <h4 style="margin-top: 15px;">Option 3: Tax‑Managed Stock Fund</h4>
                <div style="display: flex; flex-wrap: wrap; gap: 20px;">
                    <div style="flex: 1 1 200px;">
                        <label>Expected Return (%)</label>
                        <input type="number" id="managedReturn" class="cat-input" value="7.0" step="0.5" style="width:100%;">
                    </div>
                    <div style="flex: 1 1 200px;">
                        <label>Annual Tax Drag (%) (compared to regular fund)</label>
                        <input type="number" id="taxDrag" class="cat-input" value="1.0" step="0.1" style="width:100%;">
                    </div>
                </div>
            </div>

            <div style="margin-top: 20px;">
                <button id="compareTaxManaged" class="btn-outline">Compare After‑Tax Returns</button>
            </div>

            <div id="taxManagedResult" style="margin-top: 25px; padding: 20px; background: var(--light-color); border-radius: 12px;">
                <p>Enter your details and click the button to see results.</p>
            </div>

            <p class="pro-tip" style="margin-top: 15px; background-color: #eef2f5; border-left-color: var(--tax-smart-color);">
                <i class="fas fa-lightbulb"></i> Tax‑managed funds aim to keep tax drag low by minimizing realized gains. The comparison assumes you hold these funds in a taxable account. For high earners, muni bonds often provide better after‑tax income than taxable bonds.
            </p>
        </div>

        <!-- quiz section (conditional) -->
        {% if app.user and quiz is defined and quiz %}
            <div class="quiz-container animate" style="background: #1e1a3a;">
                <h3 style="color:white; margin-top: 0;">🧠 You've already taken this quiz</h3>
                <p style="color: #e2e8f0; font-size: 1.2rem;">
                    Your score: <strong>{{ quiz.quizzScore }}%</strong>
                </p>
                <p style="color: #cbd5e0;">
                    You can retake the quiz to improve your score. Click the button below to reset it.
                </p>
                <div class="quiz-actions">
                    <a href="{{ path('app_page_show', { journey: 'tax', slug: 'tax-managed-funds-municipal-bonds', retake: 1 }) }}"
                       class="btn"
                       style="background-color: #2c3e50; color: white; text-decoration: none;">
                        Retake Quiz
                    </a>
                </div>
            </div>
        {% else %}
            <div class="quiz-container animate" data-page-id="{{ page.id }}" style="background: #1e2b37;">
                <h3 style="color:white; margin-top: 0;">📝 Test your knowledge: Tax‑Managed Funds & Municipal Bonds</h3>

                <div class="quiz-question">1. What is the primary benefit of a municipal bond for a high‑income investor?</div>
                <div class="quiz-options" data-question="1">
                    <div class="quiz-option" data-answer="correct">Interest is exempt from federal income tax</div>
                    <div class="quiz-option" data-answer="wrong">Higher yields than corporate bonds</div>
                    <div class="quiz-option" data-answer="wrong">No risk of default</div>
                    <div class="quiz-option" data-answer="wrong">Guaranteed returns</div>
                </div>

                <div class="quiz-question">2. How do tax‑managed funds typically reduce tax drag?</div>
                <div class="quiz-options" data-question="2">
                    <div class="quiz-option" data-answer="correct">Using low‑turnover strategies and tax‑loss harvesting</div>
                    <div class="quiz-option" data-answer="wrong">Investing only in tax‑free bonds</div>
                    <div class="quiz-option" data-answer="wrong">Holding only cash</div>
                    <div class="quiz-option" data-answer="wrong">Avoiding all dividends</div>
                </div>

                <div class="quiz-question">3. The tax‑equivalent yield formula is: Tax‑Free Yield ÷ (1 – ________)</div>
                <div class="quiz-options" data-question="3">
                    <div class="quiz-option" data-answer="correct">Marginal tax rate</div>
                    <div class="quiz-option" data-answer="wrong">Inflation rate</div>
                    <div class="quiz-option" data-answer="wrong">Dividend yield</div>
                    <div class="quiz-option" data-answer="wrong">Capital gains rate</div>
                </div>

                <div class="quiz-question">4. Why might a tax‑managed fund be held in a taxable account rather than an IRA?</div>
                <div class="quiz-options" data-question="4">
                    <div class="quiz-option" data-answer="wrong">It has no tax advantages</div>
                    <div class="quiz-option" data-answer="correct">Its tax efficiency is wasted in a tax‑advantaged account, where taxes are already deferred</div>
                    <div class="quiz-option" data-answer="wrong">IRAs don't allow mutual funds</div>
                    <div class="quiz-option" data-answer="wrong">It's illegal to hold them in IRAs</div>
                </div>

                <div class="quiz-question">5. Which investor would benefit most from municipal bonds?</div>
                <div class="quiz-options" data-question="5">
                    <div class="quiz-option" data-answer="wrong">Someone in the 10% tax bracket</div>
                    <div class="quiz-option" data-answer="wrong">Someone with no taxable income</div>
                    <div class="quiz-option" data-answer="correct">Someone in the 37% federal tax bracket</div>
                    <div class="quiz-option" data-answer="wrong">A tax‑exempt entity</div>
                </div>

                <div class="quiz-actions">
                    <button id="quiz-submit" class="btn" style="background-color: var(--tax-smart-color);">Get score & submit</button>
                </div>
                <div class="quiz-result"></div>
            </div>
        {% endif %}

        <!-- next steps in phase 4 (Skill Building) – this is the last article, so maybe link to other advanced topics or conclude -->
        <section style="margin: 60px 0;">
            <h2 class="section-title" style="text-align: center;">📘 Continue Your Learning Journey</h2>
            <div class="next-steps">
                <a href="{{ path('app_page_show', { journey: 'tax', slug: 'tax-efficient-withdrawal-strategies-in-retirement' }) }}" class="next-card">
                    <i class="fas fa-umbrella-beach"></i>
                    <h3>Tax‑Efficient Withdrawal Strategies</h3>
                    <p>How to spend your retirement savings smartly.</p>
                </a>
                <a href="{{ path('app_page_show', { journey: 'tax', slug: 'side-hustle-tax-strategies' }) }}" class="next-card">
                    <i class="fas fa-briefcase"></i>
                    <h3>Side Hustle Tax Strategies</h3>
                    <p>Deductions and retirement plans for freelancers.</p>
                </a>
                <a href="{{ path('app_page_show', { journey: 'tax', slug: 'estate-planning-basics' }) }}" class="next-card">
                    <i class="fas fa-tree"></i>
                    <h3>Estate Planning Basics</h3>
                    <p>Step‑up in basis, gift taxes, and inheritance strategies.</p>
                </a>
            </div>
        </section>
    </div>
{% endblock %}
