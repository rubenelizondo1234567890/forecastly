{# templates/roadmaps/tax/estate-planning-basics.html.twig #}
{% extends 'base-roadmaps.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('tax_css') }}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('tax_js') }}
{% endblock %}

{% block body %}
    <div class="container">
        <!-- article hero – tax style -->
        <div class="article-hero animate" style="background: linear-gradient(135deg, #1e2b37 0%, #2c3e50 100%);">
            <div class="hero-content">
                <div class="hero-icon" style="background-color: var(--tax-smart-color);">
                    <i class="fas fa-tree"></i>
                </div>
                <h1>Estate Planning Basics <span>Step‑Up in Basis & Gift Taxes</span></h1>
                <p class="hero-description">
                    Understand how assets transfer at death, the powerful step‑up in basis rule, and strategies for gifting to loved ones.
                    Learn how to minimize taxes for your heirs and make the most of your estate.
                </p>
                <div class="phase-tag" style="background-color: rgba(44,62,80,0.2); color: #b0c4de;">
                    <i class="fas fa-layer-group"></i> Phase 4: Skill Building · 10 min read
                </div>
            </div>
        </div>

        <!-- introduction -->
        <section class="animate">
            <h2 class="section-title">📖 Leave More, Tax Less</h2>
            <p style="font-size: 1.2rem; margin-bottom: 20px;">
                Estate planning isn't just for the wealthy. Whether you're passing on a home, investments, or retirement accounts,
                understanding the tax rules can save your heirs thousands. This guide covers the step‑up in basis (a powerful tax break),
                the gift tax exemption, and strategies to transfer wealth efficiently.
            </p>
        </section>

        <!-- key takeaways in rule‑grid style -->
        <div class="rule-grid animate">
            <div class="rule-item">
                <h4><i class="fas fa-chart-line"></i> Step‑Up in Basis</h4>
                <p>When you inherit an asset, its cost basis is "stepped up" to its fair market value at the date of death. This eliminates capital gains tax on appreciation during the original owner's lifetime.</p>
            </div>
            <div class="rule-item">
                <h4><i class="fas fa-gift"></i> Gift Tax Exemption</h4>
                <p>You can give up to $18,000 per person per year (2024) without filing a gift tax return. Lifetime exemption is $13.61 million (2024). Gifts beyond these may trigger tax, but it's rare.</p>
            </div>
            <div class="rule-item">
                <h4><i class="fas fa-file-signature"></i> Estate Tax</h4>
                <p>The federal estate tax applies only to estates exceeding $13.61 million (2024). Most families don't owe estate tax, but proper planning ensures smooth transfer.</p>
            </div>
        </div>

        <!-- interactive tool: Step‑Up in Basis Calculator -->
        <div class="card animate" style="margin: 40px 0;" id="step-up-basis-tool">
            <h3><i class="fas fa-calculator"></i> Interactive: Step‑Up in Basis Calculator</h3>
            <p>See how the step‑up in basis can save your heirs significant taxes. Compare selling an asset before death vs. after inheritance.</p>

            <div style="display: flex; flex-wrap: wrap; gap: 20px; margin: 20px 0;">
                <div style="flex: 1 1 250px;">
                    <label>Original Purchase Price ($)</label>
                    <input type="number" id="originalCost" class="cat-input" value="50000" step="5000" style="width:100%;">
                </div>
                <div style="flex: 1 1 250px;">
                    <label>Current Market Value ($)</label>
                    <input type="number" id="currentValue" class="cat-input" value="150000" step="5000" style="width:100%;">
                </div>
                <div style="flex: 1 1 250px;">
                    <label>Long‑Term Capital Gains Rate</label>
                    <input type="range" id="ltcgRateEstate" min="0" max="20" value="15" step="1" class="cat-input" style="width:100%;">
                    <span id="ltcgRateEstateVal">15</span>%
                </div>
            </div>

            <div style="margin-top: 20px;">
                <button id="calcStepUpBasis" class="btn-outline">Calculate Tax Difference</button>
            </div>

            <div id="stepUpResult" style="margin-top: 25px; padding: 20px; background: var(--light-color); border-radius: 12px;">
                <p>Enter the numbers and click the button to see results.</p>
            </div>

            <p class="pro-tip" style="margin-top: 15px; background-color: #eef2f5; border-left-color: var(--tax-smart-color);">
                <i class="fas fa-lightbulb"></i> This tool demonstrates the tax advantage of the step‑up in basis. In reality, the asset's basis is stepped up to fair market value at death, eliminating capital gains tax on pre‑death appreciation.
            </p>
        </div>

        <!-- quiz section (conditional) -->
        {% if app.user and quiz is defined and quiz %}
            <div class="quiz-container animate" style="background: #1e1a3a;">
                <h3 style="color:white; margin-top: 0;">🧠 You've already taken this quiz</h3>
                <p style="color: #e2e8f0; font-size: 1.2rem;">
                    Your score: <strong>{{ quiz.quizzScore }}%</strong>
                </p>
                <p style="color: #cbd5e0;">
                    You can retake the quiz to improve your score. Click the button below to reset it.
                </p>
                <div class="quiz-actions">
                    <a href="{{ path('app_page_show', { journey: 'tax', slug: 'estate-planning-basics', retake: 1 }) }}"
                       class="btn"
                       style="background-color: #2c3e50; color: white; text-decoration: none;">
                        Retake Quiz
                    </a>
                </div>
            </div>
        {% else %}
            <div class="quiz-container animate" data-page-id="{{ page.id }}" style="background: #1e2b37;">
                <h3 style="color:white; margin-top: 0;">📝 Test your knowledge: Estate Planning & Gift Taxes</h3>

                <div class="quiz-question">1. What is the step‑up in basis?</div>
                <div class="quiz-options" data-question="1">
                    <div class="quiz-option" data-answer="correct">The cost basis of inherited assets is adjusted to their fair market value at the date of death</div>
                    <div class="quiz-option" data-answer="wrong">The IRS adds a penalty to inherited assets</div>
                    <div class="quiz-option" data-answer="wrong">You can deduct the full value of an asset from your taxes</div>
                    <div class="quiz-option" data-answer="wrong">Only applies to real estate</div>
                </div>

                <div class="quiz-question">2. For 2024, what is the annual gift tax exclusion amount per person?</div>
                <div class="quiz-options" data-question="2">
                    <div class="quiz-option" data-answer="wrong">$15,000</div>
                    <div class="quiz-option" data-answer="correct">$18,000</div>
                    <div class="quiz-option" data-answer="wrong">$20,000</div>
                    <div class="quiz-option" data-answer="wrong">$10,000</div>
                </div>

                <div class="quiz-question">3. If you sell an appreciated asset before death, what tax do you owe?</div>
                <div class="quiz-options" data-question="3">
                    <div class="quiz-option" data-answer="correct">Capital gains tax on the appreciation</div>
                    <div class="quiz-option" data-answer="wrong">Estate tax on the entire value</div>
                    <div class="quiz-option" data-answer="wrong">No tax</div>
                    <div class="quiz-option" data-answer="wrong">Gift tax</div>
                </div>

                <div class="quiz-question">4. What is the federal estate tax exemption amount for 2024?</div>
                <div class="quiz-options" data-question="4">
                    <div class="quiz-option" data-answer="wrong">$5 million</div>
                    <div class="quiz-option" data-answer="correct">$13.61 million</div>
                    <div class="quiz-option" data-answer="wrong">$1 million</div>
                    <div class="quiz-option" data-answer="wrong">$25 million</div>
                </div>

                <div class="quiz-question">5. Why might you want to gift assets while alive instead of leaving them in your estate?</div>
                <div class="quiz-options" data-question="5">
                    <div class="quiz-option" data-answer="wrong">To avoid the step‑up in basis</div>
                    <div class="quiz-option" data-answer="correct">To reduce the size of your taxable estate and possibly use the annual gift exclusion</div>
                    <div class="quiz-option" data-answer="wrong">Gifting always results in lower taxes</div>
                    <div class="quiz-option" data-answer="wrong">It's required by law</div>
                </div>

                <div class="quiz-actions">
                    <button id="quiz-submit" class="btn" style="background-color: var(--tax-smart-color);">Get score & submit</button>
                </div>
                <div class="quiz-result"></div>
            </div>
        {% endif %}

        <!-- next steps in phase 4 (Skill Building) -->
        <section style="margin: 60px 0;">
            <h2 class="section-title" style="text-align: center;">📘 Continue Phase 4: Skill Building</h2>
            <div class="next-steps">
                <a href="{{ path('app_page_show', { journey: 'tax', slug: 'tax-efficient-withdrawal-strategies-in-retirement' }) }}" class="next-card">
                    <i class="fas fa-umbrella-beach"></i>
                    <h3>Tax‑Efficient Withdrawal Strategies</h3>
                    <p>How to spend your retirement savings smartly.</p>
                </a>
                <a href="{{ path('app_page_show', { journey: 'tax', slug: 'side-hustle-tax-strategies' }) }}" class="next-card">
                    <i class="fas fa-briefcase"></i>
                    <h3>Side Hustle Tax Strategies</h3>
                    <p>Deductions and retirement plans for freelancers.</p>
                </a>
                <a href="{{ path('app_page_show', { journey: 'tax', slug: 'tax-managed-funds-municipal-bonds' }) }}" class="next-card">
                    <i class="fas fa-city"></i>
                    <h3>Tax‑Managed Funds & Municipal Bonds</h3>
                    <p>Advanced strategies to minimize taxable distributions.</p>
                </a>
            </div>
        </section>
    </div>
{% endblock %}
