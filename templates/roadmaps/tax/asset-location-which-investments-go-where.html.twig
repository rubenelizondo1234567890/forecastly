{# templates/roadmaps/tax/asset-location-which-investments-go-where.html.twig #}
{% extends 'base-roadmaps.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('tax_css') }}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('tax_js') }}
{% endblock %}

{% block body %}
    <div class="container">
        <!-- article hero – tax style -->
        <div class="article-hero animate" style="background: linear-gradient(135deg, #1e2b37 0%, #2c3e50 100%);">
            <div class="hero-content">
                <div class="hero-icon" style="background-color: var(--tax-smart-color);">
                    <i class="fas fa-location-dot"></i>
                </div>
                <h1>Asset Location <span>Which Investments Go Where</span></h1>
                <p class="hero-description">
                    Not all accounts are created equal. Learn how to strategically place investments across taxable,
                    tax‑deferred, and tax‑free accounts to maximize after‑tax returns and minimize tax drag.
                </p>
                <div class="phase-tag" style="background-color: rgba(44,62,80,0.2); color: #b0c4de;">
                    <i class="fas fa-layer-group"></i> Phase 2: Risk Management · 10 min read
                </div>
            </div>
        </div>

        <!-- introduction -->
        <section class="animate">
            <h2 class="section-title">📖 The Silent Boost to Your Returns</h2>
            <p style="font-size: 1.2rem; margin-bottom: 20px;">
                Asset location is the art of placing different types of investments in the accounts where they are most tax‑efficient.
                While asset allocation focuses on <em>what</em> you own, asset location focuses on <em>where</em> you own it.
                Done right, it can add 0.5% to 1% or more to your annual after‑tax returns.
            </p>
        </section>

        <!-- key takeaways in rule‑grid style -->
        <div class="rule-grid animate">
            <div class="rule-item">
                <h4><i class="fas fa-university"></i> Taxable Accounts</h4>
                <p>Best for tax‑efficient assets like index ETFs, municipal bonds, and individual stocks held long‑term. Avoid high‑turnover active funds and REITs here.</p>
            </div>
            <div class="rule-item">
                <h4><i class="fas fa-chart-line"></i> Tax‑Deferred Accounts (Traditional IRA/401k)</h4>
                <p>Ideal for assets that generate ordinary income: bonds, REITs, high‑dividend stocks, and active funds. Taxes are deferred until withdrawal.</p>
            </div>
            <div class="rule-item">
                <h4><i class="fas fa-rocket"></i> Tax‑Free Accounts (Roth IRA)</h4>
                <p>Perfect for high‑growth assets you expect to appreciate the most, since all future growth is tax‑free. Also good for tax‑inefficient assets if you have limited space.</p>
            </div>
        </div>

        <!-- interactive tool: Asset Location Optimizer -->
        <div class="card animate" style="margin: 40px 0;" id="asset-location-tool">
            <h3><i class="fas fa-chart-pie"></i> Interactive: Asset Location Optimizer</h3>
            <p>Select an asset type and an account to see the estimated annual tax drag. Drag the sliders to see how placement affects your after‑tax returns.</p>

            <div style="display: flex; flex-wrap: wrap; gap: 20px; margin: 20px 0;">
                <div style="flex: 1 1 250px;">
                    <label>Asset Type</label>
                    <select id="assetType" class="cat-input" style="width:100%;">
                        <option value="bonds">Taxable Bonds (e.g., Corporate Bonds)</option>
                        <option value="highDividend">High‑Dividend Stocks (4% yield)</option>
                        <option value="growth">Growth Stocks (Low dividends)</option>
                        <option value="reit">REITs (Real Estate Investment Trusts)</option>
                        <option value="muni">Municipal Bonds</option>
                    </select>
                </div>
                <div style="flex: 1 1 250px;">
                    <label>Account Type</label>
                    <select id="accountTypeLoc" class="cat-input" style="width:100%;">
                        <option value="taxable">Taxable Brokerage</option>
                        <option value="taxDeferred">Tax‑Deferred (Traditional IRA/401k)</option>
                        <option value="roth">Tax‑Free (Roth IRA)</option>
                    </select>
                </div>
                <div style="flex: 1 1 250px;">
                    <label>Investment Amount ($) <span id="amountLocVal">10,000</span></label>
                    <input type="range" id="amountLoc" min="0" max="100000" value="10000" step="1000" class="cat-input" style="width:100%;">
                </div>
                <div style="flex: 1 1 250px;">
                    <label>Marginal Tax Rate <span id="taxRateLocVal">24</span>%</label>
                    <input type="range" id="taxRateLoc" min="0" max="37" value="24" step="1" class="cat-input" style="width:100%;">
                </div>
            </div>

            <div style="margin-top: 20px;">
                <button id="calcAssetLocation" class="btn-outline">Calculate Tax Impact</button>
            </div>

            <div id="assetLocationResult" style="margin-top: 25px; padding: 20px; background: var(--light-color); border-radius: 12px;">
                <p>Adjust the values and click the button to see results.</p>
            </div>

            <p class="pro-tip" style="margin-top: 15px; background-color: #eef2f5; border-left-color: var(--tax-smart-color);">
                <i class="fas fa-lightbulb"></i> This tool provides a simplified estimate. Actual tax costs depend on investment returns, holding periods, and your specific tax situation.
            </p>
        </div>

        <!-- quiz section (conditional) -->
        {% if app.user and quiz is defined and quiz %}
            <div class="quiz-container animate" style="background: #1e1a3a;">
                <h3 style="color:white; margin-top: 0;">🧠 You've already taken this quiz</h3>
                <p style="color: #e2e8f0; font-size: 1.2rem;">
                    Your score: <strong>{{ quiz.quizzScore }}%</strong>
                </p>
                <p style="color: #cbd5e0;">
                    You can retake the quiz to improve your score. Click the button below to reset it.
                </p>
                <div class="quiz-actions">
                    <a href="{{ path('app_page_show', { journey: 'tax', slug: 'asset-location-which-investments-go-where', retake: 1 }) }}"
                       class="btn"
                       style="background-color: #2c3e50; color: white; text-decoration: none;">
                        Retake Quiz
                    </a>
                </div>
            </div>
        {% else %}
            <div class="quiz-container animate" data-page-id="{{ page.id }}" style="background: #1e2b37;">
                <h3 style="color:white; margin-top: 0;">📝 Test your knowledge: Asset Location</h3>

                <div class="quiz-question">1. Which type of account is generally best for tax‑inefficient assets like REITs?</div>
                <div class="quiz-options" data-question="1">
                    <div class="quiz-option" data-answer="wrong">Taxable brokerage account</div>
                    <div class="quiz-option" data-answer="correct">Tax‑deferred account (Traditional IRA/401k)</div>
                    <div class="quiz-option" data-answer="wrong">Roth IRA</div>
                    <div class="quiz-option" data-answer="wrong">529 plan</div>
                </div>

                <div class="quiz-question">2. What is the primary goal of asset location?</div>
                <div class="quiz-options" data-question="2">
                    <div class="quiz-option" data-answer="wrong">To maximize diversification</div>
                    <div class="quiz-option" data-answer="wrong">To simplify portfolio management</div>
                    <div class="quiz-option" data-answer="correct">To minimize taxes by placing assets in the most tax‑efficient accounts</div>
                    <div class="quiz-option" data-answer="wrong">To avoid capital gains taxes entirely</div>
                </div>

                <div class="quiz-question">3. Which asset is most tax‑efficient in a taxable account?</div>
                <div class="quiz-options" data-question="3">
                    <div class="quiz-option" data-answer="wrong">High‑yield bonds</div>
                    <div class="quiz-option" data-answer="correct">Index ETFs with low turnover</div>
                    <div class="quiz-option" data-answer="wrong">REITs</div>
                    <div class="quiz-option" data-answer="wrong">Actively managed mutual funds</div>
                </div>

                <div class="quiz-question">4. Why might you want to place high‑growth stocks in a Roth IRA?</div>
                <div class="quiz-options" data-question="4">
                    <div class="quiz-option" data-answer="wrong">To deduct the contributions</div>
                    <div class="quiz-option" data-answer="correct">To allow the growth to be tax‑free upon withdrawal</div>
                    <div class="quiz-option" data-answer="wrong">To avoid capital gains taxes on dividends</div>
                    <div class="quiz-option" data-answer="wrong">To increase contribution limits</div>
                </div>

                <div class="quiz-question">5. Municipal bonds are best suited for which type of account?</div>
                <div class="quiz-options" data-question="5">
                    <div class="quiz-option" data-answer="wrong">Tax‑deferred accounts</div>
                    <div class="quiz-option" data-answer="correct">Taxable accounts (since they are already tax‑exempt)</div>
                    <div class="quiz-option" data-answer="wrong">Roth IRAs</div>
                    <div class="quiz-option" data-answer="wrong">Any account, they are always tax‑free</div>
                </div>

                <div class="quiz-actions">
                    <button id="quiz-submit" class="btn" style="background-color: var(--tax-smart-color);">Get score & submit</button>
                </div>
                <div class="quiz-result"></div>
            </div>
        {% endif %}

        <!-- next steps in phase 2 (Risk Management) -->
        <section style="margin: 60px 0;">
            <h2 class="section-title" style="text-align: center;">📘 Continue Phase 2: Risk Management</h2>
            <div class="next-steps">
                <a href="{{ path('app_page_show', { journey: 'tax', slug: 'tax-loss-harvesting' }) }}" class="next-card">
                    <i class="fas fa-leaf"></i>
                    <h3>Tax‑Loss Harvesting</h3>
                    <p>Turn losses into savings – the basics.</p>
                </a>
                <a href="{{ path('app_page_show', { journey: 'tax', slug: 'avoiding-the-wash-sale-rule' }) }}" class="next-card">
                    <i class="fas fa-broom"></i>
                    <h3>Avoiding the Wash Sale Rule</h3>
                    <p>Stay compliant while harvesting losses.</p>
                </a>
                <a href="{{ path('app_page_show', { journey: 'tax', slug: 'tax-implications-of-rebalancing' }) }}" class="next-card">
                    <i class="fas fa-arrows-rotate"></i>
                    <h3>Tax Implications of Rebalancing</h3>
                    <p>Smart tactics to rebalance without triggering unnecessary taxes.</p>
                </a>
            </div>
        </section>
    </div>
{% endblock %}
