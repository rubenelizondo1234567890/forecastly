{# templates/roadmaps/tax/side-hustle-tax-strategies.html.twig #}
{% extends 'base-roadmaps.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('tax_css') }}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('tax_js') }}
{% endblock %}

{% block body %}
    <div class="container">
        <!-- article hero – tax style -->
        <div class="article-hero animate" style="background: linear-gradient(135deg, #1e2b37 0%, #2c3e50 100%);">
            <div class="hero-content">
                <div class="hero-icon" style="background-color: var(--tax-smart-color);">
                    <i class="fas fa-briefcase"></i>
                </div>
                <h1>Side Hustle Tax Strategies <span>Deductions & Retirement</span></h1>
                <p class="hero-description">
                    Turn your side hustle into a tax‑saving machine. Learn which expenses you can deduct, how to handle self‑employment tax,
                    and how to set up retirement accounts that reduce your taxable income while building wealth.
                </p>
                <div class="phase-tag" style="background-color: rgba(44,62,80,0.2); color: #b0c4de;">
                    <i class="fas fa-layer-group"></i> Phase 4: Skill Building · 11 min read
                </div>
            </div>
        </div>

        <!-- introduction -->
        <section class="animate">
            <h2 class="section-title">📖 Your Side Gig, Your Tax Advantage</h2>
            <p style="font-size: 1.2rem; margin-bottom: 20px;">
                More than 40% of Americans have a side hustle. But many miss out on tax deductions that could save thousands.
                Whether you drive for Uber, freelance, or sell crafts online, understanding self‑employment taxes and retirement options can transform your side income into a powerful wealth‑building tool.
            </p>
        </section>

        <!-- key takeaways in rule‑grid style -->
        <div class="rule-grid animate">
            <div class="rule-item">
                <h4><i class="fas fa-receipt"></i> Deductible Expenses</h4>
                <p>Home office, equipment, supplies, software, internet, vehicle mileage, and health insurance premiums are all potentially deductible.</p>
            </div>
            <div class="rule-item">
                <h4><i class="fas fa-chart-line"></i> Self‑Employment Tax</h4>
                <p>You pay both the employee and employer portion of Social Security/Medicare (15.3%). But you can deduct half of it on your return.</p>
            </div>
            <div class="rule-item">
                <h4><i class="fas fa-piggy-bank"></i> Retirement Accounts</h4>
                <p>SEP IRA, Solo 401(k), or SIMPLE IRA let you contribute up to $66,000 (2024) pre‑tax, reducing your taxable income dramatically.</p>
            </div>
        </div>

        <!-- interactive tool: Side Hustle Tax Estimator -->
        <div class="card animate" style="margin: 40px 0;" id="side-hustle-tool">
            <h3><i class="fas fa-calculator"></i> Interactive: Side Hustle Tax Estimator</h3>
            <p>Estimate your side hustle taxes and see how deductions and retirement contributions can save you money.</p>

            <div style="display: flex; flex-wrap: wrap; gap: 20px; margin: 20px 0;">
                <div style="flex: 1 1 250px;">
                    <label>Gross Side Hustle Income ($)</label>
                    <input type="number" id="grossIncome" class="cat-input" value="20000" step="1000" style="width:100%;">
                </div>
                <div style="flex: 1 1 300px;">
                    <label>Business Expenses (deductible)</label>
                    <input type="number" id="expenses" class="cat-input" value="5000" step="500" style="width:100%;">
                </div>
                <div style="flex: 1 1 300px;">
                    <label>Your Marginal Tax Rate (ordinary income) <span id="marginalRateSideVal">24</span>%</label>
                    <input type="range" id="marginalRateSide" min="0" max="37" value="24" step="1" class="cat-input" style="width:100%;">
                </div>
            </div>

            <div style="margin-bottom: 20px;">
                <h4>Retirement Contribution (optional)</h4>
                <div style="display: flex; flex-wrap: wrap; gap: 20px;">
                    <div style="flex: 1 1 250px;">
                        <label>Choose a plan</label>
                        <select id="retirementPlan" class="cat-input" style="width:100%;">
                            <option value="none">None</option>
                            <option value="sep">SEP IRA (up to 25% of net income)</option>
                            <option value="solo401k">Solo 401(k) (up to $23,000 + 25% profit sharing)</option>
                        </select>
                    </div>
                    <div style="flex: 1 1 250px;">
                        <label>Custom contribution amount ($)</label>
                        <input type="number" id="customContribution" class="cat-input" value="0" step="500" style="width:100%;">
                    </div>
                </div>
            </div>

            <div style="margin-top: 20px;">
                <button id="calcSideHustleTax" class="btn-outline">Calculate Tax Impact</button>
            </div>

            <div id="sideHustleResult" style="margin-top: 25px; padding: 20px; background: var(--light-color); border-radius: 12px;">
                <p>Enter your numbers and click the button to see results.</p>
            </div>

            <p class="pro-tip" style="margin-top: 15px; background-color: #eef2f5; border-left-color: var(--tax-smart-color);">
                <i class="fas fa-lightbulb"></i> This estimator uses simplified rules. Actual taxes depend on your total income, filing status, and state taxes. Consult a tax professional for personalized advice.
            </p>
        </div>

        <!-- quiz section (conditional) -->
        {% if app.user and quiz is defined and quiz %}
            <div class="quiz-container animate" style="background: #1e1a3a;">
                <h3 style="color:white; margin-top: 0;">🧠 You've already taken this quiz</h3>
                <p style="color: #e2e8f0; font-size: 1.2rem;">
                    Your score: <strong>{{ quiz.quizzScore }}%</strong>
                </p>
                <p style="color: #cbd5e0;">
                    You can retake the quiz to improve your score. Click the button below to reset it.
                </p>
                <div class="quiz-actions">
                    <a href="{{ path('app_page_show', { journey: 'tax', slug: 'side-hustle-tax-strategies', retake: 1 }) }}"
                       class="btn"
                       style="background-color: #2c3e50; color: white; text-decoration: none;">
                        Retake Quiz
                    </a>
                </div>
            </div>
        {% else %}
            <div class="quiz-container animate" data-page-id="{{ page.id }}" style="background: #1e2b37;">
                <h3 style="color:white; margin-top: 0;">📝 Test your knowledge: Side Hustle Taxes</h3>

                <div class="quiz-question">1. Which of the following is NOT typically deductible as a business expense for a side hustle?</div>
                <div class="quiz-options" data-question="1">
                    <div class="quiz-option" data-answer="wrong">Home office used exclusively for business</div>
                    <div class="quiz-option" data-answer="correct">Commuting from home to your main job</div>
                    <div class="quiz-option" data-answer="wrong">Software subscriptions for your freelance work</div>
                    <div class="quiz-option" data-answer="wrong">Mileage for client meetings</div>
                </div>

                <div class="quiz-question">2. What is the self‑employment tax rate for 2024?</div>
                <div class="quiz-options" data-question="2">
                    <div class="quiz-option" data-answer="wrong">7.65%</div>
                    <div class="quiz-option" data-answer="correct">15.3%</div>
                    <div class="quiz-option" data-answer="wrong">12.4%</div>
                    <div class="quiz-option" data-answer="wrong">20%</div>
                </div>

                <div class="quiz-question">3. What is the main advantage of a SEP IRA for a side hustler?</div>
                <div class="quiz-options" data-question="3">
                    <div class="quiz-option" data-answer="correct">You can contribute up to 25% of net earnings (up to $66,000) pre‑tax</div>
                    <div class="quiz-option" data-answer="wrong">You can withdraw contributions anytime tax‑free</div>
                    <div class="quiz-option" data-answer="wrong">It requires no paperwork to set up</div>
                    <div class="quiz-option" data-answer="wrong">It has no contribution limits</div>
                </div>

                <div class="quiz-question">4. If you use a home office exclusively for your side hustle, how is the deduction calculated?</div>
                <div class="quiz-options" data-question="4">
                    <div class="quiz-option" data-answer="wrong">Flat $1,500 regardless of size</div>
                    <div class="quiz-option" data-answer="correct">Either actual expenses or simplified $5 per square foot (up to 300 sq ft)</div>
                    <div class="quiz-option" data-answer="wrong">A percentage of your total income</div>
                    <div class="quiz-option" data-answer="wrong">Only available if you have no other income</div>
                </div>

                <div class="quiz-question">5. Why might you consider a Solo 401(k) instead of a SEP IRA?</div>
                <div class="quiz-options" data-question="5">
                    <div class="quiz-option" data-answer="wrong">Lower contribution limits</div>
                    <div class="quiz-option" data-answer="wrong">It's easier to open</div>
                    <div class="quiz-option" data-answer="correct">It allows a larger total contribution (employee + employer) and can include a Roth option</div>
                    <div class="quiz-option" data-answer="wrong">There's no paperwork required</div>
                </div>

                <div class="quiz-actions">
                    <button id="quiz-submit" class="btn" style="background-color: var(--tax-smart-color);">Get score & submit</button>
                </div>
                <div class="quiz-result"></div>
            </div>
        {% endif %}

        <!-- next steps in phase 4 (Skill Building) -->
        <section style="margin: 60px 0;">
            <h2 class="section-title" style="text-align: center;">📘 Continue Phase 4: Skill Building</h2>
            <div class="next-steps">
                <a href="{{ path('app_page_show', { journey: 'tax', slug: 'tax-efficient-withdrawal-strategies-in-retirement' }) }}" class="next-card">
                    <i class="fas fa-umbrella-beach"></i>
                    <h3>Tax‑Efficient Withdrawal Strategies</h3>
                    <p>How to spend your retirement savings smartly.</p>
                </a>
                <a href="{{ path('app_page_show', { journey: 'tax', slug: 'estate-planning-basics' }) }}" class="next-card">
                    <i class="fas fa-tree"></i>
                    <h3>Estate Planning Basics</h3>
                    <p>Step‑up in basis, gift taxes, and inheritance strategies.</p>
                </a>
                <a href="{{ path('app_page_show', { journey: 'tax', slug: 'tax-managed-funds-municipal-bonds' }) }}" class="next-card">
                    <i class="fas fa-city"></i>
                    <h3>Tax‑Managed Funds & Municipal Bonds</h3>
                    <p>Advanced strategies to minimize taxable distributions.</p>
                </a>
            </div>
        </section>
    </div>
{% endblock %}
