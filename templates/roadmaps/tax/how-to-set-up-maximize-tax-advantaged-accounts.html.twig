{# templates/roadmaps/tax/how-to-set-up-maximize-tax-advantaged-accounts.html.twig #}
{% extends 'base-roadmaps.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('tax_css') }}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('tax_js') }}
{% endblock %}

{% block body %}
    <div class="container">
        <!-- article hero – tax style -->
        <div class="article-hero animate" style="background: linear-gradient(135deg, #1e2b37 0%, #2c3e50 100%);">
            <div class="hero-content">
                <div class="hero-icon" style="background-color: var(--tax-smart-color);">
                    <i class="fas fa-gear"></i>
                </div>
                <h1>How to Set Up & Maximize <span>Tax‑Advantaged Accounts</span></h1>
                <p class="hero-description">
                    A practical guide to opening and optimizing 401(k)s, IRAs, and HSAs. Learn the step‑by‑step process,
                    contribution limits, employer match strategies, and how to choose the right accounts for your financial goals.
                </p>
                <div class="phase-tag" style="background-color: rgba(44,62,80,0.2); color: #b0c4de;">
                    <i class="fas fa-layer-group"></i> Phase 3: Practical Execution · 10 min read
                </div>
            </div>
        </div>

        <!-- introduction -->
        <section class="animate">
            <h2 class="section-title">📖 Your Blueprint for Tax‑Efficient Wealth</h2>
            <p style="font-size: 1.2rem; margin-bottom: 20px;">
                Tax‑advantaged accounts are the most powerful tools in your investing arsenal. Yet many people never set them up correctly,
                miss out on employer matches, or fail to maximize contributions. This guide walks you through the entire process—from
                opening accounts to automating contributions—so you can build wealth faster.
            </p>
        </section>

        <!-- key takeaways in rule‑grid style -->
        <div class="rule-grid animate">
            <div class="rule-item">
                <h4><i class="fas fa-building"></i> 401(k) Setup</h4>
                <p>Enroll through your employer, choose a contribution percentage (at least enough to get the full match), and select investments. Aim to increase contributions each year.</p>
            </div>
            <div class="rule-item">
                <h4><i class="fas fa-user"></i> IRA (Traditional & Roth)</h4>
                <p>Open at a brokerage (Vanguard, Fidelity, etc.), fund it, and invest. 2024 limits: $7,000 ($8,000 if 50+). Roth has income limits.</p>
            </div>
            <div class="rule-item">
                <h4><i class="fas fa-briefcase-medical"></i> HSA</h4>
                <p>Available if you have a high‑deductible health plan. Offers triple tax advantage. Contribute pre‑tax, invest for growth, and withdraw tax‑free for medical expenses.</p>
            </div>
        </div>

        <!-- interactive tool: Contribution Prioritizer -->
        <div class="card animate" style="margin: 40px 0;" id="contribution-prioritizer">
            <h3><i class="fas fa-chart-pie"></i> Interactive: Where Should You Contribute First?</h3>
            <p>Enter your financial details to get a personalized order of operations for maximizing tax‑advantaged accounts.</p>

            <div style="display: flex; flex-wrap: wrap; gap: 20px; margin: 20px 0;">
                <div style="flex: 1 1 300px;">
                    <label>Employer 401(k) match (%)</label>
                    <input type="number" id="matchPercent" class="cat-input" style="width:100%;" value="100" step="10">
                    <small>e.g., 100% means dollar‑for‑dollar match; 50% means half match.</small>
                </div>
                <div style="flex: 1 1 300px;">
                    <label>401(k) match limit (% of salary)</label>
                    <input type="number" id="matchLimit" class="cat-input" style="width:100%;" value="6" step="1">
                    <small>Usually 3‑6% of your salary.</small>
                </div>
                <div style="flex: 1 1 300px;">
                    <label>Your marginal tax rate (%)</label>
                    <input type="range" id="taxRatePrioritizer" min="0" max="37" value="24" step="1" class="cat-input" style="width:100%;">
                    <span id="taxRatePrioritizerVal">24</span>%
                </div>
                <div style="flex: 1 1 300px;">
                    <label>Do you expect higher taxes in retirement?</label>
                    <select id="futureTaxOutlook" class="cat-input" style="width:100%;">
                        <option value="higher">Yes, higher</option>
                        <option value="same" selected>About the same</option>
                        <option value="lower">No, lower</option>
                    </select>
                </div>
                <div style="flex: 1 1 300px;">
                    <label>Do you have a high‑deductible health plan (HDHP)?</label>
                    <select id="hasHdhp" class="cat-input" style="width:100%;">
                        <option value="yes">Yes</option>
                        <option value="no" selected>No</option>
                    </select>
                </div>
            </div>

            <div style="margin-top: 20px;">
                <button id="calcPriority" class="btn-outline">Get My Contribution Order</button>
            </div>

            <div id="priorityResult" style="margin-top: 25px; padding: 20px; background: var(--light-color); border-radius: 12px;">
                <p>Enter your details and click the button to see your personalized plan.</p>
            </div>

            <p class="pro-tip" style="margin-top: 15px; background-color: #eef2f5; border-left-color: var(--tax-smart-color);">
                <i class="fas fa-lightbulb"></i> This tool provides a general guideline. Your actual order may vary based on your specific financial goals and investment options.
            </p>
        </div>

        <!-- quiz section (conditional) -->
        {% if app.user and quiz is defined and quiz %}
            <div class="quiz-container animate" style="background: #1e1a3a;">
                <h3 style="color:white; margin-top: 0;">🧠 You've already taken this quiz</h3>
                <p style="color: #e2e8f0; font-size: 1.2rem;">
                    Your score: <strong>{{ quiz.quizzScore }}%</strong>
                </p>
                <p style="color: #cbd5e0;">
                    You can retake the quiz to improve your score. Click the button below to reset it.
                </p>
                <div class="quiz-actions">
                    <a href="{{ path('app_page_show', { journey: 'tax', slug: 'how-to-set-up-maximize-tax-advantaged-accounts', retake: 1 }) }}"
                       class="btn"
                       style="background-color: #2c3e50; color: white; text-decoration: none;">
                        Retake Quiz
                    </a>
                </div>
            </div>
        {% else %}
            <div class="quiz-container animate" data-page-id="{{ page.id }}" style="background: #1e2b37;">
                <h3 style="color:white; margin-top: 0;">📝 Test your knowledge: Setting Up Tax‑Advantaged Accounts</h3>

                <div class="quiz-question">1. What is the first financial priority when contributing to a 401(k)?</div>
                <div class="quiz-options" data-question="1">
                    <div class="quiz-option" data-answer="correct">Contribute enough to get the full employer match</div>
                    <div class="quiz-option" data-answer="wrong">Max out the $23,000 limit immediately</div>
                    <div class="quiz-option" data-answer="wrong">Choose Roth contributions only</div>
                    <div class="quiz-option" data-answer="wrong">Invest in the highest‑risk funds</div>
                </div>

                <div class="quiz-question">2. For 2024, what is the maximum contribution to an IRA (Traditional or Roth) for someone under 50?</div>
                <div class="quiz-options" data-question="2">
                    <div class="quiz-option" data-answer="wrong">$5,500</div>
                    <div class="quiz-option" data-answer="correct">$7,000</div>
                    <div class="quiz-option" data-answer="wrong">$8,000</div>
                    <div class="quiz-option" data-answer="wrong">$10,000</div>
                </div>

                <div class="quiz-question">3. Which of the following is required to open an HSA?</div>
                <div class="quiz-options" data-question="3">
                    <div class="quiz-option" data-answer="wrong">Being self‑employed</div>
                    <div class="quiz-option" data-answer="correct">Enrollment in a high‑deductible health plan (HDHP)</div>
                    <div class="quiz-option" data-answer="wrong">Having a Traditional IRA</div>
                    <div class="quiz-option" data-answer="wrong">Being over age 55</div>
                </div>

                <div class="quiz-question">4. What is a key benefit of a Roth IRA over a Traditional IRA?</div>
                <div class="quiz-options" data-question="4">
                    <div class="quiz-option" data-answer="wrong">No contribution limits</div>
                    <div class="quiz-option" data-answer="wrong">Pre‑tax contributions</div>
                    <div class="quiz-option" data-answer="correct">Tax‑free qualified withdrawals in retirement</div>
                    <div class="quiz-option" data-answer="wrong">Employer matching</div>
                </div>

                <div class="quiz-question">5. After maxing out your employer match, what is generally the next best account to fund?</div>
                <div class="quiz-options" data-question="5">
                    <div class="quiz-option" data-answer="correct">IRA (Traditional or Roth)</div>
                    <div class="quiz-option" data-answer="wrong">Taxable brokerage account</div>
                    <div class="quiz-option" data-answer="wrong">529 plan</div>
                    <div class="quiz-option" data-answer="wrong">Increase 401(k) contributions further</div>
                </div>

                <div class="quiz-actions">
                    <button id="quiz-submit" class="btn" style="background-color: var(--tax-smart-color);">Get score & submit</button>
                </div>
                <div class="quiz-result"></div>
            </div>
        {% endif %}

        <!-- next steps in phase 3 (Practical Execution) -->
        <section style="margin: 60px 0;">
            <h2 class="section-title" style="text-align: center;">📘 Continue Phase 3: Practical Execution</h2>
            <div class="next-steps">
                <a href="{{ path('app_page_show', { journey: 'tax', slug: 'step-by-step-harvesting-your-first-tax-loss' }) }}" class="next-card">
                    <i class="fas fa-check-double"></i>
                    <h3>Harvesting Your First Tax Loss</h3>
                    <p>Step‑by‑step guide with checklist and simulator.</p>
                </a>
                <a href="{{ path('app_page_show', { journey: 'tax', slug: 'year-end-tax-planning-checklist' }) }}" class="next-card">
                    <i class="fas fa-calendar-check"></i>
                    <h3>Year‑End Tax Planning Checklist</h3>
                    <p>What to do in November/December to optimize taxes.</p>
                </a>
                <a href="{{ path('app_page_show', { journey: 'tax', slug: 'tax-software-or-professional' }) }}" class="next-card">
                    <i class="fas fa-laptop"></i>
                    <h3>Tax Software or a Professional?</h3>
                    <p>Decide whether to DIY with software or hire a CPA.</p>
                </a>
            </div>
        </section>
    </div>
{% endblock %}
