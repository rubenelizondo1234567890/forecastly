{# templates/roadmaps/tax/tax-efficient-withdrawal-strategies-in-retirement.html.twig #}
{% extends 'base-roadmaps.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('tax_css') }}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('tax_js') }}
{% endblock %}

{% block body %}
    <div class="container">
        <!-- article hero – tax style -->
        <div class="article-hero animate" style="background: linear-gradient(135deg, #1e2b37 0%, #2c3e50 100%);">
            <div class="hero-content">
                <div class="hero-icon" style="background-color: var(--tax-smart-color);">
                    <i class="fas fa-umbrella-beach"></i>
                </div>
                <h1>Tax‑Efficient Withdrawal <span>Strategies in Retirement</span></h1>
                <p class="hero-description">
                    How you withdraw money in retirement can be just as important as how you saved it.
                    Learn the optimal order to tap your accounts, how to manage tax brackets, and strategies to make your nest egg last longer.
                </p>
                <div class="phase-tag" style="background-color: rgba(44,62,80,0.2); color: #b0c4de;">
                    <i class="fas fa-layer-group"></i> Phase 4: Skill Building · 13 min read
                </div>
            </div>
        </div>

        <!-- introduction -->
        <section class="animate">
            <h2 class="section-title">📖 The Art of Spending Smartly</h2>
            <p style="font-size: 1.2rem; margin-bottom: 20px;">
                You've spent decades saving and investing. Now comes the critical phase: spending your hard‑earned money.
                The order in which you withdraw from your accounts—taxable, tax‑deferred, and tax‑free—can dramatically affect how much you keep.
                This article reveals the strategies used by savvy retirees to minimize taxes and maximize longevity.
            </p>
        </section>

        <!-- key takeaways in rule‑grid style -->
        <div class="rule-grid animate">
            <div class="rule-item">
                <h4><i class="fas fa-chart-line"></i> The "Bucket" Strategy</h4>
                <p>First, withdraw from taxable accounts (using cash, dividends, and gains). Next, tap tax‑deferred accounts (Traditional IRA/401k) up to the top of your current bracket. Finally, use Roth accounts tax‑free.</p>
            </div>
            <div class="rule-item">
                <h4><i class="fas fa-chart-simple"></i> Manage Your Tax Brackets</h4>
                <p>Fill lower brackets with tax‑deferred withdrawals. Consider Roth conversions in low‑income years to avoid higher future taxes.</p>
            </div>
            <div class="rule-item">
                <h4><i class="fas fa-hand-holding-usd"></i> Required Minimum Distributions (RMDs)</h4>
                <p>After age 73 (or 75 depending on birth year), you must withdraw from Traditional IRAs/401ks. Plan ahead to avoid being pushed into a higher bracket.</p>
            </div>
        </div>

        <!-- interactive tool: Retirement Withdrawal Optimizer -->
        <div class="card animate" style="margin: 40px 0;" id="retirement-withdrawal-tool">
            <h3><i class="fas fa-chart-pie"></i> Interactive: Retirement Withdrawal Optimizer</h3>
            <p>Enter your account balances and annual spending to see the optimal withdrawal order and estimated taxes.</p>

            <div style="display: flex; flex-wrap: wrap; gap: 20px; margin: 20px 0;">
                <div style="flex: 1 1 250px;">
                    <label>Taxable Account Balance ($)</label>
                    <input type="number" id="taxableBalance" class="cat-input" value="200000" step="10000" style="width:100%;">
                </div>
                <div style="flex: 1 1 250px;">
                    <label>Tax‑Deferred Balance (Traditional IRA/401k) ($)</label>
                    <input type="number" id="deferredBalance" class="cat-input" value="500000" step="10000" style="width:100%;">
                </div>
                <div style="flex: 1 1 250px;">
                    <label>Tax‑Free Balance (Roth IRA/401k) ($)</label>
                    <input type="number" id="rothBalance" class="cat-input" value="100000" step="10000" style="width:100%;">
                </div>
            </div>
            <div style="display: flex; flex-wrap: wrap; gap: 20px;">
                <div style="flex: 1 1 250px;">
                    <label>Annual Desired Spending ($)</label>
                    <input type="number" id="annualSpending" class="cat-input" value="50000" step="5000" style="width:100%;">
                </div>
                <div style="flex: 1 1 250px;">
                    <label>Marginal Tax Rate (on ordinary income) <span id="taxRateWithdrawalVal">24</span>%</label>
                    <input type="range" id="taxRateWithdrawal" min="0" max="37" value="24" step="1" class="cat-input" style="width:100%;">
                </div>
                <div style="flex: 1 1 250px;">
                    <label>Capital Gains Tax Rate</label>
                    <input type="range" id="ltcgRateWithdrawal" min="0" max="20" value="15" step="1" class="cat-input" style="width:100%;">
                    <span id="ltcgRateVal">15</span>%
                </div>
            </div>

            <div style="margin-top: 20px;">
                <button id="optimizeWithdrawals" class="btn-outline">Calculate Optimal Strategy</button>
            </div>

            <div id="withdrawalResult" style="margin-top: 25px; padding: 20px; background: var(--light-color); border-radius: 12px;">
                <p>Enter your details and click the button to see the optimal withdrawal strategy.</p>
            </div>

            <p class="pro-tip" style="margin-top: 15px; background-color: #eef2f5; border-left-color: var(--tax-smart-color);">
                <i class="fas fa-lightbulb"></i> This tool assumes you have sufficient balances and uses a simplified strategy: taxable first, then tax‑deferred up to your bracket limit, then Roth tax‑free. Real‑world planning should consider RMDs, Social Security taxation, and other factors.
            </p>
        </div>

        <!-- quiz section (conditional) -->
        {% if app.user and quiz is defined and quiz %}
            <div class="quiz-container animate" style="background: #1e1a3a;">
                <h3 style="color:white; margin-top: 0;">🧠 You've already taken this quiz</h3>
                <p style="color: #e2e8f0; font-size: 1.2rem;">
                    Your score: <strong>{{ quiz.quizzScore }}%</strong>
                </p>
                <p style="color: #cbd5e0;">
                    You can retake the quiz to improve your score. Click the button below to reset it.
                </p>
                <div class="quiz-actions">
                    <a href="{{ path('app_page_show', { journey: 'tax', slug: 'tax-efficient-withdrawal-strategies-in-retirement', retake: 1 }) }}"
                       class="btn"
                       style="background-color: #2c3e50; color: white; text-decoration: none;">
                        Retake Quiz
                    </a>
                </div>
            </div>
        {% else %}
            <div class="quiz-container animate" data-page-id="{{ page.id }}" style="background: #1e2b37;">
                <h3 style="color:white; margin-top: 0;">📝 Test your knowledge: Retirement Withdrawal Strategies</h3>

                <div class="quiz-question">1. In retirement, which account should you typically withdraw from first to minimize taxes?</div>
                <div class="quiz-options" data-question="1">
                    <div class="quiz-option" data-answer="wrong">Tax‑deferred (Traditional IRA/401k)</div>
                    <div class="quiz-option" data-answer="correct">Taxable brokerage account</div>
                    <div class="quiz-option" data-answer="wrong">Roth IRA</div>
                    <div class="quiz-option" data-answer="wrong">Health Savings Account</div>
                </div>

                <div class="quiz-question">2. Why might you withdraw from a Traditional IRA before touching a Roth IRA?</div>
                <div class="quiz-options" data-question="2">
                    <div class="quiz-option" data-answer="wrong">Roth withdrawals are taxed at a higher rate</div>
                    <div class="quiz-option" data-answer="wrong">Traditional IRA has no required minimum distributions</div>
                    <div class="quiz-option" data-answer="correct">To use up lower tax brackets and allow Roth to grow tax‑free longer</div>
                    <div class="quiz-option" data-answer="wrong">It's required by law</div>
                </div>

                <div class="quiz-question">3. At what age do Required Minimum Distributions (RMDs) generally begin for most retirees (depending on birth year)?</div>
                <div class="quiz-options" data-question="3">
                    <div class="quiz-option" data-answer="wrong">65</div>
                    <div class="quiz-option" data-answer="wrong">70½</div>
                    <div class="quiz-option" data-answer="correct">73 (or 75 for those born later)</div>
                    <div class="quiz-option" data-answer="wrong">80</div>
                </div>

                <div class="quiz-question">4. What is a Roth conversion?</div>
                <div class="quiz-options" data-question="4">
                    <div class="quiz-option" data-answer="wrong">Moving money from a Roth to a Traditional account</div>
                    <div class="quiz-option" data-answer="correct">Moving money from a Traditional IRA to a Roth IRA, paying taxes now</div>
                    <div class="quiz-option" data-answer="wrong">Withdrawing from a Roth tax‑free</div>
                    <div class="quiz-option" data-answer="wrong">A strategy to avoid RMDs entirely</div>
                </div>

                <div class="quiz-question">5. Why might you want to keep your taxable income low in retirement?</div>
                <div class="quiz-options" data-question="5">
                    <div class="quiz-option" data-answer="correct">To avoid higher Medicare premiums (IRMAA) and keep more of your Social Security benefits tax‑free</div>
                    <div class="quiz-option" data-answer="wrong">There's no benefit to low income in retirement</div>
                    <div class="quiz-option" data-answer="wrong">To qualify for a mortgage</div>
                    <div class="quiz-option" data-answer="wrong">To avoid paying state income tax</div>
                </div>

                <div class="quiz-actions">
                    <button id="quiz-submit" class="btn" style="background-color: var(--tax-smart-color);">Get score & submit</button>
                </div>
                <div class="quiz-result"></div>
            </div>
        {% endif %}

        <!-- next steps in phase 4 (Skill Building) -->
        <section style="margin: 60px 0;">
            <h2 class="section-title" style="text-align: center;">📘 Continue Phase 4: Skill Building</h2>
            <div class="next-steps">
                <a href="{{ path('app_page_show', { journey: 'tax', slug: 'side-hustle-tax-strategies' }) }}" class="next-card">
                    <i class="fas fa-briefcase"></i>
                    <h3>Side Hustle Tax Strategies</h3>
                    <p>Write off expenses and consider SEP IRA or Solo 401(k).</p>
                </a>
                <a href="{{ path('app_page_show', { journey: 'tax', slug: 'estate-planning-basics' }) }}" class="next-card">
                    <i class="fas fa-tree"></i>
                    <h3>Estate Planning Basics</h3>
                    <p>Step‑up in basis, gift taxes, and inheritance strategies.</p>
                </a>
                <a href="{{ path('app_page_show', { journey: 'tax', slug: 'tax-managed-funds-municipal-bonds' }) }}" class="next-card">
                    <i class="fas fa-city"></i>
                    <h3>Tax‑Managed Funds & Municipal Bonds</h3>
                    <p>Advanced strategies to minimize taxable distributions.</p>
                </a>
            </div>
        </section>
    </div>
{% endblock %}
