{# templates/roadmaps/tax/year-end-tax-planning-checklist.html.twig #}
{% extends 'base-roadmaps.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('tax_css') }}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('tax_js') }}
{% endblock %}

{% block body %}
    <div class="container">
        <!-- article hero – tax style -->
        <div class="article-hero animate" style="background: linear-gradient(135deg, #1e2b37 0%, #2c3e50 100%);">
            <div class="hero-content">
                <div class="hero-icon" style="background-color: var(--tax-smart-color);">
                    <i class="fas fa-calendar-check"></i>
                </div>
                <h1>Year‑End Tax Planning <span>Checklist</span></h1>
                <p class="hero-description">
                    Before December 31, take these critical steps to reduce your tax bill, maximize deductions, and set yourself up for a stress‑free tax season. Use our interactive checklist to track your progress.
                </p>
                <div class="phase-tag" style="background-color: rgba(44,62,80,0.2); color: #b0c4de;">
                    <i class="fas fa-layer-group"></i> Phase 3: Practical Execution · 9 min read
                </div>
            </div>
        </div>

        <!-- introduction -->
        <section class="animate">
            <h2 class="section-title">📖 Don't Leave Money on the Table</h2>
            <p style="font-size: 1.2rem; margin-bottom: 20px;">
                The end of the year is your last chance to take actions that affect this year's tax return. Whether it's harvesting losses,
                making charitable contributions, or maxing out retirement accounts, a few smart moves can save you thousands.
                This checklist covers the most impactful strategies.
            </p>
        </section>

        <!-- key takeaways in rule‑grid style -->
        <div class="rule-grid animate">
            <div class="rule-item">
                <h4><i class="fas fa-leaf"></i> Harvest Losses</h4>
                <p>Sell losing investments to offset gains and up to $3,000 of ordinary income. Watch the wash sale rule.</p>
            </div>
            <div class="rule-item">
                <h4><i class="fas fa-hand-holding-heart"></i> Maximize Deductions</h4>
                <p>Bunch charitable donations, prepay property tax (if allowed), and consider qualified charitable distributions if over 70½.</p>
            </div>
            <div class="rule-item">
                <h4><i class="fas fa-piggy-bank"></i> Boost Retirement Savings</h4>
                <p>Max out 401(k), IRA, and HSA contributions before the deadlines. Check if you qualify for a Roth conversion.</p>
            </div>
        </div>

        <!-- interactive tool: Year‑End Tax Planning Checklist -->
        <div class="card animate" style="margin: 40px 0;" id="year-end-checklist">
            <h3><i class="fas fa-clipboard-list"></i> Interactive: Year‑End Tax Planning Checklist</h3>
            <p>Check off the items you've completed. Enter the relevant amounts to see estimated tax savings.</p>

            <div style="margin-bottom: 20px;">
                <label>Your marginal tax rate (%)</label>
                <input type="range" id="taxRateChecklist" min="0" max="37" value="24" step="1" class="cat-input" style="width:100%; max-width:300px;">
                <span id="taxRateChecklistVal">24</span>%
            </div>

            <div class="checklist-container" style="margin: 25px 0;">
                <!-- Item 1: Tax‑Loss Harvesting -->
                <div class="checklist-item" data-item="losses">
                    <div class="checklist-checkbox">
                        <input type="checkbox" id="checkLosses" class="checklist-input">
                        <label for="checkLosses">✅ Harvest tax losses</label>
                    </div>
                    <div class="checklist-details">
                        <label>Realized losses ($)</label>
                        <input type="number" id="lossAmount" class="cat-input checklist-amount" value="3000" step="500" disabled>
                        <span class="checklist-savings"></span>
                    </div>
                </div>

                <!-- Item 2: Max Out Retirement Contributions -->
                <div class="checklist-item" data-item="retirement">
                    <div class="checklist-checkbox">
                        <input type="checkbox" id="checkRetirement" class="checklist-input">
                        <label for="checkRetirement">💰 Max out retirement contributions (401k, IRA)</label>
                    </div>
                    <div class="checklist-details">
                        <label>Additional contribution ($)</label>
                        <input type="number" id="retirementAmount" class="cat-input checklist-amount" value="5000" step="500" disabled>
                        <span class="checklist-savings"></span>
                    </div>
                </div>

                <!-- Item 3: HSA Contribution -->
                <div class="checklist-item" data-item="hsa">
                    <div class="checklist-checkbox">
                        <input type="checkbox" id="checkHSA" class="checklist-input">
                        <label for="checkHSA">🏥 Max out HSA contribution (if eligible)</label>
                    </div>
                    <div class="checklist-details">
                        <label>HSA contribution ($)</label>
                        <input type="number" id="hsaAmount" class="cat-input checklist-amount" value="4150" step="500" disabled>
                        <span class="checklist-savings"></span>
                    </div>
                </div>

                <!-- Item 4: Charitable Donations -->
                <div class="checklist-item" data-item="charity">
                    <div class="checklist-checkbox">
                        <input type="checkbox" id="checkCharity" class="checklist-input">
                        <label for="checkCharity">🙏 Make charitable donations (cash or appreciated stock)</label>
                    </div>
                    <div class="checklist-details">
                        <label>Donation amount ($)</label>
                        <input type="number" id="charityAmount" class="cat-input checklist-amount" value="1000" step="100" disabled>
                        <span class="checklist-savings"></span>
                    </div>
                </div>

                <!-- Item 5: Bunch Deductions -->
                <div class="checklist-item" data-item="bunch">
                    <div class="checklist-checkbox">
                        <input type="checkbox" id="checkBunch" class="checklist-input">
                        <label for="checkBunch">📑 Bunch deductions (prepay property tax, medical expenses)</label>
                    </div>
                    <div class="checklist-details">
                        <label>Additional deductible expenses ($)</label>
                        <input type="number" id="bunchAmount" class="cat-input checklist-amount" value="2000" step="500" disabled>
                        <span class="checklist-savings"></span>
                    </div>
                </div>

                <!-- Item 6: Roth Conversion -->
                <div class="checklist-item" data-item="roth">
                    <div class="checklist-checkbox">
                        <input type="checkbox" id="checkRoth" class="checklist-input">
                        <label for="checkRoth">🔄 Consider Roth conversion (if in lower bracket this year)</label>
                    </div>
                    <div class="checklist-details">
                        <label>Amount converted ($)</label>
                        <input type="number" id="rothAmount" class="cat-input checklist-amount" value="10000" step="1000" disabled>
                        <span class="checklist-savings"></span>
                        <span class="checklist-note">(This may increase current taxes but saves future taxes)</span>
                    </div>
                </div>
            </div>

            <div id="checklistSummary" style="margin-top: 25px; padding: 20px; background: var(--light-color); border-radius: 12px;">
                <p><strong>Estimated Tax Savings:</strong> <span id="totalSavings">$0</span></p>
                <p>Complete the checklist items to see your potential tax savings.</p>
            </div>

            <p class="pro-tip" style="margin-top: 15px; background-color: #eef2f5; border-left-color: var(--tax-smart-color);">
                <i class="fas fa-lightbulb"></i> This checklist provides estimates based on your marginal tax rate. Real savings depend on your specific situation, including itemized deductions and phase‑outs. Consult a tax professional.
            </p>
        </div>

        <!-- quiz section (conditional) -->
        {% if app.user and quiz is defined and quiz %}
            <div class="quiz-container animate" style="background: #1e1a3a;">
                <h3 style="color:white; margin-top: 0;">🧠 You've already taken this quiz</h3>
                <p style="color: #e2e8f0; font-size: 1.2rem;">
                    Your score: <strong>{{ quiz.quizzScore }}%</strong>
                </p>
                <p style="color: #cbd5e0;">
                    You can retake the quiz to improve your score. Click the button below to reset it.
                </p>
                <div class="quiz-actions">
                    <a href="{{ path('app_page_show', { journey: 'tax', slug: 'year-end-tax-planning-checklist', retake: 1 }) }}"
                       class="btn"
                       style="background-color: #2c3e50; color: white; text-decoration: none;">
                        Retake Quiz
                    </a>
                </div>
            </div>
        {% else %}
            <div class="quiz-container animate" data-page-id="{{ page.id }}" style="background: #1e2b37;">
                <h3 style="color:white; margin-top: 0;">📝 Test your knowledge: Year‑End Tax Planning</h3>

                <div class="quiz-question">1. Which of the following actions must be completed by December 31 to affect this year's taxes?</div>
                <div class="quiz-options" data-question="1">
                    <div class="quiz-option" data-answer="correct">Making charitable contributions</div>
                    <div class="quiz-option" data-answer="wrong">Filing your tax return</div>
                    <div class="quiz-option" data-answer="wrong">Making IRA contributions for the previous year</div>
                    <div class="quiz-option" data-answer="wrong">Paying estimated taxes for the following year</div>
                </div>

                <div class="quiz-question">2. What is the maximum amount of capital loss that can offset ordinary income in a single tax year?</div>
                <div class="quiz-options" data-question="2">
                    <div class="quiz-option" data-answer="wrong">$1,000</div>
                    <div class="quiz-option" data-answer="correct">$3,000</div>
                    <div class="quiz-option" data-answer="wrong">$5,000</div>
                    <div class="quiz-option" data-answer="wrong">No limit</div>
                </div>

                <div class="quiz-question">3. Why might you "bunch" charitable donations into one tax year?</div>
                <div class="quiz-options" data-question="3">
                    <div class="quiz-option" data-answer="correct">To exceed the standard deduction and itemize</div>
                    <div class="quiz-option" data-answer="wrong">To avoid reporting them</div>
                    <div class="quiz-option" data-answer="wrong">To lower your tax bracket permanently</div>
                    <div class="quiz-option" data-answer="wrong">To qualify for a Roth IRA</div>
                </div>

                <div class="quiz-question">4. When is the deadline to make a Roth conversion for the current tax year?</div>
                <div class="quiz-options" data-question="4">
                    <div class="quiz-option" data-answer="wrong">April 15 of the following year</div>
                    <div class="quiz-option" data-answer="correct">December 31 of the current year</div>
                    <div class="quiz-option" data-answer="wrong">October 15 of the following year</div>
                    <div class="quiz-option" data-answer="wrong">Any time before filing your return</div>
                </div>

                <div class="quiz-question">5. If you donate appreciated stock held for more than a year, what tax advantage do you get?</div>
                <div class="quiz-options" data-question="5">
                    <div class="quiz-option" data-answer="correct">You deduct the fair market value and avoid paying capital gains tax on the appreciation</div>
                    <div class="quiz-option" data-answer="wrong">You deduct only your cost basis</div>
                    <div class="quiz-option" data-answer="wrong">You must pay capital gains tax on the appreciation</div>
                    <div class="quiz-option" data-answer="wrong">There is no tax benefit</div>
                </div>

                <div class="quiz-actions">
                    <button id="quiz-submit" class="btn" style="background-color: var(--tax-smart-color);">Get score & submit</button>
                </div>
                <div class="quiz-result"></div>
            </div>
        {% endif %}

        <!-- next steps in phase 3 (Practical Execution) -->
        <section style="margin: 60px 0;">
            <h2 class="section-title" style="text-align: center;">📘 Continue Phase 3: Practical Execution</h2>
            <div class="next-steps">
                <a href="{{ path('app_page_show', { journey: 'tax', slug: 'step-by-step-harvesting-your-first-tax-loss' }) }}" class="next-card">
                    <i class="fas fa-check-double"></i>
                    <h3>Harvesting Your First Tax Loss</h3>
                    <p>Step‑by‑step guide with checklist and simulator.</p>
                </a>
                <a href="{{ path('app_page_show', { journey: 'tax', slug: 'how-to-set-up-maximize-tax-advantaged-accounts' }) }}" class="next-card">
                    <i class="fas fa-gear"></i>
                    <h3>Set Up & Maximize Tax‑Advantaged Accounts</h3>
                    <p>Practical guide to opening and optimizing accounts.</p>
                </a>
                <a href="{{ path('app_page_show', { journey: 'tax', slug: 'tax-software-or-professional' }) }}" class="next-card">
                    <i class="fas fa-laptop"></i>
                    <h3>Tax Software or a Professional?</h3>
                    <p>Decide whether to DIY with software or hire a CPA.</p>
                </a>
            </div>
        </section>
    </div>
{% endblock %}
