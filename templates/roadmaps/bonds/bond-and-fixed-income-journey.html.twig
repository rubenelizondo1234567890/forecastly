{# templates/roadmaps/bonds/bond-and-fixed-income-journey.html.twig #}
{% extends 'base-roadmaps.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('bonds_css') }}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('bonds_js') }}
{% endblock %}

{% block body %}
    <div class="container">
        <!-- hero section specific for bond & fixed income -->
        <div class="journey-hero animate">
            <div class="hero-content">
                <div class="journey-icon">
                    <i class="fas fa-hand-holding-usd"></i>
                </div>
                <h1>Bond & Fixed Income <span>Basics</span></h1>
                <p class="hero-description">
                    Bonds aren’t boring – they’re ballast. Learn how government and corporate bonds work,
                    manage risks, and build a resilient portfolio. Your four‑phase roadmap starts here.
                </p>
            </div>
        </div>

        <!-- intro text: how our roadmaps work (bonds version) -->
        <div style="text-align: center; margin: 40px 0 20px;" class="animate">
            <h2 class="section-title">🧭 Your 4‑phase bond roadmap</h2>
            <p class="section-subtitle">
                Each phase follows the <strong>Foundation → Risk → Execution → Skill Building</strong> structure.
                Complete the articles in order or jump to what you need most.
            </p>
        </div>

        <!-- ===== PHASE 1 – FOUNDATION FIRST ===== -->
        <div class="phase-wrapper animate">
            <div class="phase-title">
                <span class="phase-number">1</span>
                <span>Foundation First · Core bond concepts</span>
            </div>
            <div class="article-grid">
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-landmark"></i></div>
                    <h3>What Are Bonds? A Beginner’s Guide</h3>
                    <p class="article-brief">Understand the essential concepts: face value, coupon, maturity, and how bonds differ from stocks. No jargon, just the foundation.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 9 min read</span>
                        <a href="#" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-building"></i></div>
                    <h3>Types of Bonds: Government, Corporate, Municipal</h3>
                    <p class="article-brief">Explore the main bond categories, who issues them, and their typical risk/return profiles.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 8 min read</span>
                        <a href="#" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-chart-line"></i></div>
                    <h3>How Bond Prices Work: Premium, Discount, and Par</h3>
                    <p class="article-brief">Learn why bond prices fluctuate and what it means to buy a bond at a premium or discount.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 7 min read</span>
                        <a href="#" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-book-open"></i></div>
                    <h3>Key Bond Terminology: Coupon, Yield, Maturity</h3>
                    <p class="article-brief">Master the vocabulary you'll encounter in any bond discussion or offering document.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 6 min read</span>
                        <a href="#" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
            </div>
        </div>

        <!-- ===== PHASE 2 – RISK MANAGEMENT ===== -->
        <div class="phase-wrapper animate">
            <div class="phase-title">
                <span class="phase-number">2</span>
                <span>Risk Management · Protect your fixed income</span>
            </div>
            <div class="article-grid">
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-chart-simple"></i></div>
                    <h3>Interest Rate Risk: Why Bond Prices Move Inversely</h3>
                    <p class="article-brief">Discover the most important risk for bondholders and how duration measures sensitivity.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 10 min read</span>
                        <a href="#" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-shield"></i></div>
                    <h3>Credit Risk and Bond Ratings Explained</h3>
                    <p class="article-brief">Learn what credit ratings mean, how they affect yields, and how to assess default risk.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 8 min read</span>
                        <a href="#" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-wind"></i></div>
                    <h3>Inflation and Purchasing Power Risk</h3>
                    <p class="article-brief">Understand how inflation erodes fixed returns and which bonds (like TIPS) can help.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 7 min read</span>
                        <a href="#" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-rotate-left"></i></div>
                    <h3>Reinvestment Risk: When Your Bond Matures</h3>
                    <p class="article-brief">Find out what happens when you have to reinvest at lower rates and how to plan ahead.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 6 min read</span>
                        <a href="#" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
            </div>
        </div>

        <!-- ===== PHASE 3 – PRACTICAL EXECUTION ===== -->
        <div class="phase-wrapper animate">
            <div class="phase-title">
                <span class="phase-number">3</span>
                <span>Practical Execution · Buy & build</span>
            </div>
            <div class="article-grid">
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-bag-shopping"></i></div>
                    <h3>How to Buy Bonds: Brokerage, TreasuryDirect, ETFs</h3>
                    <p class="article-brief">Step‑by‑step guide to accessing the bond market, whether you want individual bonds or funds.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 11 min read</span>
                        <a href="#" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-layer-group"></i></div>
                    <h3>Building a Bond Ladder for Steady Income</h3>
                    <p class="article-brief">Learn the ladder strategy to manage interest rate risk and create predictable cash flow.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 9 min read</span>
                        <a href="#" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-scale-balanced"></i></div>
                    <h3>Bond Funds vs. Individual Bonds: Pros and Cons</h3>
                    <p class="article-brief">Compare liquidity, diversification, fees, and control to decide which suits your needs.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 8 min read</span>
                        <a href="#" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-table"></i></div>
                    <h3>Reading a Bond Quote or Table Like a Pro</h3>
                    <p class="article-brief">Decode the numbers and symbols in bond listings so you know exactly what you're buying.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 7 min read</span>
                        <a href="#" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
            </div>
        </div>

        <!-- ===== PHASE 4 – SKILL BUILDING ===== -->
        <div class="phase-wrapper animate">
            <div class="phase-title">
                <span class="phase-number">4</span>
                <span>Skill Building · Deepen your expertise</span>
            </div>
            <div class="article-grid">
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-chart-scatter"></i></div>
                    <h3>Advanced Yield Curve Analysis</h3>
                    <p class="article-brief">Understand what the yield curve tells about the economy and how to position your portfolio accordingly.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 10 min read</span>
                        <a href="#" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-bell"></i></div>
                    <h3>Callable Bonds and Sinking Funds</h3>
                    <p class="article-brief">Dive into features that can work for or against you, and learn what to watch for.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 8 min read</span>
                        <a href="#" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-umbrella"></i></div>
                    <h3>TIPS and I Bonds: Inflation-Protected Securities</h3>
                    <p class="article-brief">Explore government bonds designed to safeguard purchasing power.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 7 min read</span>
                        <a href="#" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-file-invoice-dollar"></i></div>
                    <h3>Tax-Efficient Bond Investing</h3>
                    <p class="article-brief">Strategies for holding bonds in taxable vs. tax‑advantaged accounts to minimise taxes.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 9 min read</span>
                        <a href="#" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
            </div>
        </div>

        <!-- call to action – start bond journey -->
        <div class="journey-cta animate">
            <h2>Ready to make bonds work for you?</h2>
            <p style="font-size: 1.2rem; color: #2d3748; margin-bottom: 10px;">Start with phase 1 – clear, step‑by‑step, no pressure.</p>
            <a href="#" class="cta-button"><i class="fas fa-road"></i> Begin the bond journey</a>
            <p style="margin-top: 25px; color: #718096;"><i class="fas fa-users"></i> Join 3,500+ fixed income learners</p>
        </div>
    </div>
{% endblock %}
