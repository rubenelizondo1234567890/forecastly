{# templates/roadmaps/credit/career-capital-journey.html.twig #}
{% extends 'base-roadmaps.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('credit_css') }}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('credit_js') }}
{% endblock %}

{% block body %}
    <div class="container">
        <!-- hero section specific for smart credit & debt -->
        <div class="journey-hero animate">
            <div class="hero-content">
                <div class="journey-icon">
                    <i class="fas fa-credit-card"></i>
                </div>
                <h1>Smart Credit & <span>Debt Optimization</span></h1>
                <p class="hero-description">
                    Use credit as a tool, not a trap. Learn to leverage good debt, crush high‑interest debt,
                    and build a credit score that saves you money — step by step.
                </p>
            </div>
        </div>

        <!-- intro: 4-phase roadmap explanation (credit flavour) -->
        <div style="text-align: center; margin: 40px 0 20px;" class="animate">
            <h2 class="section-title">🧭 Your 4‑phase credit roadmap</h2>
            <p class="section-subtitle">
                Every phase follows the <strong>Foundation → Risk → Execution → Skill Building</strong> structure.
                Go in order or jump to what you need most.
            </p>
        </div>

        <!-- ===== PHASE 1 – FOUNDATION FIRST ===== -->
        <div class="phase-wrapper animate">
            <div class="phase-title">
                <span class="phase-number">1</span>
                <span>Foundation First · Credit & debt basics</span>
            </div>
            <div class="article-grid">
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-chart-line"></i></div>
                    <h3>Credit Scores & Reports: What the Numbers Mean</h3>
                    <p class="article-brief">Demystify FICO and VantageScore, learn where to get free reports, and understand what impacts your score most.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 9 min read</span>
                        <a href="#" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-balance-scale"></i></div>
                    <h3>Good Debt vs. Bad Debt – A Clear Framework</h3>
                    <p class="article-brief">How to distinguish between debt that can build wealth (mortgages, student loans) and debt that drains it (high‑interest credit cards).</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 8 min read</span>
                        <a href="#" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-percent"></i></div>
                    <h3>How Interest Really Works (APR, compounding)</h3>
                    <p class="article-brief">Simple explanations of annual percentage rate, daily compounding, and why minimum payments keep you in debt.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 7 min read</span>
                        <a href="#" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-credit-card"></i></div>
                    <h3>Anatomy of a Credit Card: Terms You Must Know</h3>
                    <p class="article-brief">From grace periods to annual fees – decode the fine print so you never get caught by surprise.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 6 min read</span>
                        <a href="#" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
            </div>
        </div>

        <!-- ===== PHASE 2 – RISK MANAGEMENT ===== -->
        <div class="phase-wrapper animate">
            <div class="phase-title">
                <span class="phase-number">2</span>
                <span>Risk Management · Protect your credit health</span>
            </div>
            <div class="article-grid">
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-exclamation-triangle"></i></div>
                    <h3>Common Debt Traps & How to Avoid Them</h3>
                    <p class="article-brief">Payday loans, rent‑to‑own, and “buy now pay later” pitfalls – spot them before they trap you.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 8 min read</span>
                        <a href="#" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-shield-alt"></i></div>
                    <h3>Identity Theft: Freeze Your Credit & More</h3>
                    <p class="article-brief">Step‑by‑step guide to credit freezes, fraud alerts, and monitoring services – essential protection.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 10 min read</span>
                        <a href="#" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-calendar-times"></i></div>
                    <h3>Late Payments: Real Impact & Recovery</h3>
                    <p class="article-brief">How a single late payment affects your score, and what to do if you’ve already missed one.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 7 min read</span>
                        <a href="#" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-chart-pie"></i></div>
                    <h3>Debt-to-Income Ratio: Why Lenders Care</h3>
                    <p class="article-brief">Calculate your DTI, understand how it affects loan approvals, and learn strategies to improve it.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 6 min read</span>
                        <a href="#" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
            </div>
        </div>

        <!-- ===== PHASE 3 – PRACTICAL EXECUTION ===== -->
        <div class="phase-wrapper animate">
            <div class="phase-title">
                <span class="phase-number">3</span>
                <span>Practical Execution · Take action on debt & credit</span>
            </div>
            <div class="article-grid">
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-rocket"></i></div>
                    <h3>Avalanche vs. Snowball: Choose Your Weapon</h3>
                    <p class="article-brief">Detailed comparison of the maths‑optimal avalanche and the motivational snowball. Pick the one you’ll stick with.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 9 min read</span>
                        <a href="#" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-file-signature"></i></div>
                    <h3>How to Dispute Errors on Your Credit Report</h3>
                    <p class="article-brief">Sample letters and step‑by‑step process to remove inaccurate information with credit bureaus.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 11 min read</span>
                        <a href="#" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-gem"></i></div>
                    <h3>Credit Card Rewards: How to Win Without Debt</h3>
                    <p class="article-brief">Maximise cashback and points while paying your balance in full every month – the only way rewards make sense.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 8 min read</span>
                        <a href="#" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-hand-holding-usd"></i></div>
                    <h3>Debt Consolidation & Refinancing Options</h3>
                    <p class="article-brief">When to consolidate, balance transfers, personal loans – and when these strategies can backfire.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 10 min read</span>
                        <a href="#" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
            </div>
        </div>

        <!-- ===== PHASE 4 – SKILL BUILDING ===== -->
        <div class="phase-wrapper animate">
            <div class="phase-title">
                <span class="phase-number">4</span>
                <span>Skill Building · Master credit & leverage</span>
            </div>
            <div class="article-grid">
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-seedling"></i></div>
                    <h3>Building Credit From Scratch (No credit history)</h3>
                    <p class="article-brief">Secured cards, credit‑builder loans, and becoming an authorised user – proven methods for newcomers.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 8 min read</span>
                        <a href="#" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-home"></i></div>
                    <h3>Leveraging Good Debt: Mortgages & Student Loans</h3>
                    <p class="article-brief">How to use debt for assets that appreciate or increase your earning power – without over‑leveraging.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 9 min read</span>
                        <a href="#" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-broom"></i></div>
                    <h3>Credit Repair Myths That Actually Work</h3>
                    <p class="article-brief">Separate fact from fiction: what legit repair looks like and why “secret” tricks are usually scams.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 7 min read</span>
                        <a href="#" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-chart-bar"></i></div>
                    <h3>When a Loan Can Actually Make You Richer</h3>
                    <p class="article-brief">Case studies of good leverage – from real estate to business loans – and the safety margins you need.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 10 min read</span>
                        <a href="#" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
            </div>
        </div>

        <!-- call to action – start journey -->
        <div class="journey-cta animate">
            <h2>Take control of your credit today</h2>
            <p style="font-size: 1.2rem; color: #2d3748; margin-bottom: 10px;">No fluff, just a clear path from debt stress to smart leverage.</p>
            <a href="#" class="cta-button"><i class="fas fa-road"></i> Begin the journey now</a>
            <p style="margin-top: 25px; color: #718096;"><i class="fas fa-users"></i> Join 15,000+ members who started here</p>
        </div>
    </div>
{% endblock %}
