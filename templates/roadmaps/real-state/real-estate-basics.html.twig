{# templates/roadmaps/real-state/real-estate-basics.html.twig #}
{% extends 'base-roadmaps.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('real_state_css') }}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('real_state_js') }}
{% endblock %}

{% block body %}
    <div class="container">
        <!-- article hero – real estate style -->
        <div class="article-hero animate" style="background: linear-gradient(135deg, #2f2a24 0%, #5e4b3f 100%);">
            <div class="hero-content">
                <div class="hero-icon" style="background-color: var(--real-estate-color);">
                    <i class="fas fa-home"></i>
                </div>
                <h1>Real Estate Fundamentals <span>What Every Beginner Must Know</span></h1>
                <p class="hero-description">
                    From “what’s a cap rate?” to “how do I even start?” – this guide cuts through the jargon and gives you the solid foundation you need.
                </p>
                <div class="phase-tag" style="background-color: rgba(225,112,85,0.2); color: #f7b9a9;">
                    <i class="fas fa-layer-group"></i> Phase 1: Foundation First · 8 min read
                </div>
            </div>
        </div>

        <!-- introduction -->
        <section class="animate">
            <h2 class="section-title">🧱 Building Your Real Estate Vocabulary</h2>
            <p style="font-size: 1.2rem; margin-bottom: 20px;">
                Real estate can feel like a foreign language. <strong>Amortization, escrow, cash flow, leverage…</strong>
                This article decodes the essential concepts so you can confidently evaluate your first property.
            </p>
        </section>

        <!-- key reasons in rule‑grid style (like real_state.css) -->
        <div class="rule-grid animate">
            <div class="rule-item">
                <h4><i class="fas fa-map-pin"></i> Location, Location, Location</h4>
                <p>A great property in a bad area will underperform. Learn how neighborhood trends, schools, and amenities drive value.</p>
            </div>
            <div class="rule-item">
                <h4><i class="fas fa-hand-holding-usd"></i> Cash Flow is King</h4>
                <p>For investors, monthly income after expenses matters more than appreciation. Understand gross yield, net yield, and the 1% rule.</p>
            </div>
            <div class="rule-item">
                <h4><i class="fas fa-chart-line"></i> Leverage Amplifies Returns</h4>
                <p>Using a mortgage lets you control a large asset with a small down payment. But leverage works both ways – it magnifies gains and losses.</p>
            </div>
        </div>

        <!-- interactive tool: Home Affordability Calculator -->
        <div class="card animate" style="margin: 40px 0;" id="real-estate-basics-tool">
            <h3><i class="fas fa-calculator"></i> Interactive: How Much Home Can You Afford?</h3>
            <p>Adjust the sliders to see a realistic price range based on your income, debts, and down payment.</p>

            <div style="display: flex; flex-wrap: wrap; gap: 20px; margin: 20px 0;">
                <div style="flex: 1 1 200px;">
                    <label>Annual income ($) <span id="incomeVal">75000</span></label>
                    <input type="range" id="annualIncome" min="20000" max="300000" value="75000" step="1000" class="cat-input" style="width:100%;">
                </div>
                <div style="flex: 1 1 200px;">
                    <label>Down payment ($) <span id="downpaymentVal">20000</span></label>
                    <input type="range" id="downpayment" min="0" max="200000" value="20000" step="1000" class="cat-input" style="width:100%;">
                </div>
                <div style="flex: 1 1 200px;">
                    <label>Monthly debts ($) <span id="debtsVal">500</span></label>
                    <input type="range" id="monthlyDebts" min="0" max="5000" value="500" step="50" class="cat-input" style="width:100%;">
                </div>
                <div style="flex: 1 1 200px;">
                    <label>Interest rate (%) <span id="rateVal">6.5</span></label>
                    <input type="range" id="interestRate" min="2" max="10" value="6.5" step="0.125" class="cat-input" style="width:100%;">
                </div>
                <div style="flex: 1 1 200px;">
                    <label>Loan term (years) </label>
                    <select id="loanTerm" class="cat-input" style="width:100%;">
                        <option value="15">15 years</option>
                        <option value="30" selected>30 years</option>
                    </select>
                </div>
            </div>

            <div style="margin-top: 20px;">
                <button id="calculateAffordability" class="btn-outline">Estimate your home price</button>
            </div>

            <div id="affordabilityResult" style="margin-top: 25px; padding: 20px; background: var(--light-color); border-radius: 12px;">
                <p>Adjust the values and click the button.</p>
            </div>

            <p class="pro-tip" style="margin-top: 15px; background-color: #fff1eb; border-left-color: var(--real-estate-color);">
                <i class="fas fa-lightbulb"></i> This calculator uses the 28/36 rule: housing expenses (PITI) should not exceed 28% of gross income, and total debt payments not more than 36%. Property taxes and insurance are estimated at 1.25% of home price annually.
            </p>
        </div>

        <!-- quiz section (conditional) -->
        {% if app.user and quiz is defined and quiz %}
            {# Logged in user – quiz already taken #}
            <div class="quiz-container animate" style="background: #2f2a24;">
                <h3 style="color:white; margin-top: 0;">🧠 You've already taken this quiz</h3>
                <p style="color: #e2e8f0; font-size: 1.2rem;">
                    Your score: <strong>{{ quiz.quizzScore }}%</strong>
                </p>
                <p style="color: #cbd5e0;">
                    You can retake the quiz to improve your score. Click the button below to reset it.
                </p>
                <div class="quiz-actions">
                    <a href="{{ path('app_page_show', { journey: 'real-state', slug: 'real-estate-basics', retake: 1 }) }}"
                       class="btn"
                       style="background-color: #e17055; color: white; text-decoration: none;">
                        Retake Quiz
                    </a>
                </div>
            </div>
        {% else %}
            {# Show quiz (interactivity blocked by JS if not logged in) #}
            <div class="quiz-container animate" data-page-id="{{ page.id }}" style="background: #2f2a24;">
                <h3 style="color:white; margin-top: 0;">📝 Test your knowledge: Real Estate Fundamentals</h3>

                <div class="quiz-question">1. What does “cash flow” mean in real estate investing?</div>
                <div class="quiz-options" data-question="1">
                    <div class="quiz-option" data-answer="wrong">The profit you make when you sell</div>
                    <div class="quiz-option" data-answer="correct">Rental income minus all operating expenses</div>
                    <div class="quiz-option" data-answer="wrong">The mortgage principal paid each month</div>
                    <div class="quiz-option" data-answer="wrong">Property appreciation</div>
                </div>

                <div class="quiz-question">2. Which of the following is NOT typically included in operating expenses for a rental property?</div>
                <div class="quiz-options" data-question="2">
                    <div class="quiz-option" data-answer="wrong">Property taxes</div>
                    <div class="quiz-option" data-answer="wrong">Insurance</div>
                    <div class="quiz-option" data-answer="wrong">Maintenance</div>
                    <div class="quiz-option" data-answer="correct">Mortgage principal payments</div>
                </div>

                <div class="quiz-question">3. The “1% rule” suggests that monthly rent should be at least what percentage of the purchase price?</div>
                <div class="quiz-options" data-question="3">
                    <div class="quiz-option" data-answer="wrong">0.5%</div>
                    <div class="quiz-option" data-answer="correct">1%</div>
                    <div class="quiz-option" data-answer="wrong">2%</div>
                    <div class="quiz-option" data-answer="wrong">5%</div>
                </div>

                <div class="quiz-question">4. What is a REIT?</div>
                <div class="quiz-options" data-question="4">
                    <div class="quiz-option" data-answer="wrong">A government grant for first‑time buyers</div>
                    <div class="quiz-option" data-answer="correct">A company that owns and operates income‑producing real estate</div>
                    <div class="quiz-option" data-answer="wrong">A type of mortgage insurance</div>
                    <div class="quiz-option" data-answer="wrong">A real estate appraisal method</div>
                </div>

                <div class="quiz-question">5. Leverage in real estate refers to:</div>
                <div class="quiz-options" data-question="5">
                    <div class="quiz-option" data-answer="wrong">Using a property manager</div>
                    <div class="quiz-option" data-answer="correct">Using borrowed money to increase potential returns</div>
                    <div class="quiz-option" data-answer="wrong">The physical act of lifting heavy objects during renovation</div>
                    <div class="quiz-option" data-answer="wrong">Negotiating the purchase price</div>
                </div>

                <div class="quiz-actions">
                    <button id="quiz-submit" class="btn" style="background-color: var(--real-estate-color);">Get score & submit</button>
                </div>
                <div class="quiz-result"></div>
            </div>
        {% endif %}

        <!-- next steps in Phase 1 (Foundation First) -->
        <section style="margin: 60px 0;">
            <h2 class="section-title" style="text-align: center;">📘 Continue Phase 1: Foundation First</h2>
            <div class="next-steps">
                <a href="{{ path('app_page_show', { journey: 'real-state', slug: 'rent-vs-buy' }) }}" class="next-card">
                    <i class="fas fa-scale-balanced"></i>
                    <h3>Rent vs. Buy</h3>
                    <p>Make the right decision for your life and finances.</p>
                </a>
                <a href="{{ path('app_page_show', { journey: 'real-state', slug: 'evaluating-property' }) }}" class="next-card">
                    <i class="fas fa-calculator"></i>
                    <h3>How to Evaluate a Property</h3>
                    <p>Cap rate, cash flow, ROI – demystified.</p>
                </a>
                <a href="{{ path('app_page_show', { journey: 'real-state', slug: 'reits-explained' }) }}" class="next-card">
                    <i class="fas fa-chart-pie"></i>
                    <h3>REITs Explained</h3>
                    <p>Invest without buying physical property.</p>
                </a>
            </div>
        </section>
    </div>
{% endblock %}
