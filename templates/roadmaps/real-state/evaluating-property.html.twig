{# templates/roadmaps/real-state/evaluating-property.html.twig #}
{% extends 'base-roadmaps.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('real_state_css') }}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('real_state_js') }}
{% endblock %}

{% block body %}
    <div class="container">
        <!-- Article Hero -->
        <div class="article-hero animate" style="background: linear-gradient(135deg, #2f2a24 0%, #5e4b3f 100%);">
            <div class="hero-content">
                <div class="hero-icon" style="background-color: var(--real-estate-color);">
                    <i class="fas fa-calculator"></i>
                </div>
                <h1>How to Evaluate a Property <span>Cap Rate, Cash Flow, ROI</span></h1>
                <p class="hero-description">
                    Stop guessing and start calculating. Learn the three essential metrics every real estate investor uses to analyze deals and compare properties.
                </p>
                <div class="phase-tag" style="background-color: rgba(225,112,85,0.2); color: #f7b9a9;">
                    <i class="fas fa-layer-group"></i> Phase 1: Foundation First · 10 min read
                </div>
            </div>
        </div>

        <!-- Introduction -->
        <section class="animate">
            <h2 class="section-title">📊 The Language of Real Estate Analysis</h2>
            <p style="font-size: 1.2rem; margin-bottom: 20px;">
                Whether you're looking at a duplex or a 20‑unit apartment building, the numbers tell the story.
                <strong>Cap rate, cash flow, and ROI</strong> are the three pillars of property evaluation.
                Master them, and you'll never overpay for an investment again.
            </p>
        </section>

        <!-- Key Metrics Grid -->
        <div class="rule-grid animate">
            <div class="rule-item">
                <h4><i class="fas fa-percent"></i> Cap Rate</h4>
                <p><strong>Net Operating Income (NOI) ÷ Property Value</strong><br>Measures the unleveraged return of a property. A higher cap rate means higher risk and potentially higher return. Useful for comparing properties regardless of financing.</p>
            </div>
            <div class="rule-item">
                <h4><i class="fas fa-hand-holding-usd"></i> Cash Flow</h4>
                <p><strong>Rental Income – All Expenses (including mortgage)</strong><br>The money left in your pocket each month. Positive cash flow = passive income. Negative cash flow = you're subsidizing the tenant.</p>
            </div>
            <div class="rule-item">
                <h4><i class="fas fa-chart-line"></i> ROI (Return on Investment)</h4>
                <p><strong>Annual Return ÷ Total Cash Invested</strong><br>Also called cash‑on‑cash return. Shows how efficiently your money is working. A 10% ROI means you earn $10 for every $100 invested.</p>
            </div>
        </div>

        <!-- Deeper Dive -->
        <div class="card animate">
            <h3><i class="fas fa-magnifying-glass-chart"></i> Breaking Down the Metrics</h3>
            <p><strong>Cap Rate</strong> ignores financing – it's the property's raw earning power. <strong>Cash flow</strong> depends on your loan terms – a great deal can turn bad with high interest. <strong>ROI</strong> tells you how fast you get your money back. Use all three together.</p>
            <p style="background: var(--light-gray); padding: 15px; border-radius: 12px;">
                <strong>Example:</strong> A $200,000 property with $20,000 NOI has a 10% cap rate. With 20% down ($40,000) and a mortgage, monthly cash flow might be $300, giving an ROI of ($3,600 / $40,000) = 9%.
            </p>
        </div>

        <!-- Interactive Tool: Property Analyzer (disabled for non-logged-in) -->
        <div class="card animate" id="property-analyzer">
            <h3><i class="fas fa-chart-pie"></i> Interactive: Rental Property Analyzer</h3>
            <p>Enter the details below to calculate cap rate, monthly cash flow, and ROI.</p>

            <div style="display: flex; flex-wrap: wrap; gap: 20px; margin: 20px 0;">
                <div style="flex: 1 1 200px;">
                    <label>Purchase Price ($) <span id="priceVal">200000</span></label>
                    <input type="range" id="purchasePrice" min="50000" max="1000000" value="200000" step="5000" class="cat-input" style="width:100%;">
                </div>
                <div style="flex: 1 1 200px;">
                    <label>Down Payment (%) <span id="downPercentVal2">20</span></label>
                    <input type="range" id="downPercent2" min="3" max="50" value="20" step="1" class="cat-input" style="width:100%;">
                </div>
                <div style="flex: 1 1 200px;">
                    <label>Interest Rate (%) <span id="rateVal2">6.5</span></label>
                    <input type="range" id="interestRate2" min="2" max="10" value="6.5" step="0.125" class="cat-input" style="width:100%;">
                </div>
                <div style="flex: 1 1 200px;">
                    <label>Loan Term (years) </label>
                    <select id="loanTerm2" class="cat-input" style="width:100%;">
                        <option value="15">15 years</option>
                        <option value="30" selected>30 years</option>
                    </select>
                </div>
                <div style="flex: 1 1 200px;">
                    <label>Monthly Rent ($) <span id="rentVal2">1800</span></label>
                    <input type="range" id="monthlyRent2" min="500" max="5000" value="1800" step="50" class="cat-input" style="width:100%;">
                </div>
                <div style="flex: 1 1 200px;">
                    <label>Property Tax (%/year) <span id="taxVal2">1.0</span></label>
                    <input type="range" id="propTax2" min="0.5" max="3" value="1.0" step="0.1" class="cat-input" style="width:100%;">
                </div>
                <div style="flex: 1 1 200px;">
                    <label>Insurance ($/year) <span id="insVal2">1200</span></label>
                    <input type="range" id="insurance2" min="300" max="5000" value="1200" step="100" class="cat-input" style="width:100%;">
                </div>
                <div style="flex: 1 1 200px;">
                    <label>Maintenance (%/year) <span id="maintVal2">1.0</span></label>
                    <input type="range" id="maintenance2" min="0.5" max="3" value="1.0" step="0.1" class="cat-input" style="width:100%;">
                </div>
                <div style="flex: 1 1 200px;">
                    <label>Vacancy Rate (%) <span id="vacancyVal2">5</span></label>
                    <input type="range" id="vacancy2" min="0" max="20" value="5" step="1" class="cat-input" style="width:100%;">
                </div>
                <div style="flex: 1 1 200px;">
                    <label>Other Monthly Expenses ($) <span id="otherVal2">100</span></label>
                    <input type="range" id="other2" min="0" max="1000" value="100" step="25" class="cat-input" style="width:100%;">
                </div>
            </div>

            <div style="margin-top: 20px;">
                <button id="analyzeProperty" class="btn-outline">Analyze Property</button>
            </div>

            <div id="propertyResult" style="margin-top: 25px; padding: 20px; background: var(--light-color); border-radius: 12px;">
                <p>Adjust the values and click the button.</p>
            </div>

            <p class="pro-tip" style="margin-top: 15px;">
                <i class="fas fa-lightbulb"></i> This calculator uses standard formulas: NOI = (rent × 12 × (1‑vacancy)) – (tax + insurance + maintenance + other). Cash flow = NOI – mortgage payments. ROI = (annual cash flow / total cash invested) × 100%. Cap rate = NOI / purchase price.
            </p>
        </div>

        <!-- Quiz Section -->
        {% if app.user and quiz is defined and quiz %}
            {# Logged in user – quiz already taken #}
            <div class="quiz-container animate" style="background: #2f2a24;">
                <h3 style="color:white; margin-top: 0;">🧠 You've already taken this quiz</h3>
                <p style="color: #e2e8f0; font-size: 1.2rem;">
                    Your score: <strong>{{ quiz.quizzScore }}%</strong>
                </p>
                <p style="color: #cbd5e0;">
                    You can retake the quiz to improve your score. Click the button below to reset it.
                </p>
                <div class="quiz-actions">
                    <a href="{{ path('app_page_show', { journey: 'real-state', slug: 'evaluating-property', retake: 1 }) }}"
                       class="btn"
                       style="background-color: #e17055; color: white; text-decoration: none;">
                        Retake Quiz
                    </a>
                </div>
            </div>
        {% else %}
            {# Show quiz (interactivity blocked by JS if not logged in) #}
            <div class="quiz-container animate" data-page-id="{{ page.id }}" style="background: #2f2a24;">
                <h3 style="color:white; margin-top: 0;">📝 Test Your Knowledge: Property Evaluation</h3>

                <div class="quiz-question">1. What does cap rate measure?</div>
                <div class="quiz-options" data-question="1">
                    <div class="quiz-option" data-answer="wrong">The property's return after financing</div>
                    <div class="quiz-option" data-answer="correct">The unleveraged return based on net operating income</div>
                    <div class="quiz-option" data-answer="wrong">The monthly cash flow</div>
                    <div class="quiz-option" data-answer="wrong">The appreciation potential</div>
                </div>

                <div class="quiz-question">2. Which metric tells you how much cash you'll actually pocket each month?</div>
                <div class="quiz-options" data-question="2">
                    <div class="quiz-option" data-answer="wrong">Cap rate</div>
                    <div class="quiz-option" data-answer="correct">Cash flow</div>
                    <div class="quiz-option" data-answer="wrong">ROI</div>
                    <div class="quiz-option" data-answer="wrong">Gross rent multiplier</div>
                </div>

                <div class="quiz-question">3. If you put $50,000 down on a property and earn $5,000 per year in cash flow, what is your cash‑on‑cash ROI?</div>
                <div class="quiz-options" data-question="3">
                    <div class="quiz-option" data-answer="wrong">5%</div>
                    <div class="quiz-option" data-answer="correct">10%</div>
                    <div class="quiz-option" data-answer="wrong">15%</div>
                    <div class="quiz-option" data-answer="wrong">20%</div>
                </div>

                <div class="quiz-question">4. Which of the following is NOT included in Net Operating Income (NOI)?</div>
                <div class="quiz-options" data-question="4">
                    <div class="quiz-option" data-answer="wrong">Property taxes</div>
                    <div class="quiz-option" data-answer="wrong">Insurance</div>
                    <div class="quiz-option" data-answer="correct">Mortgage principal and interest</div>
                    <div class="quiz-option" data-answer="wrong">Maintenance</div>
                </div>

                <div class="quiz-question">5. A property has a high cap rate (e.g., 12%) compared to similar properties (8%). This likely indicates:</div>
                <div class="quiz-options" data-question="5">
                    <div class="quiz-option" data-answer="wrong">It's a safer investment</div>
                    <div class="quiz-option" data-answer="correct">It's riskier or in a less desirable area</div>
                    <div class="quiz-option" data-answer="wrong">Financing terms are very favorable</div>
                    <div class="quiz-option" data-answer="wrong">It has no mortgage</div>
                </div>

                <div class="quiz-actions">
                    <button id="quiz-submit" class="btn" style="background-color: var(--real-estate-color);">Get score & submit</button>
                </div>
                <div class="quiz-result"></div>
            </div>
        {% endif %}

        <!-- Next Steps in Phase 1 -->
        <section style="margin: 60px 0;">
            <h2 class="section-title" style="text-align: center;">📘 Continue Phase 1: Foundation First</h2>
            <div class="next-steps">
                <a href="{{ path('app_page_show', { journey: 'real-state', slug: 'real-estate-basics' }) }}" class="next-card">
                    <i class="fas fa-school"></i>
                    <h3>Real Estate Fundamentals</h3>
                    <p>Learn key terms and concepts every beginner must know.</p>
                </a>
                <a href="{{ path('app_page_show', { journey: 'real-state', slug: 'rent-vs-buy' }) }}" class="next-card">
                    <i class="fas fa-scale-balanced"></i>
                    <h3>Rent vs. Buy</h3>
                    <p>Make the right decision for your life and finances.</p>
                </a>
                <a href="{{ path('app_page_show', { journey: 'real-state', slug: 'reits-explained' }) }}" class="next-card">
                    <i class="fas fa-chart-pie"></i>
                    <h3>REITs Explained</h3>
                    <p>Invest without buying physical property.</p>
                </a>
            </div>
        </section>
    </div>
{% endblock %}
