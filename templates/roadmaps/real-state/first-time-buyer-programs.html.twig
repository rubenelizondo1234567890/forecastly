{# templates/roadmaps/real-state/first-time-buyer-programs.html.twig #}
{% extends 'base-roadmaps.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('real_state_css') }}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('real_state_js') }}
{% endblock %}

{% block body %}
    <div class="container">
        <!-- Article Hero -->
        <div class="article-hero animate" style="background: linear-gradient(135deg, #2f2a24 0%, #5e4b3f 100%);">
            <div class="hero-content">
                <div class="hero-icon" style="background-color: var(--real-estate-color);">
                    <i class="fas fa-hand-holding-heart"></i>
                </div>
                <h1>First‑Time Homebuyer Programs <span>and Grants</span></h1>
                <p class="hero-description">
                    Many buyers leave money on the table. Discover down payment assistance programs, tax credits, and grants available to first‑time buyers – and see what you might qualify for.
                </p>
                <div class="phase-tag" style="background-color: rgba(225,112,85,0.2); color: #f7b9a9;">
                    <i class="fas fa-layer-group"></i> Phase 3: Practical Execution · 6 min read
                </div>
            </div>
        </div>

        <!-- Introduction -->
        <section class="animate">
            <h2 class="section-title">🎁 Don't Leave Free Money on the Table</h2>
            <p style="font-size: 1.2rem; margin-bottom: 20px;">
                First‑time homebuyer programs can reduce your down payment, lower your interest rate, or even give you cash for closing costs.
                <strong>Millions of dollars in assistance go unclaimed every year</strong> because buyers don't know they exist. This guide helps you find them.
            </p>
        </section>

        <!-- Key Programs Grid -->
        <div class="rule-grid animate">
            <div class="rule-item">
                <h4><i class="fas fa-building"></i> FHA Loans</h4>
                <p>3.5% down, credit score as low as 580. Mortgage insurance required. Popular with first‑time buyers.</p>
            </div>
            <div class="rule-item">
                <h4><i class="fas fa-home"></i> Conventional 97</h4>
                <p>3% down for first‑time buyers. Requires 620+ credit. Private mortgage insurance (PMI) if less than 20% down.</p>
            </div>
            <div class="rule-item">
                <h4><i class="fas fa-shield"></i> VA Loans</h4>
                <p>0% down, no PMI, competitive rates. For veterans, active duty, and some military spouses. Funding fee applies.</p>
            </div>
            <div class="rule-item">
                <h4><i class="fas fa-tree"></i> USDA Loans</h4>
                <p>0% down for rural and some suburban areas. Income limits apply. Guarantee fee instead of PMI.</p>
            </div>
        </div>

        <!-- Down Payment Assistance Card -->
        <div class="card animate">
            <h3><i class="fas fa-piggy-bank"></i> Down Payment Assistance (DPA) Programs</h3>
            <p>Many states, counties, and nonprofits offer grants or low‑interest loans to help with down payment and closing costs. These are often combined with FHA, conventional, or USDA loans.</p>
            <p><strong>Examples:</strong> FHA DPA loans (up to 5% of purchase price), state housing authority grants (e.g., $5,000–$15,000), and employer‑assisted housing benefits.</p>
            <p style="background: var(--light-gray); padding: 15px; border-radius: 12px;">
                <strong>Pro Tip:</strong> Check with your state's housing finance agency (HFA) and local nonprofits. Some programs are income‑limited and require a homebuyer education course.
            </p>
        </div>

        <!-- Interactive Tool: First‑Time Buyer Assistance Finder (disabled for non-logged-in) -->
        <div class="card animate" id="assistance-finder">
            <h3><i class="fas fa-magnifying-glass"></i> Interactive: First‑Time Buyer Assistance Finder</h3>
            <p>Answer a few questions to see which programs you might qualify for and estimate your potential savings.</p>

            <div style="display: flex; flex-wrap: wrap; gap: 20px; margin: 20px 0;">
                <div style="flex: 1 1 200px;">
                    <label>State (example)</label>
                    <select id="stateSelect" class="cat-input" style="width:100%;">
                        <option value="CA">California</option>
                        <option value="TX">Texas</option>
                        <option value="NY">New York</option>
                        <option value="FL">Florida</option>
                        <option value="IL">Illinois</option>
                        <option value="OH">Ohio</option>
                        <option value="GA">Georgia</option>
                        <option value="NC">North Carolina</option>
                        <option value="MI">Michigan</option>
                        <option value="PA">Pennsylvania</option>
                        <option value="other">Other</option>
                    </select>
                </div>
                <div style="flex: 1 1 200px;">
                    <label>Annual Income ($) <span id="incomeValAssist">60000</span></label>
                    <input type="range" id="incomeAssist" min="20000" max="200000" value="60000" step="1000" class="cat-input" style="width:100%;">
                </div>
                <div style="flex: 1 1 200px;">
                    <label>Credit Score <span id="creditValAssist">680</span></label>
                    <input type="range" id="creditAssist" min="500" max="850" value="680" step="10" class="cat-input" style="width:100%;">
                </div>
                <div style="flex: 1 1 200px;">
                    <label>Military Service?</label>
                    <select id="militaryAssist" class="cat-input" style="width:100%;">
                        <option value="no">No</option>
                        <option value="yes">Yes (Veteran/Active)</option>
                    </select>
                </div>
                <div style="flex: 1 1 200px;">
                    <label>Property Location</label>
                    <select id="locationAssist" class="cat-input" style="width:100%;">
                        <option value="urban">Urban/Suburban</option>
                        <option value="rural">Rural (USDA eligible)</option>
                    </select>
                </div>
            </div>

            <div style="margin-top: 20px;">
                <button id="findAssistance" class="btn-outline">Find Programs</button>
            </div>

            <div id="assistanceResult" style="margin-top: 25px; padding: 20px; background: var(--light-color); border-radius: 12px;">
                <p>Adjust the values and click the button.</p>
            </div>

            <p class="pro-tip" style="margin-top: 15px;">
                <i class="fas fa-lightbulb"></i> This tool provides a simulation based on common national programs. Actual eligibility depends on specific program rules, lender participation, and funding availability. Always verify with local housing agencies.
            </p>
        </div>

        <!-- Quiz Section -->
        {% if app.user and quiz is defined and quiz %}
            {# Logged in user – quiz already taken #}
            <div class="quiz-container animate" style="background: #2f2a24;">
                <h3 style="color:white; margin-top: 0;">🧠 You've already taken this quiz</h3>
                <p style="color: #e2e8f0; font-size: 1.2rem;">
                    Your score: <strong>{{ quiz.quizzScore }}%</strong>
                </p>
                <p style="color: #cbd5e0;">
                    You can retake the quiz to improve your score. Click the button below to reset it.
                </p>
                <div class="quiz-actions">
                    <a href="{{ path('app_page_show', { journey: 'real-state', slug: 'first-time-buyer-programs', retake: 1 }) }}"
                       class="btn"
                       style="background-color: #e17055; color: white; text-decoration: none;">
                        Retake Quiz
                    </a>
                </div>
            </div>
        {% else %}
            {# Show quiz (interactivity blocked by JS if not logged in) #}
            <div class="quiz-container animate" data-page-id="{{ page.id }}" style="background: #2f2a24;">
                <h3 style="color:white; margin-top: 0;">📝 Test Your Knowledge: First‑Time Buyer Programs</h3>

                <div class="quiz-question">1. What is the minimum down payment for an FHA loan?</div>
                <div class="quiz-options" data-question="1">
                    <div class="quiz-option" data-answer="wrong">5%</div>
                    <div class="quiz-option" data-answer="correct">3.5%</div>
                    <div class="quiz-option" data-answer="wrong">0%</div>
                    <div class="quiz-option" data-answer="wrong">10%</div>
                </div>

                <div class="quiz-question">2. Which loan program is exclusively for veterans and active military?</div>
                <div class="quiz-options" data-question="2">
                    <div class="quiz-option" data-answer="wrong">FHA</div>
                    <div class="quiz-option" data-answer="correct">VA</div>
                    <div class="quiz-option" data-answer="wrong">USDA</div>
                    <div class="quiz-option" data-answer="wrong">Conventional</div>
                </div>

                <div class="quiz-question">3. USDA loans are available only in __________ areas.</div>
                <div class="quiz-options" data-question="3">
                    <div class="quiz-option" data-answer="wrong">Urban</div>
                    <div class="quiz-option" data-answer="correct">Rural (and some suburban)</div>
                    <div class="quiz-option" data-answer="wrong">Coastal</div>
                    <div class="quiz-option" data-answer="wrong">High‑cost</div>
                </div>

                <div class="quiz-question">4. Down payment assistance (DPA) programs typically come from:</div>
                <div class="quiz-options" data-question="4">
                    <div class="quiz-option" data-answer="wrong">The federal government only</div>
                    <div class="quiz-option" data-answer="correct">State and local housing agencies</div>
                    <div class="quiz-option" data-answer="wrong">Private banks exclusively</div>
                    <div class="quiz-option" data-answer="wrong">Employers only</div>
                </div>

                <div class="quiz-question">5. True or False: You can combine a down payment assistance grant with an FHA loan.</div>
                <div class="quiz-options" data-question="5">
                    <div class="quiz-option" data-answer="correct">True</div>
                    <div class="quiz-option" data-answer="wrong">False</div>
                </div>

                <div class="quiz-actions">
                    <button id="quiz-submit" class="btn" style="background-color: var(--real-estate-color);">Get score & submit</button>
                </div>
                <div class="quiz-result"></div>
            </div>
        {% endif %}

        <!-- Next Steps in Phase 3 -->
        <section style="margin: 60px 0;">
            <h2 class="section-title" style="text-align: center;">📘 Continue Phase 3: Practical Execution</h2>
            <div class="next-steps">
                <a href="{{ path('app_page_show', { journey: 'real-state', slug: 'saving-for-down-payment' }) }}" class="next-card">
                    <i class="fas fa-piggy-bank"></i>
                    <h3>Saving for Your Down Payment</h3>
                    <p>A step‑by‑step plan to build your fund.</p>
                </a>
                <a href="{{ path('app_page_show', { journey: 'real-state', slug: 'mortgage-guide' }) }}" class="next-card">
                    <i class="fas fa-file-signature"></i>
                    <h3>How to Get a Mortgage</h3>
                    <p>Credit, pre‑approval, and loan types.</p>
                </a>
                <a href="{{ path('app_page_show', { journey: 'real-state', slug: 'analyze-rental-property' }) }}" class="next-card">
                    <i class="fas fa-chart-simple"></i>
                    <h3>How to Analyze a Rental Property</h3>
                    <p>A practical template for investors.</p>
                </a>
            </div>
        </section>
    </div>
{% endblock %}
