{# templates/roadmaps/career-capital/self-assessment.html.twig #}
{% extends 'base-roadmaps.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('career_capital_css') }}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('career_capital_js') }}
{% endblock %}

{% block body %}
    <div class="container">
        <!-- article hero -->
        <div class="article-hero animate" style="background: linear-gradient(135deg, #1a202c 0%, #2d3748 100%);">
            <div class="hero-content">
                <div class="hero-icon" style="font-size: 3rem; margin-bottom: 20px;">
                    <i class="fas fa-smile" style="color: var(--career-color);"></i>
                </div>
                <h1>Self‑Assessment <span>Discover Your Natural Advantages</span></h1>
                <p class="hero-description">
                    Worksheets and prompts to uncover your strengths, interests, and the skills you can build fastest — so you don’t fight your nature.
                </p>
                <div class="phase-tag" style="background-color: rgba(156,136,255,0.2); color: #c3b9ff;">
                    <i class="fas fa-layer-group"></i> Phase 1: Foundation First · 12 min read
                </div>
            </div>
        </div>

        <!-- introduction -->
        <section class="animate">
            <h2 class="section-title">Why Self‑Assessment Matters</h2>
            <p style="font-size: 1.2rem; margin-bottom: 20px;">
                Building career capital is not about forcing yourself into a mould — it’s about amplifying what you’re already good at. When you align skill development with your natural advantages, learning becomes faster, more enjoyable, and more sustainable.
            </p>
            <p>
                Most people try to fix weaknesses. The most successful professionals double down on strengths. This self‑assessment will help you identify the areas where you have the highest potential to excel.
            </p>
        </section>

        <!-- four strength domains (like rule-grid) -->
        <div class="rule-grid animate" style="grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));">
            <div class="rule-item" style="border-top-color: var(--career-color);">
                <h3><i class="fas fa-brain"></i> Analytical Thinking</h3>
                <div class="percentage" style="color: var(--career-color);">problem solver</div>
                <p>You enjoy data, logic, and systems. You naturally spot patterns, troubleshoot, and make decisions based on evidence.</p>
            </div>
            <div class="rule-item" style="border-top-color: var(--career-color);">
                <h3><i class="fas fa-paint-brush"></i> Creativity</h3>
                <div class="percentage" style="color: var(--career-color);">idea generator</div>
                <p>You love coming up with new concepts, designing, writing, or visualizing. You see possibilities others miss.</p>
            </div>
            <div class="rule-item" style="border-top-color: var(--career-color);">
                <h3><i class="fas fa-handshake"></i> Social Intelligence</h3>
                <div class="percentage" style="color: var(--career-color);">people connector</div>
                <p>You empathize easily, communicate clearly, and build trust. Networking, teamwork, and persuasion come naturally.</p>
            </div>
            <div class="rule-item" style="border-top-color: var(--career-color);">
                <h3><i class="fas fa-tasks"></i> Organizational Skills</h3>
                <div class="percentage" style="color: var(--career-color);">execution master</div>
                <p>You thrive on structure, planning, and follow‑through. You keep projects on track and details in order.</p>
            </div>
        </div>

        <!-- interactive self‑assessment tool -->
        <div class="calc-card animate" style="border: 1px solid rgba(156,136,255,0.3);">
            <h2 class="calc-title"><i class="fas fa-sliders-h" style="color: var(--career-color); margin-right: 10px;"></i> Natural Advantage Finder</h2>
            <p style="font-size: 1.1rem;">Rate yourself on each domain (0 = not like me, 10 = very much like me). Then click to see your strongest area.</p>

            <div class="calc-input">
                <label>Analytical Thinking</label>
                <div style="display: flex; align-items: center; gap: 20px; flex-wrap: wrap;">
                    <div style="flex:3; min-width:250px;">
                        <input type="range" id="analytical" class="cat-input" min="0" max="10" value="5" step="1">
                    </div>
                    <span class="slider-value" id="analyticalVal">5</span>
                </div>
            </div>
            <div class="calc-input">
                <label>Creativity</label>
                <div style="display: flex; align-items: center; gap: 20px; flex-wrap: wrap;">
                    <div style="flex:3; min-width:250px;">
                        <input type="range" id="creative" class="cat-input" min="0" max="10" value="5" step="1">
                    </div>
                    <span class="slider-value" id="creativeVal">5</span>
                </div>
            </div>
            <div class="calc-input">
                <label>Social Intelligence</label>
                <div style="display: flex; align-items: center; gap: 20px; flex-wrap: wrap;">
                    <div style="flex:3; min-width:250px;">
                        <input type="range" id="social" class="cat-input" min="0" max="10" value="5" step="1">
                    </div>
                    <span class="slider-value" id="socialVal">5</span>
                </div>
            </div>
            <div class="calc-input">
                <label>Organizational Skills</label>
                <div style="display: flex; align-items: center; gap: 20px; flex-wrap: wrap;">
                    <div style="flex:3; min-width:250px;">
                        <input type="range" id="organizational" class="cat-input" min="0" max="10" value="5" step="1">
                    </div>
                    <span class="slider-value" id="organizationalVal">5</span>
                </div>
            </div>

            <div style="margin: 30px 0; text-align: center;">
                <button id="strengthsCalculate" class="btn" style="background-color: var(--career-color);">Reveal my top strength</button>
            </div>

            <div class="calc-result" style="border: 2px dashed var(--career-color);">
                <p class="result-label" style="font-size:1.2rem;">🔍 Your natural advantage</p>
                <div id="strengthsResult" style="font-size:1.5rem; font-weight:600; color:var(--dark-color);">✨ Adjust the sliders to discover your strongest area.</div>
            </div>

            <script>
                // Live update for displayed values even if not logged in
                document.querySelectorAll('.calc-input input[type=range]').forEach(slider => {
                    const display = document.getElementById(slider.id + 'Val');
                    if (display) {
                        slider.addEventListener('input', () => { display.textContent = slider.value; });
                    }
                });
            </script>
        </div>

        <!-- deeper reflection prompts -->
        <div class="card animate" style="border-top: 4px solid var(--career-color);">
            <h3 style="font-size: 1.8rem; margin-bottom: 20px;">Reflection Questions</h3>
            <p style="margin-bottom: 20px;">Take a few minutes to journal your answers — they’ll guide your skill‑building journey.</p>
            <ul class="checklist">
                <li><i class="fas fa-check-circle"></i> What activities make you lose track of time?</li>
                <li><i class="fas fa-check-circle"></i> What do people often ask you for help with?</li>
                <li><i class="fas fa-check-circle"></i> Think of a recent win — what strengths did you use?</li>
                <li><i class="fas fa-check-circle"></i> Which of the four domains energises you most?</li>
                <li><i class="fas fa-check-circle"></i> What would you do even if you weren’t paid?</li>
            </ul>
        </div>

        <!-- tips for leveraging strengths -->
        <section class="animate">
            <h2 class="section-title">🔧 How to Build on Your Advantages</h2>
            <ul class="tip-list">
                <li><i class="fas fa-check-circle"></i> <strong>Choose skills that align:</strong> If you’re analytical, consider data analysis, financial modelling, or programming. If you’re creative, explore copywriting, design, or content creation.</li>
                <li><i class="fas fa-check-circle"></i> <strong>Don’t ignore weaknesses entirely:</strong> Build just enough competency in areas that might hold you back (e.g., basic organisation for creatives).</li>
                <li><i class="fas fa-check-circle"></i> <strong>Seek roles that play to your strengths:</strong> Look for job descriptions that match your natural advantages.</li>
                <li><i class="fas fa-check-circle"></i> <strong>Find mentors in your strength zone:</strong> Connect with people who excel in the same domains and learn from them.</li>
            </ul>
        </section>

        <!-- Quiz section (up to 5 questions) -->
        {% if app.user and quiz %}
            {# Logged in user – quiz already taken #}
            <div class="quiz-container animate" style="background-color: #1e293b;">
                <h3 style="color:white; margin-top: 0;">🧠 You've already taken this quiz</h3>
                <p style="color: #e2e8f0; font-size: 1.2rem;">
                    Your score: <strong>{{ quiz.quizzScore }}%</strong>
                </p>
                <p style="color: #cbd5e0;">
                    You can retake the quiz to improve your score. Click the button below to reset it.
                </p>
                <div class="quiz-actions">
                    <a href="{{ path('app_page_show', { journey: 'career-capital', slug: 'self-assessment', retake: 1 }) }}"
                       class="btn"
                       style="background-color: var(--career-color); color: white; text-decoration: none;">
                        Retake Quiz
                    </a>
                </div>
            </div>
        {% else %}
            {# Quiz for everyone (login modal triggers if not logged in) #}
            <div class="quiz-container animate" data-page-id="{{ page.id }}" style="background-color: #1e293b;">
                <h3 style="color:white; margin-top: 0;">🧠 Quick quiz: discover your self‑assessment knowledge</h3>

                <div class="quiz-question">1. Why is self‑assessment important for career capital?</div>
                <div class="quiz-options" data-question="1">
                    <div class="quiz-option" data-answer="wrong">It helps you fix all your weaknesses</div>
                    <div class="quiz-option" data-answer="correct">It helps you align skill development with natural strengths</div>
                    <div class="quiz-option" data-answer="wrong">It guarantees a high salary</div>
                    <div class="quiz-option" data-answer="wrong">It’s required by employers</div>
                </div>

                <div class="quiz-question">2. Which of the following is one of the four strength domains mentioned?</div>
                <div class="quiz-options" data-question="2">
                    <div class="quiz-option" data-answer="wrong">Athletic ability</div>
                    <div class="quiz-option" data-answer="correct">Social Intelligence</div>
                    <div class="quiz-option" data-answer="wrong">Musical talent</div>
                    <div class="quiz-option" data-answer="wrong">Memory</div>
                </div>

                <div class="quiz-question">3. According to the article, what should you do about weaknesses?</div>
                <div class="quiz-options" data-question="3">
                    <div class="quiz-option" data-answer="wrong">Ignore them completely</div>
                    <div class="quiz-option" data-answer="correct">Build just enough competency so they don’t hold you back</div>
                    <div class="quiz-option" data-answer="wrong">Spend most of your time fixing them</div>
                    <div class="quiz-option" data-answer="wrong">Hide them from everyone</div>
                </div>

                <div class="quiz-question">4. What question can help you identify your natural advantages?</div>
                <div class="quiz-options" data-question="4">
                    <div class="quiz-option" data-answer="wrong">What job pays the most?</div>
                    <div class="quiz-option" data-answer="correct">What activities make you lose track of time?</div>
                    <div class="quiz-option" data-answer="wrong">What did you study in college?</div>
                    <div class="quiz-option" data-answer="wrong">What is your current job title?</div>
                </div>

                <div class="quiz-question">5. If you are highly analytical, which skill might be a good fit?</div>
                <div class="quiz-options" data-question="5">
                    <div class="quiz-option" data-answer="wrong">Copywriting</div>
                    <div class="quiz-option" data-answer="correct">Data analysis</div>
                    <div class="quiz-option" data-answer="wrong">Public speaking</div>
                    <div class="quiz-option" data-answer="wrong">Graphic design</div>
                </div>

                <div class="quiz-actions">
                    <button id="quiz-submit" class="btn" style="background-color: var(--career-color);">Get Score and Submit</button>
                </div>
                <div class="quiz-result"></div>
            </div>
        {% endif %}

        <!-- next articles in Phase 1 -->
        <section style="margin: 60px 0;">
            <h2 class="section-title" style="text-align: center;">Continue your Foundation First phase</h2>
            <div class="next-steps">
                <a href="{{ url('app_page_show', { journey: 'career-capital', slug: 'what-is-career-capital' }) }}" class="next-card" style="border-bottom-color: var(--career-color);">
                    <i class="fas fa-dharmachakra"></i>
                    <h3>What is Career Capital</h3>
                    <p style="color: var(--gray-color);">Understand the three pillars of career capital.</p>
                </a>
                <a href="{{ url('app_page_show', { journey: 'career-capital', slug: 'high-income-skills' }) }}" class="next-card" style="border-bottom-color: var(--career-color);">
                    <i class="fas fa-chart-network"></i>
                    <h3>High‑Income Skills</h3>
                    <p style="color: var(--gray-color);">Discover which skills actually pay and how to choose the right one for you.</p>
                </a>
                <a href="{{ url('app_page_show', { journey: 'career-capital', slug: 'growth-mindset' }) }}" class="next-card" style="border-bottom-color: var(--career-color);">
                    <i class="fas fa-brain"></i>
                    <h3>Growth Mindset</h3>
                    <p style="color: var(--gray-color);">Cultivate resilience and turn setbacks into fuel.</p>
                </a>
            </div>
        </section>
    </div>
{% endblock %}
