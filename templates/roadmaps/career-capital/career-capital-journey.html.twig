{# templates/roadmaps/career-capital/career-capital-journey.html.twig #}
{% extends 'base-roadmaps.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('career_capital_css') }}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('career_capital_js') }}
{% endblock %}

{% block body %}
    <div class="container">
        <!-- hero section (career capital) -->
        <div class="journey-hero animate">
            <div class="hero-content">
                <div class="journey-icon">
                    <i class="fas fa-rocket"></i>
                </div>
                <h1>Career Capital <span>& High-Income Skills</span></h1>
                <p class="hero-description">
                    Increase your earning potential strategically — from identifying skills to negotiating offers.
                    A four‑phase roadmap designed for ambitious beginners.
                </p>
            </div>
        </div>

        <!-- intro: how our roadmaps work -->
        <div style="text-align: center; margin: 40px 0 20px;" class="animate">
            <h2 class="section-title">🧭 Your 4‑phase roadmap</h2>
            <p class="section-subtitle">
                Each phase follows the <strong>Foundation → Risk → Execution → Skill Building</strong> structure.
                Move through the articles in order or jump to what you need most.
            </p>
        </div>

        <!-- ===== PHASE 1 – FOUNDATION FIRST ===== -->
        <div class="phase-wrapper animate">
            <div class="phase-title">
                <span class="phase-number">1</span>
                <span>Foundation First · Identify & understand career capital</span>
            </div>
            <div class="article-grid">
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-dharmachakra"></i></div>
                    <h3>What is Career Capital? (Skills, Network, Reputation)</h3>
                    <p class="article-brief">Define the three pillars of career capital and why they matter more than your current job title. Start building your inventory.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 9 min read</span>
                        <a href="{{ url('app_page_show', { journey: 'career-capital', slug: 'what-is-career-capital' }) }}" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-chart-network"></i></div>
                    <h3>High‑Income Skills: Which Ones Actually Pay?</h3>
                    <p class="article-brief">Data‑driven overview of skills with the highest ROI: sales, copywriting, coding, AI prompting, and more. Find your fit.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 11 min read</span>
                        <a href="{{ url('app_page_show', { journey: 'career-capital', slug: 'high-income-skills' }) }}" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-smile"></i></div>
                    <h3>Self‑Assessment: Discover Your Natural Advantages</h3>
                    <p class="article-brief">Worksheets and prompts to uncover your strengths, interests, and the skills you can build fastest — so you don’t fight your nature.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 12 min read</span>
                        <a href="{{ url('app_page_show', { journey: 'career-capital', slug: 'self-assessment' }) }}" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-brain"></i></div>
                    <h3>Growth Mindset for Career Builders</h3>
                    <p class="article-brief">How to cultivate resilience, embrace feedback, and turn setbacks into skill‑building fuel. Essential before you start.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 8 min read</span>
                        <a href="{{ url('app_page_show', { journey: 'career-capital', slug: 'growth-mindset' }) }}" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
            </div>
        </div>

        <!-- ===== PHASE 2 – RISK MANAGEMENT ===== -->
        <div class="phase-wrapper animate">
            <div class="phase-title">
                <span class="phase-number">2</span>
                <span>Risk Management · Protect & diversify your career</span>
            </div>
            <div class="article-grid">
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-shield-virus"></i></div>
                    <h3>Job Security in a Volatile Economy</h3>
                    <p class="article-brief">Future‑proof your role by identifying which skills keep you relevant and how to monitor industry shifts without panic.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 10 min read</span>
                        <a href="{{ url('app_page_show', { journey: 'career-capital', slug: 'job-security-volatile-economy' }) }}" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-user-tie"></i></div>
                    <h3>Protecting Your Reputation & Personal Brand</h3>
                    <p class="article-brief">Simple habits to maintain a positive digital footprint, handle disagreements professionally, and build trust.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 8 min read</span>
                        <a href="{{ url('app_page_show', { journey: 'career-capital', slug: 'protecting-your-reputation-and-personal-brand' }) }}" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-heartbeat"></i></div>
                    <h3>Avoid Burnout While Upskilling</h3>
                    <p class="article-brief">Set sustainable learning boundaries, avoid “hustle culture” traps, and maintain energy for the long haul.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 7 min read</span>
                        <a href="{{ url('app_page_show', { journey: 'career-capital', slug: 'avoid-burnout' }) }}" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
