                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 9 min read</span>
                        <a href="{{ url('app_page_show', { journey: 'career-capital', slug: 'informational-interviews' }) }}" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
            </div>
        </div>

        <!-- ===== PHASE 4 – SKILL BUILDING ===== -->
        <div class="phase-wrapper animate">
            <div class="phase-title">
                <span class="phase-number">4</span>
                <span>Skill Building · Go deeper & compound your value</span>
            </div>
            <div class="article-grid">
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-crown"></i></div>
                    <h3>Master One High‑Income Skill Deeply</h3>
                    <p class="article-brief">Project‑based learning framework to move from intermediate to expert — choose a specialisation and build a standout portfolio.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 13 min read</span>
                        <a href="{{ url('app_page_show', { journey: 'career-capital', slug: 'master-one-skill' }) }}" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
                <div class="article-card">
                    <div class="article-icon"><i class="fas fa-microchip"></i></div>
                    <h3>Leverage AI & Automation to 10x Your Output</h3>
                    <p class="article-brief">Practical ways to use AI tools for research, writing, coding, and admin — saving hours while increasing quality.</p>
                    <div class="article-meta">
                        <span><i class="far fa-clock"></i> 10 min read</span>
                        <a href="{{ url('app_page_show', { journey: 'career-capital', slug: 'leverage-ai-automation' }) }}" class="read-link">Start <i class="fas fa-chevron-right"></i></a>
                    </div>
                </div>
