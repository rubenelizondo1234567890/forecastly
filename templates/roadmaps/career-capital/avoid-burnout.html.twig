{# templates/roadmaps/career-capital/avoid-burnout.html.twig #}
{% extends 'base-roadmaps.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('career_capital_css') }}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('career_capital_js') }}
{% endblock %}

{% block body %}
    <div class="container">
        <!-- article hero -->
        <div class="article-hero animate" style="background: linear-gradient(135deg, #1a202c 0%, #2d3748 100%);">
            <div class="hero-content">
                <div class="hero-icon" style="font-size: 3rem; margin-bottom: 20px;">
                    <i class="fas fa-heartbeat" style="color: var(--career-color);"></i>
                </div>
                <h1>Avoid Burnout <span>While Upskilling</span></h1>
                <p class="hero-description">
                    Set sustainable learning boundaries, avoid “hustle culture” traps, and maintain energy for the long haul.
                </p>
                <div class="phase-tag" style="background-color: rgba(156,136,255,0.2); color: #c3b9ff;">
                    <i class="fas fa-layer-group"></i> Phase 2: Risk Management · 7 min read
                </div>
            </div>
        </div>

        <!-- introduction -->
        <section class="animate">
            <h2 class="section-title">The Hidden Cost of Hustle</h2>
            <p style="font-size: 1.2rem; margin-bottom: 20px;">
                Building career capital requires consistent effort, but there’s a fine line between productive growth and destructive burnout. When you’re constantly pushing, you risk exhaustion, cynicism, and reduced effectiveness — exactly the opposite of what you’re trying to achieve.
            </p>
            <p>
                Burnout doesn’t happen overnight. It’s a gradual erosion of energy caused by chronic stress, lack of recovery, and unsustainable demands. The good news: with awareness and the right strategies, you can upskill vigorously without burning out.
            </p>
        </section>

        <!-- interactive burnout risk checker -->
        <div class="calc-card animate" style="border: 1px solid rgba(156,136,255,0.3);">
            <h2 class="calc-title"><i class="fas fa-heartbeat" style="color: var(--career-color); margin-right: 10px;"></i> Burnout Risk Checker</h2>
            <p style="font-size: 1.1rem;">Answer honestly to assess your current risk level.</p>

            <div class="calc-input">
                <label>Average weekly work/study hours</label>
                <div style="display: flex; align-items: center; gap: 20px; flex-wrap: wrap;">
                    <div style="flex:3; min-width:250px;">
                        <input type="range" id="workHours" class="cat-input" min="0" max="80" value="45" step="1">
                    </div>
                    <span class="slider-value" id="workHoursVal">45</span>
                </div>
            </div>
            <div class="calc-input">
                <label>Average sleep per night (hours)</label>
                <div style="display: flex; align-items: center; gap: 20px; flex-wrap: wrap;">
                    <div style="flex:3; min-width:250px;">
                        <input type="range" id="sleepHours" class="cat-input" min="0" max="12" value="6.5" step="0.5">
                    </div>
                    <span class="slider-value" id="sleepHoursVal">6.5</span>
                </div>
            </div>
            <div class="calc-input">
                <label>Breaks taken during work/study (per day, 0-10)</label>
                <div style="display: flex; align-items: center; gap: 20px; flex-wrap: wrap;">
                    <div style="flex:3; min-width:250px;">
                        <input type="range" id="breaks" class="cat-input" min="0" max="10" value="4" step="1">
                    </div>
                    <span class="slider-value" id="breaksVal">4</span>
                </div>
            </div>
            <div class="calc-input">
                <label>Stress level (0 = none, 10 = overwhelming)</label>
                <div style="display: flex; align-items: center; gap: 20px; flex-wrap: wrap;">
                    <div style="flex:3; min-width:250px;">
                        <input type="range" id="stressLevel" class="cat-input" min="0" max="10" value="6" step="1">
                    </div>
                    <span class="slider-value" id="stressLevelVal">6</span>
                </div>
            </div>
            <div class="calc-input">
                <label>Support system (0 = none, 10 = strong network)</label>
                <div style="display: flex; align-items: center; gap: 20px; flex-wrap: wrap;">
                    <div style="flex:3; min-width:250px;">
                        <input type="range" id="supportSystem" class="cat-input" min="0" max="10" value="5" step="1">
                    </div>
                    <span class="slider-value" id="supportSystemVal">5</span>
                </div>
            </div>

            <div style="margin: 30px 0; text-align: center;">
                <button id="burnoutCalculate" class="btn" style="background-color: var(--career-color);">Check my risk</button>
            </div>

            <div class="calc-result" style="border: 2px dashed var(--career-color);">
                <p class="result-label" style="font-size:1.2rem;">🫀 Your burnout risk</p>
                <div id="burnoutResult" style="font-size:1.3rem; font-weight:500; color:var(--dark-color);">Adjust sliders and click the button.</div>
            </div>

            <script>
                // Live update for displayed values even if not logged in
                document.querySelectorAll('.calc-input input[type=range]').forEach(slider => {
                    const display = document.getElementById(slider.id + 'Val');
                    if (display) {
                        slider.addEventListener('input', () => { display.textContent = slider.value; });
                    }
                });
            </script>
        </div>

        <!-- deeper dive: sustainable upskilling strategies -->
        <div class="card animate" style="border-top: 4px solid var(--career-color);">
            <h3 style="font-size: 1.8rem; margin-bottom: 20px;">Sustainable Upskilling Strategies</h3>
            <ul class="checklist">
                <li><i class="fas fa-check-circle"></i> <strong>Set boundaries:</strong> Designate specific hours for learning and stick to them. Protect your downtime.</li>
                <li><i class="fas fa-check-circle"></i> <strong>Use the 50/10 rule:</strong> Study for 50 minutes, then take a 10-minute break to recharge.</li>
                <li><i class="fas fa-check-circle"></i> <strong>Prioritize sleep:</strong> Sleep is when your brain consolidates learning. Skimping on sleep sabotages your progress.</li>
                <li><i class="fas fa-check-circle"></i> <strong>Celebrate small wins:</strong> Acknowledge progress to maintain motivation, not just final outcomes.</li>
                <li><i class="fas fa-check-circle"></i> <strong>Connect with peers:</strong> Learning alone is isolating. Join a community or find an accountability partner.</li>
            </ul>
        </div>

        <!-- signs of burnout and what to do -->
        <section class="animate">
            <h2 class="section-title">🚩 Early Warning Signs of Burnout</h2>
            <ul class="tip-list">
                <li><i class="fas fa-exclamation-triangle" style="color: var(--career-color);"></i> <strong>Chronic fatigue:</strong> Feeling tired even after rest.</li>
                <li><i class="fas fa-exclamation-triangle" style="color: var(--career-color);"></i> <strong>Cynicism:</strong> Becoming negative or detached about your work/learning.</li>
                <li><i class="fas fa-exclamation-triangle" style="color: var(--career-color);"></i> <strong>Reduced performance:</strong> Difficulty concentrating, making mistakes.</li>
                <li><i class="fas fa-exclamation-triangle" style="color: var(--career-color);"></i> <strong>Physical symptoms:</strong> Headaches, muscle tension, frequent illness.</li>
                <li><i class="fas fa-exclamation-triangle" style="color: var(--career-color);"></i> <strong>Loss of enjoyment:</strong> Activities that used to excite you now feel like chores.</li>
            </ul>
            <p style="margin-top:20px;">If you notice these signs, it’s time to scale back, seek support, and prioritise recovery.</p>
        </section>

        <!-- Quiz section -->
        {% if app.user and quiz %}
            <div class="quiz-container animate" style="background-color: #1e293b;">
                <h3 style="color:white; margin-top: 0;">🧠 You've already taken this quiz</h3>
                <p style="color: #e2e8f0; font-size: 1.2rem;">
                    Your score: <strong>{{ quiz.quizzScore }}%</strong>
                </p>
                <p style="color: #cbd5e0;">
                    You can retake the quiz to improve your score. Click the button below to reset it.
                </p>
                <div class="quiz-actions">
                    <a href="{{ path('app_page_show', { journey: 'career-capital', slug: 'avoid-burnout', retake: 1 }) }}"
                       class="btn"
                       style="background-color: var(--career-color); color: white; text-decoration: none;">
                        Retake Quiz
                    </a>
                </div>
            </div>
        {% else %}
            <div class="quiz-container animate" data-page-id="{{ page.id }}" style="background-color: #1e293b;">
                <h3 style="color:white; margin-top: 0;">🧠 Quick quiz: test your burnout prevention knowledge</h3>

                <div class="quiz-question">1. What is a common early sign of burnout?</div>
                <div class="quiz-options" data-question="1">
                    <div class="quiz-option" data-answer="wrong">Increased motivation</div>
                    <div class="quiz-option" data-answer="correct">Chronic fatigue</div>
                    <div class="quiz-option" data-answer="wrong">Better focus</div>
                    <div class="quiz-option" data-answer="wrong">More creativity</div>
                </div>

                <div class="quiz-question">2. According to the article, how can you structure study time to avoid burnout?</div>
                <div class="quiz-options" data-question="2">
                    <div class="quiz-option" data-answer="wrong">Study for 4 hours straight without breaks</div>
                    <div class="quiz-option" data-answer="correct">Use the 50/10 rule (50 min study, 10 min break)</div>
                    <div class="quiz-option" data-answer="wrong">Study only on weekends</div>
                    <div class="quiz-option" data-answer="wrong">Skip breaks to get more done</div>
                </div>

                <div class="quiz-question">3. Which factor is most important for consolidating learning?</div>
                <div class="quiz-options" data-question="3">
                    <div class="quiz-option" data-answer="wrong">Caffeine intake</div>
                    <div class="quiz-option" data-answer="correct">Sleep</div>
                    <div class="quiz-option" data-answer="wrong">Number of books read</div>
                    <div class="quiz-option" data-answer="wrong">Social media breaks</div>
                </div>

                <div class="quiz-question">4. What should you do if you notice early signs of burnout?</div>
                <div class="quiz-options" data-question="4">
                    <div class="quiz-option" data-answer="wrong">Push through and work harder</div>
                    <div class="quiz-option" data-answer="correct">Scale back and prioritise recovery</div>
                    <div class="quiz-option" data-answer="wrong">Ignore them, they’ll pass</div>
                    <div class="quiz-option" data-answer="wrong">Take a vacation for a month</div>
                </div>

                <div class="quiz-question">5. Which is NOT a recommended strategy for sustainable upskilling?</div>
                <div class="quiz-options" data-question="5">
                    <div class="quiz-option" data-answer="wrong">Setting boundaries</div>
                    <div class="quiz-option" data-answer="wrong">Celebrating small wins</div>
                    <div class="quiz-option" data-answer="correct">Studying 12 hours a day on weekends</div>
                    <div class="quiz-option" data-answer="wrong">Connecting with peers</div>
                </div>

                <div class="quiz-actions">
                    <button id="quiz-submit" class="btn" style="background-color: var(--career-color);">Get Score and Submit</button>
                </div>
                <div class="quiz-result"></div>
            </div>
        {% endif %}

        <!-- next articles in Phase 2 -->
        <section style="margin: 60px 0;">
            <h2 class="section-title" style="text-align: center;">Continue your Risk Management phase</h2>
            <div class="next-steps">
                <a href="{{ url('app_page_show', { journey: 'career-capital', slug: 'job-security-volatile-economy' }) }}" class="next-card" style="border-bottom-color: var(--career-color);">
                    <i class="fas fa-shield-virus"></i>
                    <h3>Job Security in a Volatile Economy</h3>
                    <p style="color: var(--gray-color);">Future‑proof your role by identifying which skills keep you relevant.</p>
                </a>
                <a href="{{ url('app_page_show', { journey: 'career-capital', slug: 'protecting-your-reputation-and-personal-brand' }) }}" class="next-card" style="border-bottom-color: var(--career-color);">
                    <i class="fas fa-user-tie"></i>
                    <h3>Protecting Your Reputation & Personal Brand</h3>
                    <p style="color: var(--gray-color);">Simple habits to maintain a positive digital footprint.</p>
                </a>
                <a href="{{ url('app_page_show', { journey: 'career-capital', slug: 'diversify-income' }) }}" class="next-card" style="border-bottom-color: var(--career-color);">
                    <i class="fas fa-random"></i>
                    <h3>Diversify Your Income</h3>
                    <p style="color: var(--gray-color);">Side hustle fundamentals without quitting your day job.</p>
                </a>
            </div>
        </section>
    </div>
{% endblock %}
